---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="מחירון — Mazeget מצגות" description="מחירון מצגות וידאו לאירועים — חבילות בסיסית, סטנדרט ופרימיום. מחירים ברורים, ללא הפתעות. בר מצווה, בת מצווה, ימי הולדת וחתונות.">
  <Header />

  <!-- Hero -->
  <section class="text-center" style="padding:3.5rem 1.5rem 3rem; background:linear-gradient(135deg,#6C22FF 0%,#E879F9 100%);">
    <h1 class="text-white font-black" style="font-size:clamp(2.2rem,5vw,3.2rem); font-family:'Secular One',sans-serif; margin-bottom:.6rem;">מחירון</h1>
    <p style="color:rgba(255,255,255,0.88); font-size:1.1rem; margin:0;">שקוף, פשוט, ללא הפתעות</p>
  </section>

  <!-- Packages -->
  <section style="padding:3.5rem 1.5rem; background:#F8F7FF;">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-center font-black text-[#12023C]" style="font-size:clamp(1.6rem,3vw,2rem); font-family:'Secular One',sans-serif; margin-bottom:2.5rem;">חבילות מצגות</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Basic -->
        <div class="bg-white rounded-2xl shadow-md text-right hover:shadow-xl transition-shadow flex flex-col" style="padding:1.75rem;">
          <div style="margin-bottom:auto;">
            <h3 class="font-black text-[#12023C]" style="font-size:1.15rem; margin-bottom:.5rem;">מצגת קצרה</h3>
            <div class="font-black text-[#6C22FF]" style="font-size:2.5rem; line-height:1; margin-bottom:1.1rem;">₪360</div>
            <ul class="text-gray-600 flex flex-col" style="font-size:.875rem; gap:.55rem; margin-bottom:1.4rem;">
              <li>&#10003; עד 3 דקות</li>
              <li>&#10003; כ-60 תמונות</li>
              <li>&#10003; כותרת פתיחה</li>
              <li>&#10003; סרטוני וידאו</li>
              <li>&#10003; מוזיקה וברכה</li>
              <li class="text-gray-400">דקה נוספת: ₪75</li>
            </ul>
          </div>
          <a href="/#contact" class="block text-center font-bold rounded-full transition-colors" style="background:#F8F7FF; color:#6C22FF; padding:.75rem 1rem; font-size:.92rem;" onmouseover="this.style.background='#6C22FF';this.style.color='white'" onmouseout="this.style.background='#F8F7FF';this.style.color='#6C22FF'">
            לפרטים
          </a>
        </div>

        <!-- Standard - highlighted -->
        <div class="rounded-2xl shadow-xl text-right relative flex flex-col" style="background:#DDD6FE; padding:1.75rem;">
          <div style="position:absolute; top:-14px; right:50%; transform:translateX(50%); background:#F59E0B; color:white; font-size:.78rem; font-weight:700; padding:.28rem 1rem; border-radius:50px; white-space:nowrap;">
            הכי פופולרי
          </div>
          <div style="margin-bottom:auto;">
            <h3 class="font-black" style="color:#12023C; font-size:1.15rem; margin-bottom:.5rem;">מצגת בסיסית</h3>
            <div class="font-black" style="color:#7C3AED; font-size:2.5rem; line-height:1; margin-bottom:1.1rem;">₪550</div>
            <ul class="flex flex-col" style="color:#4B4580; font-size:.875rem; gap:.55rem; margin-bottom:1.4rem;">
              <li>&#10003; עד 6 דקות</li>
              <li>&#10003; כ-120 תמונות</li>
              <li>&#10003; תוכן מורחב</li>
              <li>&#10003; סרטוני וידאו</li>
              <li style="color:#9490B8;">דקה נוספת: ₪75</li>
            </ul>
          </div>
          <a href="/#contact" class="block text-center font-bold rounded-full" style="background:#7C3AED; color:white; padding:.75rem 1rem; font-size:.92rem; margin-bottom:1.25rem;">
            לפרטים
          </a>
          <div style="margin:0 -1.75rem -1.75rem -1.75rem; background:linear-gradient(135deg,#F59E0B,#EA580C); padding:.6rem 1rem; border-radius:0 0 16px 16px; text-align:center;">
            <span style="color:white; font-weight:800; font-size:.74rem;">🎁 הזמן מצגת של 6 או 10 דקות וקבל דקה נוספת במתנה</span>
          </div>
        </div>

        <!-- Premium -->
        <div class="rounded-2xl shadow-md text-right flex flex-col" style="background:#4C1D95; padding:1.75rem;">
          <div style="margin-bottom:auto;">
            <h3 class="font-black" style="color:white; font-size:1.15rem; margin-bottom:.5rem;">מצגת פרימיום</h3>
            <div class="font-black" style="color:#C4B5FD; font-size:2.5rem; line-height:1; margin-bottom:1.1rem;">₪750</div>
            <ul class="flex flex-col" style="color:rgba(255,255,255,0.85); font-size:.875rem; gap:.55rem; margin-bottom:1.4rem;">
              <li>&#10003; עד 10 דקות</li>
              <li>&#10003; כ-170 תמונות</li>
              <li>&#10003; וידאו ללא הגבלה</li>
              <li>&#10003; חלוקה לנושאים</li>
              <li style="color:rgba(255,255,255,0.45);">דקה נוספת: ₪75</li>
            </ul>
          </div>
          <a href="/#contact" class="block text-center font-bold rounded-full" style="background:white; color:#4C1D95; padding:.75rem 1rem; font-size:.92rem; margin-bottom:1.25rem;">
            לפרטים
          </a>
          <div style="margin:0 -1.75rem -1.75rem -1.75rem; background:linear-gradient(135deg,#F59E0B,#EA580C); padding:.6rem 1rem; border-radius:0 0 16px 16px; text-align:center;">
            <span style="color:white; font-weight:800; font-size:.74rem;">🎁 הזמן מצגת של 6 או 10 דקות וקבל דקה נוספת במתנה</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Extra Services -->
  <section style="padding:3.5rem 1.5rem; background:white;">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-center font-black text-[#12023C]" style="font-size:clamp(1.6rem,3vw,2rem); font-family:'Secular One',sans-serif; margin-bottom:2rem;">שירותים נוספים</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">

        <div class="rounded-2xl text-right" style="background:#F8F7FF; padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1.1rem; margin-bottom:.4rem;">שיר שלטים</h3>
          <div class="font-black text-[#E879F9]" style="font-size:1.9rem; line-height:1.1; margin-bottom:.5rem;">₪540</div>
          <p class="text-gray-500" style="font-size:.875rem; margin-bottom:.2rem;">עד 3 דקות עם משתתפי המשפחה</p>
          <p class="text-gray-400" style="font-size:.85rem; margin:0;">דקה נוספת: ₪180</p>
        </div>

        <div class="rounded-2xl text-right" style="background:#F8F7FF; padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1.1rem; margin-bottom:.4rem;">סליחה על השאלה</h3>
          <div class="font-black text-[#E879F9]" style="font-size:1.9rem; line-height:1.1; margin-bottom:.5rem;">₪540</div>
          <p class="text-gray-500" style="font-size:.875rem; margin-bottom:.2rem;">עד 3 דקות בסגנון קוויז משפחתי</p>
          <p class="text-gray-400" style="font-size:.85rem; margin:0;">דקה נוספת: ₪180</p>
        </div>

      </div>

      <!-- Add-ons -->
      <div class="rounded-2xl text-right" style="background:#F8F7FF; padding:1.5rem 1.75rem;">
        <h3 class="font-black text-[#12023C]" style="font-size:1.05rem; margin-bottom:1rem;">תוספות בתשלום</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <div class="flex items-center gap-3">
            <span style="font-size:1.5rem;">🤖</span>
            <span class="text-gray-600" style="font-size:.875rem;">דיבוב AI של דמויות מוכרות</span>
          </div>
          <div class="flex items-center gap-3">
            <span style="font-size:1.5rem;">🖼️</span>
            <span class="text-gray-600" style="font-size:.875rem;">הוספת תמונות AI</span>
          </div>
          <div class="flex items-center gap-3">
            <span style="font-size:1.5rem;">🎬</span>
            <span class="text-gray-600" style="font-size:.875rem;">עריכת וידאו מיוחדת</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Info -->
  <section style="padding:3.5rem 1.5rem; background:white;">
    <div class="max-w-3xl mx-auto text-right">
      <h2 class="font-black text-[#12023C]" style="font-size:clamp(1.6rem,3vw,2rem); font-family:'Secular One',sans-serif; margin-bottom:1rem;">
        מחירון מצגות וידאו לאירועים – שקוף, ברור וללא הפתעות
      </h2>
      <p class="text-gray-600" style="font-size:1.05rem; line-height:1.8; margin-bottom:.75rem;">
        אצלנו המחיר של מצגת וידאו נקבע בצורה פשוטה וברורה — לפי אורך המצגת והיקף העבודה.
      </p>
      <p class="text-gray-600" style="font-size:1.05rem; line-height:1.8; margin-bottom:.75rem;">
        בלי אותיות קטנות, בלי תוספות מפתיעות — אתם יודעים בדיוק מה תקבלו וכמה זה עולה.
      </p>
      <p class="text-gray-600" style="font-size:1.05rem; line-height:1.8; margin-bottom:2.5rem;">
        מצגות לבר מצווה, בת מצווה, ימי הולדת ואירועים מיוחדים נבנות בהתאמה אישית מלאה — עם עריכה מקצועית, מוזיקה, כתוביות ואפקטים מתקדמים.
      </p>

      <h3 class="font-black text-[#12023C]" style="font-size:1.2rem; font-family:'Secular One',sans-serif; margin-bottom:.75rem;">איך נקבע המחיר?</h3>
      <p class="text-gray-600" style="font-size:1rem; margin-bottom:.5rem;">המחיר מושפע מכמה גורמים עיקריים:</p>
      <ul class="text-gray-600 flex flex-col" style="font-size:1rem; gap:.45rem; margin-bottom:.75rem;">
        <li>&#10003; אורך המצגת (הגורם המרכזי)</li>
        <li>&#10003; כמות התמונות והסרטונים</li>
        <li>&#10003; רמת העריכה והאפקטים</li>
        <li>&#10003; שילוב קטעי וידאו / AI (לפי צורך)</li>
      </ul>
      <p class="text-gray-500" style="font-size:.95rem; margin-bottom:2.5rem;">💡 ברוב המקרים — המחיר נקבע לפי דקות מצגת בלבד.</p>

      <h3 class="font-black text-[#12023C]" style="font-size:1.2rem; font-family:'Secular One',sans-serif; margin-bottom:.75rem;">מה כולל המחיר?</h3>
      <ul class="text-gray-600 flex flex-col" style="font-size:1rem; gap:.45rem; margin-bottom:.75rem;">
        <li>✔ עריכת וידאו מקצועית</li>
        <li>✔ התאמת מוזיקה לפי הסגנון שלכם</li>
        <li>✔ כתוביות מעוצבות</li>
        <li>✔ מעברים ואפקטים</li>
        <li>✔ שילוב תמונות וסרטונים</li>
        <li>✔ תיקוני הגהה לאחר סקיצה ראשונית</li>
      </ul>
      <p class="text-gray-500" style="font-size:.9rem; margin-bottom:2.5rem;">📌 המחיר המדויק ניתן לאחר קבלת החומרים והבנת הצרכים.</p>

      <h3 class="font-black text-[#12023C]" style="font-size:1.2rem; font-family:'Secular One',sans-serif; margin-bottom:.75rem;">למה המחיר משתלם?</h3>
      <p class="text-gray-600" style="font-size:1.05rem; line-height:1.8;">
        כי אתם לא מקבלים רק "סרטון" — אתם מקבלים חוויה מרגשת שתישאר עם המשפחה לשנים.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding:3.5rem 1.5rem; background:#F8F7FF;">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-center font-black text-[#12023C]" style="font-size:clamp(1.6rem,3vw,2rem); font-family:'Secular One',sans-serif; margin-bottom:2.5rem;">שאלות נפוצות</h2>

      <div class="flex flex-col" style="gap:1rem;">

        <div class="bg-white rounded-2xl text-right" style="padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1rem; margin-bottom:.5rem;">כמה עולה מצגת לבר מצווה או בת מצווה?</h3>
          <p class="text-gray-600" style="font-size:.9rem;">המחיר משתנה בהתאם לאורך המצגת והחומרים, אך לרוב מצגת מתחילה בכמה מאות שקלים ומעלה. הדרך המדויקת לדעת היא לשלוח חומרים ולקבל הצעת מחיר מסודרת.</p>
        </div>

        <div class="bg-white rounded-2xl text-right" style="padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1rem; margin-bottom:.5rem;">מה משפיע הכי הרבה על מחיר המצגת?</h3>
          <p class="text-gray-600" style="font-size:.9rem;">הגורם המרכזי הוא אורך המצגת. בנוסף, כמות התמונות, סרטונים ושימוש באפקטים מיוחדים יכולים להשפיע.</p>
        </div>

        <div class="bg-white rounded-2xl text-right" style="padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1rem; margin-bottom:.5rem;">האם יש תוספות מחיר לא צפויות?</h3>
          <p class="text-gray-600" style="font-size:.9rem;">לא. המחיר אצלנו שקוף וברור מראש — כל מה שסוכם בתחילת התהליך הוא מה שתשלמו.</p>
        </div>

        <div class="bg-white rounded-2xl text-right" style="padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1rem; margin-bottom:.5rem;">כמה זמן לוקח להכין מצגת?</h3>
          <p class="text-gray-600" style="font-size:.9rem;">בדרך כלל בין יום לשלושה ימים מרגע קבלת החומרים, כולל סקיצה ותיקונים.</p>
        </div>

        <div class="bg-white rounded-2xl text-right" style="padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1rem; margin-bottom:.5rem;">אפשר להכין מצגת דחופה?</h3>
          <p class="text-gray-600" style="font-size:.9rem;">כן, ניתן להכין מצגת גם בזמנים קצרים מאוד — בהתאם לזמינות.</p>
        </div>

        <div class="bg-white rounded-2xl text-right" style="padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1rem; margin-bottom:.5rem;">כמה תמונות צריך למצגת?</h3>
          <p class="text-gray-600" style="font-size:.9rem;">לרוב בין 50 ל-150 תמונות, תלוי באורך המצגת ובסגנון.</p>
        </div>

        <div class="bg-white rounded-2xl text-right" style="padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1rem; margin-bottom:.5rem;">אפשר לשלב סרטוני וידאו?</h3>
          <p class="text-gray-600" style="font-size:.9rem;">בהחלט. שילוב סרטונים מוסיף המון רגש ועניין למצגת.</p>
        </div>

        <div class="bg-white rounded-2xl text-right" style="padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1rem; margin-bottom:.5rem;">האם אתם עוזרים בבחירת מוזיקה?</h3>
          <p class="text-gray-600" style="font-size:.9rem;">כן, אנחנו מלווים אתכם בבחירת מוזיקה שמתאימה לאופי האירוע.</p>
        </div>

        <div class="bg-white rounded-2xl text-right" style="padding:1.5rem 1.75rem;">
          <h3 class="font-black text-[#12023C]" style="font-size:1rem; margin-bottom:.5rem;">מה מקבלים בסוף?</h3>
          <p class="text-gray-600" style="font-size:.9rem;">קובץ וידאו באיכות גבוהה (HD) מוכן להקרנה באירוע.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- WhatsApp CTA -->
  <section style="padding:2.5rem 1.5rem; background:white; text-align:center;">
    <p class="text-gray-500" style="font-size:.95rem; margin-bottom:1rem;">שלחו לנו כמה תמונות ונחזור אליכם עם הערכה מדויקת תוך זמן קצר</p>
    <a href="https://wa.me/97274764863" target="_blank" rel="noopener"
      style="display:inline-flex; align-items:center; gap:.6rem; background:#25D366; color:white; font-weight:700; font-size:1rem; padding:.9rem 2.25rem; border-radius:50px; text-decoration:none; box-shadow:0 4px 18px rgba(37,211,102,.35);">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.107.547 4.09 1.502 5.814L.057 23.857l6.2-1.623A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.79 9.79 0 01-5.017-1.378l-.36-.214-3.68.964.982-3.595-.234-.369A9.786 9.786 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
      קבלו הצעת מחיר מהירה בוואטסאפ
    </a>
  </section>

  <!-- CTA -->
  <section class="text-center" style="padding:3rem 1.5rem; background:linear-gradient(135deg,#6C22FF 0%,#06B6D4 100%);">
    <h2 class="font-black text-white" style="font-size:clamp(1.6rem,3vw,2rem); font-family:'Secular One',sans-serif; margin-bottom:.6rem;">מוכנים להתחיל?</h2>
    <p style="color:rgba(255,255,255,0.88); margin-bottom:1.75rem; font-size:.95rem;">צרו קשר ונבנה יחד את המצגת המושלמת</p>
    <a href="/#contact" class="inline-block font-bold rounded-full transition-transform hover:scale-105" style="background:white; color:#6C22FF; font-size:1rem; padding:.85rem 2.25rem; box-shadow:0 6px 22px rgba(0,0,0,.18);">
      צרו קשר עכשיו
    </a>
  </section>

</Layout>
