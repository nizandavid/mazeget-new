---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import { getHomepageVideos, getVideoPages } from '../lib/sheets';

const [barMitzvaVideos, batMitzvaVideos, birthdayVideos, extrasVideos] = await Promise.all([
  getHomepageVideos('bar_mitzva'),
  getHomepageVideos('bat_mitzva'),
  getHomepageVideos('birthday'),
  getHomepageVideos('other'),
]);

const slugMap = new Map<string, string>();
try {
  const pages = await getVideoPages();
  for (const p of pages) slugMap.set(p.vimeo_id, p.slug);
} catch {}
---

<Layout title="Mazeget — מצגות וידאו לאירועים משפחתיים" description="מצגות וידאו מרגשות לבר מצווה, בת מצווה, ימי הולדת וחתונות. עיצוב מקצועי עם AI, מוכן להקרנה באירוע. צרו קשר עוד היום.">
  <Header />

  <!-- ANNOUNCEMENT BAR -->
  <div id="announcement-bar" style="background:linear-gradient(135deg,#BE185D,#EF4444); padding:.75rem 6%; display:flex; justify-content:center; align-items:center; gap:1.5rem; flex-wrap:wrap; position:relative; z-index:1; transition:transform .4s ease, opacity .4s ease;">
    <span style="color:white; font-weight:800; font-size:.9rem;">🎁 הזמן מצגת של 6 או 10 דקות וקבל דקה נוספת במתנה</span>
    <a href="#contact" style="background:white; color:#BE185D; font-weight:800; font-size:.78rem; padding:.35rem 1.1rem; border-radius:50px; text-decoration:none; white-space:nowrap;">הזמינו עכשיו ←</a>
  </div>

  <!-- HERO -->
  <section style="padding: 3.5rem 6% 3rem; text-align:center; position:relative; background:linear-gradient(145deg,#1e0a4a 0%,#4c1d95 55%,#7c3aed 100%); overflow:hidden;">
    <div class="section-orb" style="width:600px;height:600px;background:#6d28d9;top:-200px;right:-150px;animation-delay:0s;opacity:0.3;"></div>
    <div class="section-orb" style="width:400px;height:400px;background:#EC4899;bottom:-100px;left:-100px;animation-delay:-8s;opacity:0.2;"></div>

    <div style="max-width:860px; margin:0 auto; position:relative; z-index:1;">

      <!-- Eyebrow -->
      <div style="display:inline-flex; align-items:center; gap:.6rem; background:rgba(255,255,255,.15); border-radius:50px; padding:.35rem 1rem; font-size:.78rem; font-weight:700; color:white; margin-bottom:1.6rem; letter-spacing:.5px;" class="reveal">
        <div style="width:7px; height:7px; border-radius:50%; background:white; animation:blink 2s ease infinite;"></div>
        מצגות וידאו לאירועים משפחתיים
      </div>

      <!-- Title -->
      <h1 style="font-size:clamp(2.6rem,5vw,4.4rem); font-weight:900; line-height:1.15; margin-bottom:1.2rem; color:white;" class="reveal">
        כל אירוע הוא סיפור.<br>
        <em class="shimmer-text" style="font-style:normal;">אנחנו הופכים אותו למצגת שמרגשת את כולם.</em>
      </h1>

      <!-- Subtitle -->
      <p style="font-size:1.05rem; color:rgba(255,255,255,.8); line-height:1.85; margin-bottom:2.2rem; max-width:580px; margin-inline:auto;" class="reveal">
        מצגות וידאו מקצועיות עם עריכה מדויקת, מוזיקה מרגשת וטכנולוגיית AI יצירתית.
      </p>

      <!-- CTA -->
      <div style="display:flex; justify-content:center; gap:1rem; flex-wrap:wrap;" class="reveal">
        <a href="#contact" style="display:inline-flex; align-items:center; gap:.5rem; background:linear-gradient(135deg,#EC4899,#9D5CF6); color:#fff; padding:.85rem 2rem; border-radius:50px; font-weight:700; font-size:.95rem; text-decoration:none; box-shadow:0 8px 28px rgba(236,72,153,.4);">
          קבלו הצעת מחיר
        </a>
        <a href="#gallery" style="display:inline-flex; align-items:center; gap:.5rem; background:transparent; border:1.5px solid rgba(255,255,255,.4); color:white; padding:.85rem 2rem; border-radius:50px; font-weight:600; font-size:.95rem; text-decoration:none;">
          ▷ צפו בדוגמאות
        </a>
      </div>
    </div>
  </section>

  <!-- VIDEO — מצד לצד, ללא שוליים -->
  <div style="position:relative; line-height:0; background:#F5F3FF; display:flex; justify-content:center;">
    <video id="hero-video" autoplay muted loop playsinline style="width:75%; display:block; object-fit:contain;">
      <source src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/Ai-story-web.mp4" type="video/mp4" />
    </video>
    <!-- כפתור סאונד -->
    <div style="position:absolute; bottom:-28px; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:6px; z-index:10;">
      <button id="hero-sound-btn" class="sound-round-btn">
        <svg id="hero-sound-icon-muted" width="26" height="26" viewBox="0 0 24 24" fill="white">
          <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
        </svg>
        <svg id="hero-sound-icon-on" width="26" height="26" viewBox="0 0 24 24" fill="white" style="display:none;">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM19 12c0-2.95-1.68-5.5-4.15-6.78v2.22c1.55 1.1 2.58 2.88 2.58 4.56s-1.03 3.46-2.58 4.56v2.22C17.32 17.5 19 14.95 19 12z"/>
        </svg>
      </button>
      <span id="hero-sound-label" style="font-size:.72rem; font-weight:700; color:#4c1d95; white-space:nowrap; background:white; box-shadow:0 2px 8px rgba(0,0,0,.1); padding:.2rem .75rem; border-radius:50px;">מומלץ להפעיל סאונד</span>
    </div>
  </div>
  <!-- spacer for sound button overlap -->
  <div style="height:44px; background:#F5F3FF;"></div>

  <!-- GALLERY HEADING -->
  <section id="gallery" style="padding:1.5rem 6% 0; background:#F5F3FF; text-align:center;">
    <div style="max-width:800px; margin:0 auto;">
      <h2 style="font-size:clamp(1.9rem,3.5vw,2.8rem); font-weight:900; color:#12023C; margin-bottom:.6rem; font-family:'Secular One',sans-serif;">
        דוגמאות למצגות וידאו מקצועיות
      </h2>
      <p style="font-size:1rem; color:#6b7280; line-height:1.7;">בחרו קטגוריה וצפו במצגות אמיתיות שיצרנו — כל אחת מותאמת אישית לאירוע ולמשפחה</p>
    </div>
  </section>

  <!-- BAR MITZVAH -->
  <section style="padding:2rem 6% 3rem; background:#F5F3FF; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#EDE9FE; color:var(--purple); font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.5rem;">בר מצווה</div>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.4rem); font-weight:900; color:var(--text); margin-bottom:.5rem;">מהרגע הראשון עד הרגע הגדול</h2>
          <p style="font-size:.9rem; color:var(--text-muted); max-width:480px; line-height:1.7;">מצגת שמספרת את הסיפור האישי — מהלידה ועד הגדלה, עם רגעים שיחרטו בזיכרון לנצח.</p>
        </div>
        <a href="/מצגות/bar_mitzva" style="display:inline-flex; align-items:center; gap:.5rem; background:var(--purple); color:white; padding:.7rem 1.6rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; white-space:nowrap; flex-shrink:0;">לכל המצגות ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;" class="reveal thumb-grid">
        {barMitzvaVideos.map(v => (
          <div style="border-radius:18px; overflow:hidden; background:white; box-shadow:0 4px 24px rgba(0,0,0,.08); cursor:pointer;" class="video-card" data-video-id={v.vimeo_id} data-video-type="vimeo" data-page-slug={slugMap.get(v.vimeo_id) || `video-${v.vimeo_id}`}>
            <div style="aspect-ratio:16/9; position:relative; background:#1a0533; overflow:hidden;">
              {v.thumbnail && <img src={v.thumbnail} alt={v.title} style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy" />}
              <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
                <div style="width:64px; height:64px; border-radius:50%; background:rgba(255,255,255,.92); display:flex; align-items:center; justify-content:center; box-shadow:0 6px 24px rgba(0,0,0,.3);">
                  <svg width="22" height="22" fill="#7C3AED" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            <div style="padding:1.1rem 1.2rem; text-align:right;">
              <div style="display:flex; align-items:center; justify-content:space-between; flex-direction:row-reverse; gap:.6rem; margin-bottom:.5rem;">
                <h3 style="font-size:.97rem; font-weight:800; color:var(--text); margin:0;">{v.title}</h3>
                <span style="background:#EDE9FE; color:#7C3AED; font-size:.7rem; font-weight:700; padding:.22rem .75rem; border-radius:50px; white-space:nowrap; flex-shrink:0;">בר מצווה</span>
              </div>
              <p style="font-size:.8rem; color:var(--text-muted); line-height:1.6; margin:0;">{v.description || 'מצגת וידאו מרגשת לאירוע הגדול'}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BAT MITZVAH -->
  <section style="padding:2.5rem 6% 3rem; background:#FFF0F8; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#FCE7F3; color:#BE185D; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.5rem;">בת מצווה</div>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.4rem); font-weight:900; color:var(--text); margin-bottom:.5rem;">מצגת שמדברת ישר ללב</h2>
          <p style="font-size:.9rem; color:var(--text-muted); max-width:480px; line-height:1.7;">מצגת מיוחדת שמדגישה את הייחוד והאישיות, עם תמונות ורגעים שנבחרו בקפידה לאורך השנים.</p>
        </div>
        <a href="/מצגות/bat_mitzva" style="display:inline-flex; align-items:center; gap:.5rem; background:#BE185D; color:white; padding:.7rem 1.6rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; white-space:nowrap; flex-shrink:0;">לכל המצגות ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;" class="reveal thumb-grid">
        {batMitzvaVideos.map(v => (
          <div style="border-radius:18px; overflow:hidden; background:white; box-shadow:0 4px 24px rgba(0,0,0,.08); cursor:pointer;" class="video-card" data-video-id={v.vimeo_id} data-video-type="vimeo" data-page-slug={slugMap.get(v.vimeo_id) || `video-${v.vimeo_id}`}>
            <div style="aspect-ratio:16/9; position:relative; background:#500724; overflow:hidden;">
              {v.thumbnail && <img src={v.thumbnail} alt={v.title} style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy" />}
              <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
                <div style="width:64px; height:64px; border-radius:50%; background:rgba(255,255,255,.92); display:flex; align-items:center; justify-content:center; box-shadow:0 6px 24px rgba(0,0,0,.3);">
                  <svg width="22" height="22" fill="#BE185D" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            <div style="padding:1.1rem 1.2rem; text-align:right;">
              <div style="display:flex; align-items:center; justify-content:space-between; flex-direction:row-reverse; gap:.6rem; margin-bottom:.5rem;">
                <h3 style="font-size:.97rem; font-weight:800; color:var(--text); margin:0;">{v.title}</h3>
                <span style="background:#FCE7F3; color:#BE185D; font-size:.7rem; font-weight:700; padding:.22rem .75rem; border-radius:50px; white-space:nowrap; flex-shrink:0;">בת מצווה</span>
              </div>
              <p style="font-size:.8rem; color:var(--text-muted); line-height:1.6; margin:0;">{v.description || 'מצגת וידאו שמדברת ישר ללב'}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BIRTHDAYS -->
  <section style="padding:2.5rem 6% 3rem; background:#FFFBEB; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#FEF3C7; color:#92400E; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.5rem;">ימי הולדת</div>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.4rem); font-weight:900; color:var(--text); margin-bottom:.5rem;">כי כל יום הולדת מגיע לסיפור שלו</h2>
          <p style="font-size:.9rem; color:var(--text-muted); max-width:480px; line-height:1.7;">מצגת צבעונית ומרגשת לכל גיל — מיום הולדת ראשון ועד יובל זהב, עם הרגעים שהכי אוהבים.</p>
        </div>
        <a href="/מצגות/birthday" style="display:inline-flex; align-items:center; gap:.5rem; background:#D97706; color:white; padding:.7rem 1.6rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; white-space:nowrap; flex-shrink:0;">לכל המצגות ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;" class="reveal thumb-grid">
        {birthdayVideos.map(v => (
          <div style="border-radius:18px; overflow:hidden; background:white; box-shadow:0 4px 24px rgba(0,0,0,.08); cursor:pointer;" class="video-card" data-video-id={v.vimeo_id} data-video-type="vimeo" data-page-slug={slugMap.get(v.vimeo_id) || `video-${v.vimeo_id}`}>
            <div style="aspect-ratio:16/9; position:relative; background:#451a03; overflow:hidden;">
              {v.thumbnail && <img src={v.thumbnail} alt={v.title} style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy" />}
              <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
                <div style="width:64px; height:64px; border-radius:50%; background:rgba(255,255,255,.92); display:flex; align-items:center; justify-content:center; box-shadow:0 6px 24px rgba(0,0,0,.3);">
                  <svg width="22" height="22" fill="#D97706" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            <div style="padding:1.1rem 1.2rem; text-align:right;">
              <div style="display:flex; align-items:center; justify-content:space-between; flex-direction:row-reverse; gap:.6rem; margin-bottom:.5rem;">
                <h3 style="font-size:.97rem; font-weight:800; color:var(--text); margin:0;">{v.title}</h3>
                <span style="background:#FEF3C7; color:#92400E; font-size:.7rem; font-weight:700; padding:.22rem .75rem; border-radius:50px; white-space:nowrap; flex-shrink:0;">יום הולדת</span>
              </div>
              <p style="font-size:.8rem; color:var(--text-muted); line-height:1.6; margin:0;">{v.description || 'מצגת וידאו מרגשת ליום המיוחד'}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXTRAS -->
  <section style="padding:2.5rem 6% 3rem; background:#F0FDFA; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#CCFBF1; color:#0F766E; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.5rem;">תוספות מיוחדות</div>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.4rem); font-weight:900; color:var(--text); margin-bottom:.5rem;">עוד קצת קסם לאירוע</h2>
          <p style="font-size:.9rem; color:var(--text-muted); max-width:480px; line-height:1.7;">שיר שלטים, "סליחה על השאלה", דיבוב AI של דמויות מוכרות ועוד — תוספות שהופכות כל אירוע לבלתי נשכח.</p>
        </div>
        <a href="/מצגות/other" style="display:inline-flex; align-items:center; gap:.5rem; background:#0D9488; color:white; padding:.7rem 1.6rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; white-space:nowrap; flex-shrink:0;">לכל המצגות השונות ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;" class="reveal thumb-grid">
        {extrasVideos.map(v => (
          <div style="border-radius:18px; overflow:hidden; background:white; box-shadow:0 4px 24px rgba(0,0,0,.08); cursor:pointer;" class="video-card" data-video-id={v.vimeo_id} data-video-type="vimeo" data-page-slug={slugMap.get(v.vimeo_id) || `video-${v.vimeo_id}`}>
            <div style="aspect-ratio:16/9; position:relative; background:#042f2e; overflow:hidden;">
              {v.thumbnail && <img src={v.thumbnail} alt={v.title} style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy" />}
              <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
                <div style="width:64px; height:64px; border-radius:50%; background:rgba(255,255,255,.92); display:flex; align-items:center; justify-content:center; box-shadow:0 6px 24px rgba(0,0,0,.3);">
                  <svg width="22" height="22" fill="#0D9488" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            <div style="padding:1.1rem 1.2rem; text-align:right;">
              <div style="display:flex; align-items:center; justify-content:space-between; flex-direction:row-reverse; gap:.6rem; margin-bottom:.5rem;">
                <h3 style="font-size:.97rem; font-weight:800; color:var(--text); margin:0;">{v.title}</h3>
                <span style="background:#CCFBF1; color:#0F766E; font-size:.7rem; font-weight:700; padding:.22rem .75rem; border-radius:50px; white-space:nowrap; flex-shrink:0;">תוספת</span>
              </div>
              <p style="font-size:.8rem; color:var(--text-muted); line-height:1.6; margin:0;">{v.description || 'תוספת מיוחדת לאירוע שלכם'}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <Contact />

  <!-- LIGHTBOX -->
  <div id="video-lightbox" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.9); z-index:600; align-items:center; justify-content:center; padding:1rem;">
    <button id="lightbox-close" style="position:absolute; top:1.2rem; left:1.2rem; background:rgba(255,255,255,.15); border:none; color:white; width:46px; height:46px; border-radius:50%; font-size:1.8rem; cursor:pointer; display:flex; align-items:center; justify-content:center; font-family:'Heebo',sans-serif; line-height:1;">×</button>
    <div id="lightbox-content" style="width:min(960px,95vw); aspect-ratio:16/9; border-radius:12px; overflow:hidden; background:#000;"></div>
  </div>

  <!-- POPUP -->
  <div id="popup-overlay" style="position:fixed; inset:0; background:rgba(0,0,0,.4); z-index:500; display:flex; align-items:center; justify-content:center; padding:1.5rem; backdrop-filter:blur(4px);">
    <div style="background:#ffffff; border-radius:28px; padding:2.5rem 2rem; max-width:420px; width:100%; position:relative; box-shadow:0 40px 80px rgba(0,0,0,.25); text-align:center;">
      <button id="popup-close" style="position:absolute; top:1rem; left:1rem; background:#f3e8ff; border:none; color:#6d28d9; width:34px; height:34px; border-radius:50%; font-size:1.4rem; cursor:pointer; display:flex; align-items:center; justify-content:center; font-family:'Heebo',sans-serif;">×</button>
      <div id="popup-timer" style="position:absolute; top:1rem; right:1rem; font-size:.75rem; color:#9ca3af; font-family:'Heebo',sans-serif;">נסגר בעוד <span id="popup-countdown">8</span>״</div>
      <div style="font-size:2.8rem; margin-bottom:.8rem;">🎁</div>
      <div style="display:inline-block; background:linear-gradient(135deg,#EC4899,#F59E0B); color:white; font-size:.7rem; font-weight:800; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:1rem;">מבצע מיוחד</div>
      <h3 style="font-size:1.5rem; font-weight:900; color:#1e0a4a; margin-bottom:.8rem; line-height:1.3;">הזמן מצגת של 6 או 10 דקות<br>וקבל דקה נוספת במתנה!</h3>
      <p style="color:#6b7280; font-size:.88rem; margin-bottom:1.8rem; line-height:1.6;">מבצע מיוחד לזמן מוגבל — אל תפספסו!</p>
      <a href="#contact" id="popup-cta" style="display:inline-flex; align-items:center; gap:.5rem; background:linear-gradient(135deg,#EC4899,#F59E0B); color:white; padding:.85rem 2.2rem; border-radius:50px; font-weight:700; font-size:.95rem; text-decoration:none; box-shadow:0 8px 28px rgba(236,72,153,.4);">
        הזמינו עכשיו ←
      </a>
    </div>
  </div>

</Layout>

<script>
  // ── Popup ──────────────────────────────────────────
  function closePopup() {
    const el = document.getElementById('popup-overlay');
    if (el) el.style.display = 'none';
  }
  document.getElementById('popup-close')?.addEventListener('click', closePopup);
  document.getElementById('popup-cta')?.addEventListener('click', closePopup);
  document.getElementById('popup-overlay')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('popup-overlay')) closePopup();
  });

  // טיימר 8 שניות
  let seconds = 8;
  const countdownEl = document.getElementById('popup-countdown');
  const timer = setInterval(() => {
    seconds--;
    if (countdownEl) countdownEl.textContent = String(seconds);
    if (seconds <= 0) { clearInterval(timer); closePopup(); }
  }, 1000);

  // ── Hero sound toggle ───────────────────────────────
  const heroVideo  = document.getElementById('hero-video') as HTMLVideoElement;
  const soundBtn   = document.getElementById('hero-sound-btn');
  const iconMuted  = document.getElementById('hero-sound-icon-muted') as HTMLElement;
  const iconOn     = document.getElementById('hero-sound-icon-on')    as HTMLElement;
  const soundLabel = document.getElementById('hero-sound-label')      as HTMLElement;
  soundBtn?.addEventListener('click', () => {
    if (!heroVideo) return;
    heroVideo.muted = !heroVideo.muted;
    iconMuted.style.display  = heroVideo.muted ? '' : 'none';
    iconOn.style.display     = heroVideo.muted ? 'none' : '';
    soundLabel.textContent   = heroVideo.muted ? 'מומלץ להפעיל סאונד' : 'השתקה';
  });

  // ── Announcement bar hide on scroll ────────────────
  window.addEventListener('scroll', () => {
    const bar = document.getElementById('announcement-bar');
    if (!bar) return;
    if (window.scrollY > 100) {
      bar.style.transform = 'translateY(-100%)';
      bar.style.opacity = '0';
      bar.style.pointerEvents = 'none';
    } else {
      bar.style.transform = 'translateY(0)';
      bar.style.opacity = '1';
      bar.style.pointerEvents = 'auto';
    }
  });

  // ── Video Lightbox ──────────────────────────────────
  function closeLightbox() {
    const lb = document.getElementById('video-lightbox');
    const content = document.getElementById('lightbox-content');
    if (lb) lb.style.display = 'none';
    if (content) content.innerHTML = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.video-card').forEach(card => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      const slug = el.dataset.pageSlug;
      if (slug) { window.location.href = '/matzget/' + slug; return; }
      const type = el.dataset.videoType;
      const id   = el.dataset.videoId;
      const src  = el.dataset.videoSrc;
      const content = document.getElementById('lightbox-content');
      const lb = document.getElementById('video-lightbox');
      if (!content || !lb) return;

      if (type === 'vimeo' && id) {
        content.innerHTML = `<iframe src="https://player.vimeo.com/video/${id}?autoplay=1&color=7C3AED" width="100%" height="100%" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>`;
      } else if (type === 'mp4' && src) {
        content.innerHTML = `<video src="${src}" controls autoplay playsinline style="width:100%;height:100%;background:#000;"></video>`;
      }

      lb.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    });
  });

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('video-lightbox')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('video-lightbox')) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<style>
  .video-card { transition: transform .2s ease, box-shadow .2s ease; }

  /* ── כפתור סאונד עגול ── */
  .sound-round-btn {
    width: 60px; height: 60px; border-radius: 50%;
    background: linear-gradient(135deg, #7C3AED, #4c1d95);
    border: 4px solid white;
    cursor: pointer; z-index: 10;
    display: flex; align-items: center; justify-content: center;
    padding: 0;
    box-shadow: 0 8px 24px rgba(124,58,237,.4);
    animation: sound-pulse 2.2s ease-out infinite;
    transition: transform .2s;
  }
  .sound-round-btn:hover { transform: scale(1.07); }
  @keyframes sound-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(124,58,237,.55), 0 8px 24px rgba(124,58,237,.35); }
    70%  { box-shadow: 0 0 0 14px rgba(124,58,237,0), 0 8px 24px rgba(124,58,237,.35); }
    100% { box-shadow: 0 0 0 0 rgba(124,58,237,0),   0 8px 24px rgba(124,58,237,.35); }
  }
  .video-card:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(0,0,0,.13) !important; }

  @media(max-width:768px){
    div[style*="grid-template-columns:repeat(4,1fr)"] {
      grid-template-columns: repeat(2,1fr) !important;
    }
    .thumb-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
