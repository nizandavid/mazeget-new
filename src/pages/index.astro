                <div class="play-btn purple-play">
                  <svg width="20" height="20" fill="#7C3AED" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            <div class="video-card-body">
              <div class="video-card-meta">
                <h3 class="video-card-title">{v.title}</h3>
                <span class="video-badge purple-badge">בר מצווה</span>
              </div>
              <p class="video-card-desc">{v.description || 'מצגת וידאו מרגשת לאירוע הגדול'}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BAT MITZVAH -->
  <section style="padding:2rem 6%; background:#FFF0F8; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem; flex-wrap:wrap; gap:1rem;">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#FCE7F3; color:#BE185D; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.6rem;">בת מצווה</div>
          <h2 style="font-size:clamp(1.7rem,2.5vw,2.4rem); font-weight:900; color:#1A1040; margin-bottom:.4rem; font-family:'Secular One',sans-serif;">מצגת שמדברת ישר ללב</h2>
          <p style="font-size:.92rem; color:#9490B8; max-width:480px; line-height:1.75;">מצגת מיוחדת שמדגישה את הייחוד והאישיות, עם תמונות ורגעים שנבחרו בקפידה לאורך השנים.</p>
        </div>
        <a href="/מצגות/bat_mitzva" class="section-cta-btn pink-btn">לכל המצגות ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.8rem;" class="reveal thumb-grid">
        {batMitzvaVideos.map(v => (
          <div class="video-card" data-video-id={v.vimeo_id} data-video-type="vimeo" data-page-slug={slugMap.get(v.vimeo_id) || `video-${v.vimeo_id}`}>
            <div class="video-thumb-wrap" style="background:#500724;">
              {v.thumbnail && <img src={v.thumbnail} alt={v.title} class="video-thumb-img" width="640" height="360" loading="lazy" />}
              <div class="video-play-overlay">
                <div class="play-btn pink-play">
                  <svg width="20" height="20" fill="#BE185D" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
