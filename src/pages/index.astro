---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import { getHomepageVideos, getVideoPages } from '../lib/sheets';

const [barMitzvaVideos, batMitzvaVideos, birthdayVideos, extrasVideos] = await Promise.all([
  getHomepageVideos('bar_mitzva'),
  getHomepageVideos('bat_mitzva'),
  getHomepageVideos('birthday'),
  getHomepageVideos('other'),
]);

const slugMap = new Map<string, string>();
try {
  const pages = await getVideoPages();
  for (const p of pages) slugMap.set(p.vimeo_id, p.slug);
} catch {}
---

<Layout title="Mazeget — מצגות וידאו לאירועים משפחתיים" description="מצגות וידאו מרגשות לבר מצווה, בת מצווה, ימי הולדת וחתונות. עיצוב מקצועי עם AI, מוכן להקרנה באירוע. צרו קשר עוד היום.">
  <Header />

  <!-- ANNOUNCEMENT BAR -->
  <div id="announcement-bar" style="background:linear-gradient(135deg,#BE185D,#EF4444); padding:.85rem 6%; display:flex; justify-content:center; align-items:center; gap:1.5rem; flex-wrap:wrap; position:relative; z-index:1; transition:transform .4s ease, opacity .4s ease;">
    <span style="color:white; font-weight:800; font-size:.9rem;">🎁 הזמן מצגת של 6 או 10 דקות וקבל דקה נוספת במתנה</span>
