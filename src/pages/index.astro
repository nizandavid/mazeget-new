---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="Mazeget — מצגות וידאו לאירועים משפחתיים">
  <Header />

  <!-- ANNOUNCEMENT BAR -->
  <div id="announcement-bar" style="background:linear-gradient(135deg,#BE185D,#EF4444); padding:.75rem 6%; display:flex; justify-content:center; align-items:center; gap:1.5rem; flex-wrap:wrap; position:relative; z-index:1; transition:transform .4s ease, opacity .4s ease;">
    <span style="color:white; font-weight:800; font-size:.9rem;">🎁 הזמן מצגת של 6 או 10 דקות וקבל דקה נוספת במתנה</span>
    <a href="#contact" style="background:white; color:#BE185D; font-weight:800; font-size:.78rem; padding:.35rem 1.1rem; border-radius:50px; text-decoration:none; white-space:nowrap;">הזמינו עכשיו ←</a>
  </div>

  <!-- HERO -->
  <section style="padding: 5rem 6% 4rem; text-align:center; position:relative; background:linear-gradient(145deg,#1e0a4a 0%,#4c1d95 55%,#7c3aed 100%); overflow:hidden;">
    <div class="section-orb" style="width:600px;height:600px;background:#6d28d9;top:-200px;right:-150px;animation-delay:0s;opacity:0.3;"></div>
    <div class="section-orb" style="width:400px;height:400px;background:#EC4899;bottom:-100px;left:-100px;animation-delay:-8s;opacity:0.2;"></div>

    <div style="max-width:860px; margin:0 auto; position:relative; z-index:1;">

      <!-- Eyebrow -->
      <div style="display:inline-flex; align-items:center; gap:.6rem; background:rgba(255,255,255,.15); border-radius:50px; padding:.35rem 1rem; font-size:.78rem; font-weight:700; color:white; margin-bottom:1.6rem; letter-spacing:.5px;" class="reveal">
        <div style="width:7px; height:7px; border-radius:50%; background:white; animation:blink 2s ease infinite;"></div>
        מצגות וידאו לאירועים משפחתיים
      </div>

      <!-- Title -->
      <h1 style="font-size:clamp(2.6rem,5vw,4.4rem); font-weight:900; line-height:1.1; margin-bottom:1.2rem; color:white;" class="reveal">
        כל אירוע מגיע לסיפור<br>
        <em class="shimmer-text" style="font-style:normal;">שמרגש את כולם</em>
      </h1>

      <!-- Subtitle -->
      <p style="font-size:1.05rem; color:rgba(255,255,255,.8); line-height:1.85; margin-bottom:2.2rem; max-width:580px; margin-inline:auto;" class="reveal">
        מצגות וידאו מקצועיות עם תזמון מושלם, כתוביות שנוגעות בלב, וקסם של AI —<br>שהופכות זיכרונות לחוויה שתישאר לנצח.
      </p>

      <!-- CTA -->
      <div style="display:flex; justify-content:center; gap:1rem; flex-wrap:wrap; margin-bottom:2.5rem;" class="reveal">
        <a href="#contact" style="display:inline-flex; align-items:center; gap:.5rem; background:linear-gradient(135deg,#EC4899,#9D5CF6); color:#fff; padding:.85rem 2rem; border-radius:50px; font-weight:700; font-size:.95rem; text-decoration:none; box-shadow:0 8px 28px rgba(236,72,153,.4);">
          קבלו הצעת מחיר
        </a>
        <a href="#gallery" style="display:inline-flex; align-items:center; gap:.5rem; background:transparent; border:1.5px solid rgba(255,255,255,.4); color:white; padding:.85rem 2rem; border-radius:50px; font-weight:600; font-size:.95rem; text-decoration:none;">
          ▷ צפו בדוגמאות
        </a>
      </div>

      <!-- VIDEO -->
      <div style="border-radius:24px; overflow:hidden; box-shadow:0 32px 64px rgba(0,0,0,.4), 0 8px 24px rgba(0,0,0,.2); border:1px solid rgba(255,255,255,.15); margin-bottom:2.5rem;" class="reveal">
        <video autoplay muted loop playsinline style="width:100%; display:block;">
          <source src="https://mazeget.com/wp-content/uploads/2025/09/Ai-story-10mb.mp4" type="video/mp4" />
        </video>
      </div>

      <!-- Trust numbers -->
      <div style="display:flex; justify-content:center; align-items:center; gap:2.5rem; flex-wrap:wrap; padding-top:2rem; border-top:1px solid rgba(255,255,255,.2);" class="reveal">
        <div style="text-align:center;">
          <div style="font-size:1.8rem; font-weight:900; color:#C4B5FD;">500+</div>
          <div style="font-size:.75rem; color:rgba(255,255,255,.65); margin-top:.2rem;">מצגות שנוצרו</div>
        </div>
        <div style="width:1px; height:36px; background:rgba(255,255,255,.2);"></div>
        <div style="text-align:center;">
          <div style="font-size:1.8rem; font-weight:900; color:#C4B5FD;">3–4</div>
          <div style="font-size:.75rem; color:rgba(255,255,255,.65); margin-top:.2rem;">ימי עבודה</div>
        </div>
        <div style="width:1px; height:36px; background:rgba(255,255,255,.2);"></div>
        <div style="text-align:center;">
          <div style="font-size:1.8rem; font-weight:900; color:#C4B5FD;">15+</div>
          <div style="font-size:.75rem; color:rgba(255,255,255,.65); margin-top:.2rem;">שנות ניסיון</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BAR MITZVAH -->
  <section style="padding:5rem 6%; background:#F5F3FF; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:2.5rem; flex-wrap:wrap; gap:1.5rem;" class="reveal">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#EDE9FE; color:var(--purple); font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.8rem;">✡️ בר מצווה</div>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.4rem); font-weight:900; color:var(--text); margin-bottom:.5rem;">מהרגע הראשון עד הרגע הגדול</h2>
          <p style="font-size:.9rem; color:var(--text-muted); max-width:480px; line-height:1.7;">מצגת שמספרת את הסיפור האישי — מהלידה ועד הגדלה, עם רגעים שיחרטו בזיכרון לנצח.</p>
        </div>
        <a href="/מצגות/bar_mitzva" style="display:inline-flex; align-items:center; gap:.5rem; background:var(--purple); color:white; padding:.7rem 1.6rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; white-space:nowrap; flex-shrink:0;">לכל המצגות ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.2rem;" class="reveal thumb-grid">
        {[1,2,3].map(() => (
          <div style="border-radius:16px; overflow:hidden; aspect-ratio:16/9; position:relative; background:linear-gradient(160deg,#EDE9FE 0%,#C4B5FD 50%,#7C3AED 100%);">
            <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
              <div style="width:52px; height:52px; border-radius:50%; background:rgba(255,255,255,.9); display:flex; align-items:center; justify-content:center;">
                <svg width="18" height="18" fill="#7C3AED" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BAT MITZVAH -->
  <section style="padding:5rem 6%; background:#FFF0F8; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:2.5rem; flex-wrap:wrap; gap:1.5rem;" class="reveal">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#FCE7F3; color:#BE185D; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.8rem;">🌸 בת מצווה</div>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.4rem); font-weight:900; color:var(--text); margin-bottom:.5rem;">מצגת שמדברת ישר ללב</h2>
          <p style="font-size:.9rem; color:var(--text-muted); max-width:480px; line-height:1.7;">מצגת מיוחדת שמדגישה את הייחוד והאישיות, עם תמונות ורגעים שנבחרו בקפידה לאורך השנים.</p>
        </div>
        <a href="/מצגות/bat_mitzva" style="display:inline-flex; align-items:center; gap:.5rem; background:#BE185D; color:white; padding:.7rem 1.6rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; white-space:nowrap; flex-shrink:0;">לכל המצגות ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.2rem;" class="reveal thumb-grid">
        {[1,2,3].map(() => (
          <div style="border-radius:16px; overflow:hidden; aspect-ratio:16/9; position:relative; background:linear-gradient(160deg,#FCE7F3 0%,#F9A8D4 50%,#EC4899 100%);">
            <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
              <div style="width:52px; height:52px; border-radius:50%; background:rgba(255,255,255,.9); display:flex; align-items:center; justify-content:center;">
                <svg width="18" height="18" fill="#EC4899" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BIRTHDAYS -->
  <section style="padding:5rem 6%; background:#FFFBEB; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:2.5rem; flex-wrap:wrap; gap:1.5rem;" class="reveal">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#FEF3C7; color:#92400E; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.8rem;">🎂 ימי הולדת</div>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.4rem); font-weight:900; color:var(--text); margin-bottom:.5rem;">כי כל יום הולדת מגיע לסיפור שלו</h2>
          <p style="font-size:.9rem; color:var(--text-muted); max-width:480px; line-height:1.7;">מצגת צבעונית ומרגשת לכל גיל — מיום הולדת ראשון ועד יובל זהב, עם הרגעים שהכי אוהבים.</p>
        </div>
        <a href="/מצגות/birthday" style="display:inline-flex; align-items:center; gap:.5rem; background:#D97706; color:white; padding:.7rem 1.6rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; white-space:nowrap; flex-shrink:0;">לכל המצגות ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.2rem;" class="reveal thumb-grid">
        {[1,2,3].map(() => (
          <div style="border-radius:16px; overflow:hidden; aspect-ratio:16/9; position:relative; background:linear-gradient(160deg,#FEF3C7 0%,#FCD34D 50%,#D97706 100%);">
            <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
              <div style="width:52px; height:52px; border-radius:50%; background:rgba(255,255,255,.9); display:flex; align-items:center; justify-content:center;">
                <svg width="18" height="18" fill="#D97706" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXTRAS -->
  <section style="padding:5rem 6%; background:#F0FDFA; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:2.5rem; flex-wrap:wrap; gap:1.5rem;" class="reveal">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#CCFBF1; color:#0F766E; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.8rem;">✨ תוספות מיוחדות</div>
          <h2 style="font-size:clamp(1.6rem,2.5vw,2.4rem); font-weight:900; color:var(--text); margin-bottom:.5rem;">עוד קצת קסם לאירוע</h2>
          <p style="font-size:.9rem; color:var(--text-muted); max-width:480px; line-height:1.7;">שיר שלטים, "סליחה על השאלה", דיבוב AI של דמויות מוכרות ועוד — תוספות שהופכות כל אירוע לבלתי נשכח.</p>
        </div>
        <a href="/מחירון" style="display:inline-flex; align-items:center; gap:.5rem; background:#0D9488; color:white; padding:.7rem 1.6rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; white-space:nowrap; flex-shrink:0;">לפרטים ומחירים ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.2rem;" class="reveal thumb-grid">
        {[
          { title:'שיר שלטים', desc:'שיר מותאם אישית עם כל המשפחה', icon:'🎵' },
          { title:'סליחה על השאלה', desc:'קוויז משפחתי מצחיק ומרגש', icon:'🎯' },
          { title:'תוספות AI', desc:'דיבוב, תמונות AI ועריכה מיוחדת', icon:'🤖' },
        ].map(item => (
          <div style="border-radius:16px; padding:2rem; background:white; border:1.5px solid #CCFBF1; text-align:right; display:flex; flex-direction:column; gap:.8rem; box-shadow:0 4px 16px rgba(13,148,136,.07);">
            <div style="font-size:2.2rem;">{item.icon}</div>
            <div style="font-size:1.05rem; font-weight:800; color:var(--text);">{item.title}</div>
            <div style="font-size:.85rem; color:var(--text-muted); line-height:1.6;">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section style="padding:5rem 6%; position:relative; background:linear-gradient(180deg,#b8f0e6 0%,#d8faf3 100%);">

    <div style="max-width:1100px; margin:0 auto;">
      <div style="text-align:center; margin-bottom:3.5rem;" class="reveal">
        <div style="display:inline-block; background:var(--purple-light); color:var(--purple); font-size:.72rem; font-weight:700; letter-spacing:2.5px; text-transform:uppercase; padding:.35rem 1rem; border-radius:50px; margin-bottom:1rem;">איך זה עובד</div>
        <h2 style="font-size:clamp(1.9rem,3.5vw,2.9rem); font-weight:900; color:var(--text);">4 צעדים ל<em class="shimmer-text" style="font-style:normal;">אירוע בלתי נשכח</em></h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; position:relative;">
        {[
          { icon:'📸', title:'מעלים תמונות', desc:'מעלים תמונות וסרטונים דרך מערכת ייחודית — קל ומהיר מהטלפון או המחשב' },
          { icon:'🎵', title:'בוחרים סגנון', desc:'מוזיקה, עריכה ותוספות AI — הכל לפי הטעם האישי שלכם' },
          { icon:'✂️', title:'אנחנו עורכים', desc:'3–4 ימי עבודה מקצועית עם ליווי צמוד לכל אורך הדרך' },
          { icon:'🎉', title:'מקבלים מצגת', desc:'מוכנה לאירוע ומביאה בכי שמחה ומחיאות כפיים' },
        ].map((step, i) => (
          <div style="text-align:center;" class="reveal">
            <div style="width:88px; height:88px; border-radius:24px; margin:0 auto 1.3rem; display:flex; align-items:center; justify-content:center; font-size:2rem; position:relative; background:var(--surface); border:1px solid var(--border); box-shadow:0 8px 24px rgba(124,58,237,.07);">
              {step.icon}
              <div style="position:absolute; top:-8px; left:-8px; width:22px; height:22px; border-radius:50%; background:linear-gradient(135deg,var(--purple),var(--purple-mid)); color:white; font-size:.65rem; font-weight:900; display:flex; align-items:center; justify-content:center;">{i+1}</div>
            </div>
            <div style="font-size:.95rem; font-weight:800; margin-bottom:.45rem; color:var(--text);">{step.title}</div>
            <div style="font-size:.8rem; color:var(--text-muted); line-height:1.6;">{step.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <Contact />

  <!-- POPUP -->
  <div id="popup-overlay" style="position:fixed; inset:0; background:rgba(0,0,0,.65); z-index:500; display:flex; align-items:center; justify-content:center; padding:1.5rem; backdrop-filter:blur(6px);">
    <div style="background:linear-gradient(145deg,#4c1d95,#7c3aed); border-radius:28px; padding:2.5rem 2rem; max-width:420px; width:100%; position:relative; box-shadow:0 40px 80px rgba(0,0,0,.5); text-align:center;">
      <button id="popup-close" style="position:absolute; top:1rem; left:1rem; background:rgba(255,255,255,.2); border:none; color:white; width:34px; height:34px; border-radius:50%; font-size:1.4rem; cursor:pointer; display:flex; align-items:center; justify-content:center; font-family:'Heebo',sans-serif;">×</button>
      <div style="font-size:2.8rem; margin-bottom:.8rem;">🎁</div>
      <div style="display:inline-block; background:linear-gradient(135deg,#EC4899,#F59E0B); color:white; font-size:.7rem; font-weight:800; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:1rem;">מבצע מיוחד</div>
      <h3 style="font-size:1.5rem; font-weight:900; color:white; margin-bottom:.8rem; line-height:1.3;">הזמן מצגת של 6 או 10 דקות<br>וקבל דקה נוספת במתנה!</h3>
      <p style="color:rgba(255,255,255,.75); font-size:.88rem; margin-bottom:1.8rem; line-height:1.6;">מבצע מיוחד לזמן מוגבל — אל תפספסו!</p>
      <a href="#contact" id="popup-cta" style="display:inline-flex; align-items:center; gap:.5rem; background:linear-gradient(135deg,#EC4899,#F59E0B); color:white; padding:.85rem 2.2rem; border-radius:50px; font-weight:700; font-size:.95rem; text-decoration:none; box-shadow:0 8px 28px rgba(236,72,153,.4);">
        הזמינו עכשיו ←
      </a>
    </div>
  </div>

</Layout>

<script>
  function closePopup() {
    const el = document.getElementById('popup-overlay');
    if (el) el.style.display = 'none';
  }
  document.getElementById('popup-close')?.addEventListener('click', closePopup);
  document.getElementById('popup-cta')?.addEventListener('click', closePopup);
  document.getElementById('popup-overlay')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('popup-overlay')) closePopup();
  });

  // Announcement bar hide on scroll
  window.addEventListener('scroll', () => {
    const bar = document.getElementById('announcement-bar');
    if (!bar) return;
    if (window.scrollY > 100) {
      bar.style.transform = 'translateY(-100%)';
      bar.style.opacity = '0';
      bar.style.pointerEvents = 'none';
    } else {
      bar.style.transform = 'translateY(0)';
      bar.style.opacity = '1';
      bar.style.pointerEvents = 'auto';
    }
  });
</script>

<style>
  @media(max-width:768px){
    div[style*="grid-template-columns:repeat(4,1fr)"] {
      grid-template-columns: repeat(2,1fr) !important;
    }
    .thumb-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
