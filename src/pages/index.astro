      </div>
      <div class="reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center;">
        <div style="text-align: center;">
          <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 8px 40px rgba(108,34,255,.25);">
            <img src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/thailand.png" alt="תמונה מקורית מהלקוח — תמונת תאילנד" style="width: 100%; height: 300px; object-fit: cover; display: block;" loading="lazy" />
          </div>
          <div style="margin-top: .8rem; display: inline-block; background: rgba(255,255,255,.1); color: rgba(255,255,255,.8); font-weight: 700; font-size: .82rem; padding: .4rem 1.1rem; border-radius: 50px;">תמונה מקורית מהלקוח</div>
        </div>
        <div style="text-align: center;">
          <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.45);">
            <video src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/thailand.mp4" autoplay loop muted playsinline style="width: 100%; height: 300px; object-fit: cover; display: block;"></video>
          </div>
          <div style="margin-top: .8rem; display: inline-block; background: linear-gradient(90deg, #E879F9, #6C22FF); color: white; font-weight: 700; font-size: .82rem; padding: .4rem 1.1rem; border-radius: 50px;">סרטון שנוצר בעזרת AI</div>
        </div>
      </div>
      <div style="text-align: center; margin-top: 2rem;" class="reveal">
        <a href="/שדרוגי-ai/thailand" style="display: inline-block; border: 2px solid rgba(232,121,249,.6); color: #E879F9; font-weight: 700; font-size: .9rem; padding: .6rem 1.8rem; border-radius: 50px; text-decoration: none; margin-left: 1rem;">לסיפור המלא ←</a>
        <a href="/שדרוגי-ai" style="display: inline-block; color: rgba(255,255,255,.5); font-weight: 600; font-size: .85rem; text-decoration: none;">לכל שדרוגי ה-AI</a>
      </div>
    </div>
  </section>

  <script is:inline>
  (function() {
    const canvas = document.getElementById('ai-home-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const section = document.getElementById('ai-home-section');
    let W, H, dots, mouse = { x: -999, y: -999 };

    function resize() {
      W = canvas.width = canvas.offsetWidth;
      H = canvas.height = canvas.offsetHeight;
    }
    function makeDots(n) {
      return Array.from({ length: n }, () => ({
        x: Math.random() * W, y: Math.random() * H,
        vx: (Math.random() - .5) * .5, vy: (Math.random() - .5) * .5,
        r: Math.random() * 2.2 + 1,
      }));
    }
    resize();
    dots = makeDots(60);
    window.addEventListener('resize', () => { resize(); dots = makeDots(60); });

    section.addEventListener('mousemove', e => {
      const r = section.getBoundingClientRect();
      mouse.x = e.clientX - r.left;
      mouse.y = e.clientY - r.top;
    });
    section.addEventListener('mouseleave', () => { mouse.x = -999; mouse.y = -999; });

    function draw() {
      ctx.clearRect(0, 0, W, H);

      // רקע גרדיאנט דינמי לפי מיקום העכבר
      const mx = mouse.x < 0 ? W / 2 : mouse.x;
      const my = mouse.y < 0 ? H / 2 : mouse.y;
      const grad = ctx.createRadialGradient(mx, my, 0, mx, my, Math.max(W, H) * 0.7);
      grad.addColorStop(0, 'rgba(108,34,255,0.18)');
      grad.addColorStop(0.5, 'rgba(232,121,249,0.07)');
      grad.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, W, H);

      for (const d of dots) {
        const dx = d.x - mouse.x, dy = d.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 100) { d.vx += dx / dist * .12; d.vy += dy / dist * .12; }
        d.vx = Math.max(-1.8, Math.min(1.8, d.vx));
        d.vy = Math.max(-1.8, Math.min(1.8, d.vy));
        d.x += d.vx; d.y += d.vy;
        if (d.x < 0 || d.x > W) d.vx *= -1;
        if (d.y < 0 || d.y > H) d.vy *= -1;
        const near = dist < 120;
        ctx.beginPath();
        ctx.arc(d.x, d.y, d.r, 0, Math.PI * 2);
        ctx.fillStyle = near ? 'rgba(232,121,249,0.75)' : 'rgba(160,100,255,0.35)';
        ctx.fill();
      }
      for (let i = 0; i < dots.length; i++) {
        for (let j = i + 1; j < dots.length; j++) {
          const dx = dots[i].x - dots[j].x, dy = dots[i].y - dots[j].y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < 120) {
            ctx.beginPath();
            ctx.moveTo(dots[i].x, dots[i].y);
            ctx.lineTo(dots[j].x, dots[j].y);
            ctx.strokeStyle = `rgba(180,80,255,${(1 - d / 120) * 0.3})`;
            ctx.lineWidth = .8;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }
    draw();
  })();
  </script>

  <!-- GALLERY HEADING -->
  <section id="gallery" style="padding:1.5rem 6% 0; background:#F5F3FF; text-align:center;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:inline-block; background:#EDE9FE; color:#7C3AED; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.35rem 1rem; border-radius:50px; margin-bottom:1rem;" class="reveal">הגלריה שלנו</div>
      <h2 style="font-size:clamp(2rem,3.5vw,2.9rem); font-weight:900; color:#12023C; margin-bottom:.8rem; font-family:'Secular One',sans-serif;" class="reveal">
        דוגמאות למצגות וידאו מקצועיות
      </h2>
      <p style="font-size:1rem; color:#6b7280; line-height:1.75; max-width:540px; margin:0 auto;" class="reveal">בחרו קטגוריה וצפו במצגות אמיתיות שיצרנו — כל אחת מותאמת אישית לאירוע ולמשפחה</p>
    </div>
  </section>

  <!-- BAR MITZVAH -->
  <section style="padding:2rem 6% 2.5rem; background:#F5F3FF; position:relative;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem; flex-wrap:wrap; gap:1rem;">
        <div style="text-align:right;">
          <div style="display:inline-block; background:#EDE9FE; color:#7C3AED; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem 1rem; border-radius:50px; margin-bottom:.6rem;">בר מצווה</div>
          <h2 style="font-size:clamp(1.7rem,2.5vw,2.4rem); font-weight:900; color:#1A1040; margin-bottom:.4rem; font-family:'Secular One',sans-serif;">מהרגע הראשון עד הרגע הגדול</h2>
          <p style="font-size:.92rem; color:#9490B8; max-width:480px; line-height:1.75;">מצגת שמספרת את הסיפור האישי — מהלידה ועד הגדלה, עם רגעים שיחרטו בזיכרון לנצח.</p>
        </div>
        <a href="/מצגות/bar_mitzva" class="section-cta-btn purple-btn">לכל המצגות ←</a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.8rem;" class="reveal thumb-grid">
