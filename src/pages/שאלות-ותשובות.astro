---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';

const faqs: { q: string; a: string }[] = [
  {
    q: "כמה זמן לוקח להכין מצגת?",
    a: "בדרך כלל 3–7 ימי עסקים מרגע קבלת כל התמונות והסרטונים. לאירועים דחופים — צרו קשר ונתאים לוח זמנים."
  },
  {
    q: "כמה תמונות וסרטונים צריך לשלוח?",
    a: "אין מינימום ואין מקסימום. בהתאם לאורך המצגת. לדוגמא מצגת של 6 דקות צריכה כ-120 תמונות. אנחנו נדריך אתכם לפי האירוע והחבילה שבחרתם."
  },
  {
    q: "באילו פורמטים אפשר לשלוח תמונות וסרטונים?",
    a: "כל פורמט סטנדרטי — JPG, PNG, HEIC לתמונות, ו-MP4, MOV, AVI לסרטונים. תמונות מהטלפון עובדות מצוין כמו שהן, לא צריך להמיר כלום."
  },
  {
    q: "איך שולחים לכם את התמונות?",
    a: "הכי נוח ובקלות! אחרי שיוצרים איתנו קשר, אתם מקבלים קישור אישי למערכת ההעלאה שלנו. מעלים ישירות מהטלפון או מהמחשב, מסדרים לפי סדר, ומוסיפים כותרות — הכל בלחיצות פשוטות, בלי להוריד שום דבר. אפשר גם לשתף תיקייה בגוגל, לשלוח קבצים בג׳מבו מייל, במייל או בווטסאפ."
  },
  {
    q: "אפשר לבקש שינויים אחרי שמקבלים את המצגת?",
    a: "כן! בכל החבילות כלולים מספר סבבי תיקונים. ניתן לבקש שינויים בטקסטים, בסדר, במוזיקה ועוד."
  },
  {
    q: "מי בוחר את המוזיקה?",
    a: "אתם! אנחנו נשאל אתכם מראש אילו שירים אתם אוהבים, ואם אין לכם העדפה — נבחר מוזיקה שמתאימה לאופי האירוע."
  },
  {
    q: "איך מקבלים את המצגת הסופית?",
    a: "שולחים לכם קישור להורדה עם קובץ MP4 באיכות מלאה, מוכן להקרנה בטלפון, מחשב, טלוויזיה או מקרן."
  },
  {
    q: "האם משתמשים בבינה מלאכותית?",
    a: "כן — אנחנו משלבים כלי AI מתקדמים שמאפשרים אפקטים וסגנונות שלא ניתן ליצור ידנית. זה מה שמייחד את המצגות שלנו."
  },
  {
    q: "מה ההבדל בין מצגת בסיסית לפרימיום?",
    a: "ראו את דף המחירון המלא. בקצרה: החבילות הגבוהות ארוכות יותר, ויש זמן להכניס סרטון פתיחה ואפקטים AI."
  },
  {
    q: "עובדים רק עם אירועים באזור מרכז?",
    a: "לא — אנחנו עובדים עם לקוחות מכל הארץ. הכל מתנהל אונליין, ולכן אין חשיבות למיקום."
  },
  {
    q: "אפשר לקבל דוגמה לפני שמזמינים?",
    a: "בוודאי! יש לנו גלרייה עם מאות מצגות אמיתיות שיצרנו — אחת מקטגוריית האירוע שלכם. אפשר לראות בדפי המצגות באתר."
  },
  {
    q: "איך משלמים?",
    a: "בסיום התהליך, אנחנו סוגרים ושולחים קובץ סופי ואתם מקבלים דרישות תשלום, ביט, פייבוקס, העברה בנקאית."
  },
];

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
});
---

<Layout title="שאלות ותשובות — Mazeget מצגות" description="כל השאלות הנפוצות על הזמנת מצגת וידאו — זמני הכנה, העלאת תמונות, מוזיקה, תיקונים ותשלום. כאן תמצאו את כל התשובות.">
  <Header />

  <!-- Hero -->
  <section class="text-center" style="padding:3.5rem 1.5rem 3rem; background:linear-gradient(135deg,#12023C 0%,#6C22FF 100%);">
    <h1 class="text-white font-black" style="font-size:clamp(2.2rem,5vw,3.2rem); font-family:'Secular One',sans-serif; margin-bottom:.6rem;">שאלות ותשובות</h1>
    <p style="color:rgba(255,255,255,0.88); font-size:1.05rem; max-width:34rem; margin:0 auto;">כל מה שרציתם לדעת על מצגות הוידאו שלנו</p>
  </section>

  <!-- FAQ -->
  <section style="padding:3.5rem 1.5rem; background:#F8F7FF;">
    <div style="max-width:46rem; margin:0 auto;">
      <div style="display:flex; flex-direction:column; gap:.75rem;" id="faq-list">
        {faqs.map((item, i) => (
          <div class="faq-item" style="background:white; border-radius:16px; box-shadow:0 1px 4px rgba(0,0,0,.06); overflow:hidden; border:1px solid rgba(108,34,255,.07);">
            <button
              class="faq-btn"
              data-index={i}
              style="width:100%; text-align:right; padding:1.15rem 1.5rem; display:flex; align-items:center; justify-content:space-between; gap:1rem; background:transparent; border:none; cursor:pointer; transition:background .15s; font-family:'Heebo',sans-serif;"
            >
              <span class="font-bold text-[#12023C]" style="font-size:1rem; line-height:1.4;">{item.q}</span>
              <span class="faq-icon" style="flex-shrink:0; width:30px; height:30px; border-radius:50%; background:rgba(108,34,255,.1); display:flex; align-items:center; justify-content:center; color:#6C22FF; font-weight:700; font-size:1.15rem; transition:transform .2s, background .2s;">+</span>
            </button>
            <div class="faq-answer hidden" style="padding:0 1.5rem 1.15rem; text-align:right;">
              <p style="color:#4B5563; line-height:1.75; font-size:.925rem; margin:0; border-top:1px solid rgba(108,34,255,.08); padding-top:.9rem;">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="text-center" style="padding:2.75rem 1.5rem; background:white; border-bottom:1px solid #ede9fe;">
    <p style="font-size:1.05rem; color:#6B7280; margin-bottom:1.25rem;">לא מצאתם תשובה? אנחנו כאן</p>
    <a href="/#contact"
      style="display:inline-block; background:#6C22FF; color:white; font-weight:700; font-size:.95rem; padding:.8rem 2rem; border-radius:50px; text-decoration:none; transition:background .2s, transform .15s; box-shadow:0 4px 16px rgba(108,34,255,.3);"
      onmouseover="this.style.background='#5a1dd6';this.style.transform='translateY(-1px)'"
      onmouseout="this.style.background='#6C22FF';this.style.transform=''">
      שלחו לנו הודעה
    </a>
  </section>

  <Contact />
  <script type="application/ld+json" set:html={faqSchema}></script>
</Layout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const answer = item.querySelector('.faq-answer')!;
      const icon = btn.querySelector('.faq-icon')!;
      const isOpen = !answer.classList.contains('hidden');

      // סגור את כולם
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(ic => {
        ic.textContent = '+';
        (ic as HTMLElement).style.transform = '';
        (ic as HTMLElement).style.background = 'rgba(108,34,255,.1)';
        (ic as HTMLElement).style.color = '#6C22FF';
      });

      if (!isOpen) {
        answer.classList.remove('hidden');
        icon.textContent = '−';
        (icon as HTMLElement).style.background = '#6C22FF';
        (icon as HTMLElement).style.color = 'white';
      }
    });

    // hover state
    btn.addEventListener('mouseenter', () => {
      (btn as HTMLElement).style.background = '#F8F7FF';
    });
    btn.addEventListener('mouseleave', () => {
      (btn as HTMLElement).style.background = 'transparent';
    });
  });
</script>
