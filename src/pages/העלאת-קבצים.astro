---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="העלאת קבצים — Mazeget מצגות">
  <Header />

  <!-- Hero -->
  <section class="py-20 px-6 text-center" style="background: linear-gradient(135deg, #6C22FF 0%, #E879F9 100%);">
    <h1 class="text-5xl text-white font-black mb-4" style="font-family: 'Secular One', sans-serif;">העלאת קבצים למצגת</h1>
    <p class="text-white/90 text-xl max-w-xl mx-auto">מערכת ייחודית שפיתחנו — לא תמצאו אותה בשום מקום אחר</p>
  </section>

  <!-- Unique Feature -->
  <section class="py-16 px-6 bg-white">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-block bg-[#F59E0B]/10 text-[#F59E0B] font-bold px-6 py-2 rounded-full mb-6 text-sm">
        ✨ טכנולוגיה בלעדית
      </div>
      <h2 class="text-3xl font-black text-[#12023C] mb-6" style="font-family: 'Secular One', sans-serif;">
        מערכת העלאה שפיתחנו במיוחד בשבילכם
      </h2>
      <p class="text-gray-600 text-lg leading-relaxed mb-4">
        אחרי שיוצרים איתנו קשר, אתם מקבלים <strong>קישור אישי</strong> למערכת ייחודית שפיתחנו —
        אין דבר כזה בשום מקום אחר.
      </p>
      <p class="text-gray-600 text-lg leading-relaxed">
        עובדת מושלם מ<strong>טלפון או מחשב</strong>, בלי להוריד שום דבר.
      </p>
    </div>
  </section>

  <!-- Steps -->
  <section class="py-20 px-6 bg-[#F8F7FF]">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-black text-[#12023C] text-center mb-16" style="font-family: 'Secular One', sans-serif;">
        איך זה עובד?
      </h2>

      <div class="flex flex-col gap-8">

        <div class="flex items-start gap-6 bg-white rounded-2xl p-8 shadow-md text-right">
          <div class="shrink-0 w-14 h-14 rounded-full flex items-center justify-center text-white font-black text-xl"
            style="background: linear-gradient(135deg, #6C22FF, #E879F9);">1</div>
          <div>
            <h3 class="text-xl font-black text-[#12023C] mb-2">יוצרים קשר</h3>
            <p class="text-gray-500">מתקשרים, שולחים וואטסאפ או ממלאים טופס — ואנחנו נחזור אליכם לתיאום</p>
          </div>
        </div>

        <div class="flex items-start gap-6 bg-white rounded-2xl p-8 shadow-md text-right">
          <div class="shrink-0 w-14 h-14 rounded-full flex items-center justify-center text-white font-black text-xl"
            style="background: linear-gradient(135deg, #6C22FF, #E879F9);">2</div>
          <div>
            <h3 class="text-xl font-black text-[#12023C] mb-2">מקבלים קישור אישי</h3>
            <p class="text-gray-500">שולחים לכם קישור ייחודי למערכת ההעלאה — עובד מהטלפון או מהמחשב, בלי להוריד שום דבר</p>
          </div>
        </div>

        <div class="flex items-start gap-6 bg-white rounded-2xl p-8 shadow-md text-right">
          <div class="shrink-0 w-14 h-14 rounded-full flex items-center justify-center text-white font-black text-xl"
            style="background: linear-gradient(135deg, #6C22FF, #E879F9);">3</div>
          <div>
            <h3 class="text-xl font-black text-[#12023C] mb-2">מעלים, מסדרים ומוסיפים כותרות</h3>
            <p class="text-gray-500">מעלים תמונות וסרטונים, נותנים כותרת לכל קבצים, ומסדרים את הסדר שרוצים — הכל בלחיצות פשוטות</p>
          </div>
        </div>

        <div class="flex items-start gap-6 bg-white rounded-2xl p-8 shadow-md text-right">
          <div class="shrink-0 w-14 h-14 rounded-full flex items-center justify-center text-white font-black text-xl"
            style="background: linear-gradient(135deg, #6C22FF, #E879F9);">4</div>
          <div>
            <h3 class="text-xl font-black text-[#12023C] mb-2">אנחנו מתחילים לעבוד</h3>
            <p class="text-gray-500">מורידים את הקבצים ממוספרים ומתחילים לבנות את המצגת — אתם רק צריכים לחכות לתוצאה</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6 text-center" style="background: linear-gradient(135deg, #06B6D4 0%, #6C22FF 100%);">
    <h2 class="text-3xl font-black text-white mb-4" style="font-family: 'Secular One', sans-serif;">
      רוצים להתחיל?
    </h2>
    <p class="text-white/90 mb-8">צרו קשר ונשלח לכם את הקישור האישי שלכם</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/#contact"
        class="inline-block bg-white text-[#6C22FF] font-bold text-lg px-10 py-4 rounded-full hover:scale-105 transition-transform">
        צרו קשר
      </a>
      <a href="https://wa.me/972500000000" target="_blank"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white font-bold text-lg px-10 py-4 rounded-full hover:scale-105 transition-transform">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        וואטסאפ
      </a>
    </div>
  </section>

</Layout>
