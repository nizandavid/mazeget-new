---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="אודותינו — Mazeget מצגות" description="ניצן שמיר — מעצב מצגות וידאו לאירועים משפחתיים מאז 2010. מצגות עם AI, מוזיקה ועריכה מקצועית לאירוע הכי חשוב שלכם.">
  <Header />

  <!-- Hero -->
  <section class="py-20 px-6 text-center" style="background: linear-gradient(135deg, #6C22FF 0%, #06B6D4 100%);">
    <h1 class="text-5xl text-white font-black mb-4" style="font-family: 'Secular One', sans-serif;">אודותינו</h1>
    <p class="text-white/90 text-xl">הסיפור שלנו</p>
  </section>

  <!-- Story -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-3xl mx-auto text-right">
      <h2 class="text-3xl font-black text-[#12023C] mb-6" style="font-family: 'Secular One', sans-serif;">
        ניצן שמיר מצגות
      </h2>
      <p class="text-gray-600 text-lg leading-relaxed mb-6">
        התחלנו כמשרד לעיצוב גרפי, ועם הזמן הרחבנו את פעילותנו לעולם מצגות הוידאו לאירועים משפחתיים.
      </p>
      <p class="text-gray-600 text-lg leading-relaxed mb-6">
        אנחנו מתמחים ביצירת מצגות וידאו מתמונות וסרטונים שמסכמות תקופה בחיים — ומשאירות מזכרת מרגשת לכל החיים.
      </p>
      <p class="text-gray-600 text-lg leading-relaxed">
        כל מצגת מותאמת אישית לאופי האירוע ולטעם האישי של המשפחה. אנחנו מספקים שירות אישי ומקצועי מתחילת התהליך ועד הרגע שהמצגת עולה על המסך.
      </p>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 px-6 bg-[#F8F7FF]">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-black text-[#12023C] text-center mb-12" style="font-family: 'Secular One', sans-serif;">
        למה לבחור בנו?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 text-right shadow-md">
          <div class="text-4xl mb-4">🎬</div>
          <h3 class="font-black text-[#12023C] text-xl mb-3">עריכה מקצועית</h3>
          <p class="text-gray-500">כל מצגת עוברת עריכה מדוקדקת עם שימוש בטכנולוגיית AI מתקדמת</p>
        </div>
        <div class="bg-white rounded-2xl p-8 text-right shadow-md">
          <div class="text-4xl mb-4">💜</div>
          <h3 class="font-black text-[#12023C] text-xl mb-3">שירות אישי</h3>
          <p class="text-gray-500">מותאם לטעם שלכם ולאופי האירוע — מתחילת התהליך ועד הסוף</p>
        </div>
        <div class="bg-white rounded-2xl p-8 text-right shadow-md">
          <div class="text-4xl mb-4">⚡</div>
          <h3 class="font-black text-[#12023C] text-xl mb-3">מהירות ואמינות</h3>
          <p class="text-gray-500">זמני עריכה מהירים ומחירים נוחים — בלי הפתעות בדרך</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Info + Map -->
  <section class="py-14 px-6 bg-white">
    <div style="max-width:1100px; margin:0 auto;">
      <h2 class="text-3xl font-black text-[#12023C] mb-8 text-center" style="font-family: 'Secular One', sans-serif;">
        פרטי התקשרות ומיקום
      </h2>
      <div class="contact-map-grid" style="display:grid; grid-template-columns:1fr 1.4fr; gap:2rem; align-items:start;">

        <!-- פרטים -->
        <div style="display:flex; flex-direction:column; gap:1rem; text-align:right;">
          <div class="flex items-center gap-3 bg-[#F8F7FF] rounded-2xl p-4">
            <span class="text-2xl">📍</span>
            <div>
              <p class="font-bold text-[#12023C] text-sm">כתובת</p>
              <p class="text-gray-500 text-sm">רחוב הנדיב 3, הרצליה</p>
            </div>
          </div>
          <div class="flex items-center gap-3 bg-[#F8F7FF] rounded-2xl p-4">
            <span class="text-2xl">📞</span>
            <div>
              <p class="font-bold text-[#12023C] text-sm">טלפון</p>
              <a href="tel:074-764-86-37" class="text-[#6C22FF] hover:underline text-sm">074-764-86-37</a>
              <span class="text-gray-400 text-xs"> (דליה/דוד)</span>
            </div>
          </div>
          <div class="flex items-center gap-3 bg-[#F8F7FF] rounded-2xl p-4">
            <span class="text-2xl">✉️</span>
            <div>
              <p class="font-bold text-[#12023C] text-sm">אימייל</p>
              <a href="mailto:nizan.shamir@gmail.com" class="text-[#6C22FF] hover:underline text-sm">nizan.shamir@gmail.com</a>
            </div>
          </div>
          <a href="https://g.page/r/CWIZB_5YqAWXEBM/review" target="_blank" rel="noopener"
            style="display:inline-flex; align-items:center; justify-content:center; gap:.5rem; background:#4285F4; color:white; padding:.7rem 1.4rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; margin-top:.5rem;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            השאירו לנו ביקורת בגוגל
          </a>
        </div>

        <!-- מפה -->
        <div style="border-radius:20px; overflow:hidden; box-shadow:0 8px 32px rgba(0,0,0,.1);">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3377.358501361138!2d34.83777637606179!3d32.16760607392442!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x151d480b54e2e837%3A0x9705a858fe071962!2zTWF6ZWdldCDigJMg16DXmdem158g16nXnteZ16gg157XpteS15XXqg!5e0!3m2!1sen!2sil!4v1773510953590!5m2!1sen!2sil"
            width="100%"
            height="340"
            style="border:0; display:block;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-6 text-center" style="background: linear-gradient(135deg, #E879F9 0%, #6C22FF 100%);">
    <h2 class="text-3xl font-black text-white mb-4" style="font-family: 'Secular One', sans-serif;">מוכנים להתחיל?</h2>
    <p class="text-white/90 mb-8">צרו קשר ונבנה יחד את המצגת המושלמת לאירוע שלכם</p>
    <a href="/#contact" class="inline-block bg-white text-[#6C22FF] font-bold text-lg px-10 py-4 rounded-full hover:scale-105 transition-transform">
      צרו קשר עכשיו
    </a>
  </section>

</Layout>

<style>
  @media (max-width: 768px) {
    .contact-map-grid { grid-template-columns: 1fr !important; }
  }
</style>
