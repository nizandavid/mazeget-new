            תמונה מקורית
          </div>
        </div>

        <!-- LEFT: תוצאת AI -->
        <div style="text-align: center;">
          <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5);">
