        <p style="color: #555; font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.7;">
          מתמונה אחת — AI שילב את הילדה בסטים של הסרטים האהובים עליה
        </p>
      </div>

      <div class="demo-grid reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center;">

        <!-- RIGHT: תמונה מקורית -->
