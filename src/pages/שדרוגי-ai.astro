---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="שדרוגי AI למצגות | Mazeget"
  description="אלמנטים מיוחדים, אפקטים וסצנות שנוצרים בעזרת AI — שדרוגים שהופכים כל מצגת לחוויה בלתי נשכחת. בר מצווה, בת מצווה, יום הולדת וחתונות."
>
  <Header />

  <!-- ═══ HERO ═══ -->
  <section id="ai-hero" style="background: #0a0118; padding: 5rem 1.5rem 5.5rem; text-align: center; position: relative; overflow: hidden;">
    <canvas id="ai-canvas" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;" aria-hidden="true"></canvas>
    <div style="position: relative; z-index: 1; max-width: 800px; margin: 0 auto;" class="reveal">
      <div style="display: inline-block; background: linear-gradient(90deg, #E879F9, #A855F7); color: white; font-size: .72rem; font-weight: 800; letter-spacing: 2px; padding: .35rem 1.1rem; border-radius: 50px; margin-bottom: 1.5rem; box-shadow: 0 4px 18px rgba(232,121,249,.45);">
        חדש — שדרוגי AI
      </div>
      <h1 style="font-family: 'Secular One', sans-serif; font-size: clamp(2.6rem, 6vw, 4.2rem); color: white; margin: 0 0 1.2rem; line-height: 1.1;">
        שדרוגי AI למצגות
      </h1>
      <p style="font-size: clamp(1rem, 2.2vw, 1.25rem); color: rgba(255,255,255,0.82); line-height: 1.75; max-width: 620px; margin: 0 auto 2.5rem;">
        אלמנטים מיוחדים, אפקטים וסצנות שנוצרים בעזרת AI והופכים כל מצגת לחוויה בלתי נשכחת
      </p>
      <a
        href="https://wa.me/972526780531"
        target="_blank"
        rel="noopener"
        style="display: inline-flex; align-items: center; gap: .6rem; background: #25D366; color: white; font-weight: 800; font-size: 1.05rem; padding: .9rem 2.4rem; border-radius: 50px; text-decoration: none; box-shadow: 0 6px 28px rgba(37,211,102,.45); transition: transform .2s, box-shadow .2s;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 10px 36px rgba(37,211,102,.55)'"
        onmouseout="this.style.transform='';this.style.boxShadow='0 6px 28px rgba(37,211,102,.45)'"
      >
        <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        רוצה גם כזה? שלח הודעה
      </a>
    </div>
  </section>

  <!-- ═══ DEMO SHOWCASE ═══ -->
  <section style="padding: 5rem 1.5rem; background: #F5F3FF;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3rem;" class="reveal">
        <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.4rem); color: #12023C; margin: 0;">
          ראו בעצמכם — תמונה שהפכה לסרטון AI
        </h2>
      </div>
      <div class="demo-grid reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start;">

        <!-- RIGHT: original photo -->
        <div style="text-align: center;">
          <div style="background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 8px 40px rgba(108,34,255,.12);">
            <img
              src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/thailand.png"
              alt="תמונה מקורית מהלקוח — תמונת תאילנד"
              style="width: 100%; height: 340px; object-fit: cover; display: block;"
              loading="lazy"
            />
          </div>
          <div style="margin-top: 1rem; display: inline-block; background: white; color: #6C22FF; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 2px 12px rgba(108,34,255,.15);">
            תמונה מקורית מהלקוח
          </div>
        </div>

        <!-- LEFT: AI video -->
        <div style="text-align: center;">
          <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5), 0 8px 40px rgba(108,34,255,.25);">
            <video
              src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/thailand.mp4"
              autoplay
              loop
              muted
              playsinline
              style="width: 100%; height: 340px; object-fit: cover; display: block;"
            ></video>
          </div>
          <div style="margin-top: 1rem; display: inline-block; background: linear-gradient(90deg, #E879F9, #6C22FF); color: white; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 4px 18px rgba(232,121,249,.4);">
            סרטון שנוצר בעזרת AI
          </div>
        </div>

      </div>
      <p style="text-align: center; margin-top: 2.5rem; color: #6C22FF; font-weight: 600; font-size: .95rem;" class="reveal">
        זה מה שנוצר מתמונה אחת שהלקוח שלח
      </p>
    </div>
  </section>

  <!-- ═══ ALEX SHOWCASE ═══ -->
  <section style="padding: 5rem 1.5rem; background: white;">
    <div style="max-width: 1100px; margin: 0 auto;">

      <div style="text-align: center; margin-bottom: 3rem;" class="reveal">
        <div style="display: inline-block; background: linear-gradient(90deg, #6C22FF, #E879F9); color: white; font-size: .72rem; font-weight: 800; letter-spacing: 2px; padding: .35rem 1.1rem; border-radius: 50px; margin-bottom: 1rem;">
          תמונות AI
        </div>
        <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.4rem); color: #12023C; margin: 0 0 .75rem;">
          אלכס — מה יקרה אחרי הפרישה?
        </h2>
        <p style="color: #555; font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.7;">
          מתמונה אחת שהמשפחה שלחה — בנינו פתיח קולנועי ושלושה עולמות דמיוניים שגרמו לכולם לצחוק
        </p>
      </div>

      <!-- Original + Video -->
      <div class="demo-grid reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; margin-bottom: 2.5rem;">
        <div style="text-align: center;">
          <div style="background: #F5F3FF; border-radius: 20px; overflow: hidden; box-shadow: 0 8px 40px rgba(108,34,255,.1);">
            <img
              src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/alex.png"
              alt="תמונה מקורית של אלכס"
              style="height: 300px; width: auto; display: block; margin: 0 auto; border-radius: 20px;"
              loading="lazy"
            />
          </div>
          <div style="margin-top: 1rem; display: inline-block; background: #F5F3FF; color: #6C22FF; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px;">
            תמונה מקורית מהמשפחה
          </div>
        </div>
        <div style="text-align: center;">
          <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.4), 0 8px 40px rgba(108,34,255,.2);">
            <video
              src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/alex-opening.mp4"
              autoplay loop muted playsinline
              style="width: 100%; height: 300px; object-fit: cover; display: block;"
            ></video>
          </div>
          <div style="margin-top: 1rem; display: inline-block; background: linear-gradient(90deg, #E879F9, #6C22FF); color: white; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 4px 18px rgba(232,121,249,.4);">
            פתיח קולנועי שנוצר בעזרת AI
          </div>
        </div>
      </div>

      <!-- 3 AI scenarios -->
      <div style="text-align: center; margin-bottom: 1.5rem;" class="reveal">
        <p style="color: #6C22FF; font-weight: 700; font-size: 1rem;">ואז — מה יעשה אלכס אחרי הפרישה?</p>
      </div>
      <div class="reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: start;">

        <!-- עמודה ימין: תמונה עומדת — אורז -->
        <div style="text-align: center;">
          <div style="border-radius: 18px; overflow: hidden; box-shadow: 0 6px 30px rgba(108,34,255,.12);">
            <img
              src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/alex-3.jpg"
              alt="אלכס בשדות האורז — תמונת AI"
              style="width: 100%; height: auto; display: block;"
              loading="lazy"
            />
          </div>
          <p style="margin-top: .75rem; font-weight: 700; color: #12023C; font-size: .92rem;">🌾 לעבוד בשדות האורז</p>
        </div>

        <!-- עמודה שמאל: שתי תמונות רוחב -->
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="text-align: center;">
            <div style="border-radius: 18px; overflow: hidden; box-shadow: 0 6px 30px rgba(108,34,255,.12);">
              <img
                src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/alex-1.jpg"
                alt="אלכס במדיטציה — תמונת AI"
                style="width: 100%; height: auto; display: block;"
                loading="lazy"
              />
            </div>
            <p style="margin-top: .75rem; font-weight: 700; color: #12023C; font-size: .92rem;">🧘 לעשות מדיטציה</p>
          </div>
          <div style="text-align: center;">
            <div style="border-radius: 18px; overflow: hidden; box-shadow: 0 6px 30px rgba(108,34,255,.12);">
              <img
                src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/alex-2.jpg"
                alt="אלכס בקזינו — תמונת AI"
                style="width: 100%; height: auto; display: block;"
                loading="lazy"
              />
            </div>
            <p style="margin-top: .75rem; font-weight: 700; color: #12023C; font-size: .92rem;">🎰 להמר בקזינו</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ NOIA SHOWCASE ═══ -->
  <section style="padding: 5rem 1.5rem; background: #F5F3FF;">
    <div style="max-width: 1100px; margin: 0 auto;">

      <div style="text-align: center; margin-bottom: 3rem;" class="reveal">
        <div style="display: inline-block; background: linear-gradient(90deg, #6C22FF, #E879F9); color: white; font-size: .72rem; font-weight: 800; letter-spacing: 2px; padding: .35rem 1.1rem; border-radius: 50px; margin-bottom: 1rem;">
          וידאו AI
        </div>
        <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.4rem); color: #12023C; margin: 0 0 .75rem;">
          טרנספורמציה — מתינוקת לנערה
        </h2>
        <p style="color: #555; font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.7;">
          6 תמונות מגילאים שונים — ו-AI שיצר מהן סרטון מעבר קסום שמראה את הצמיחה
        </p>
      </div>

      <div class="demo-grid reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center;">

        <!-- RIGHT: overlay image -->
        <div style="text-align: center;">
          <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 8px 40px rgba(108,34,255,.12);">
            <img
              src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/Noia-overlay.png"
              alt="6 תמונות של נויה בגילאים שונים"
              style="width: 100%; height: auto; display: block;"
              loading="lazy"
            />
          </div>
          <div style="margin-top: 1rem; display: inline-block; background: white; color: #6C22FF; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 2px 12px rgba(108,34,255,.15);">
            6 תמונות מקוריות מהמשפחה
          </div>
        </div>

        <!-- LEFT: transformation video -->
        <div style="text-align: center;">
          <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5), 0 8px 40px rgba(108,34,255,.25);">
            <video
              src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/noia-stage.mp4"
              autoplay loop muted playsinline
              style="width: 100%; height: auto; display: block;"
            ></video>
          </div>
          <div style="margin-top: 1rem; display: inline-block; background: linear-gradient(90deg, #E879F9, #6C22FF); color: white; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 4px 18px rgba(232,121,249,.4);">
            סרטון טרנספורמציה שנוצר בעזרת AI
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ FOOTBALL SHOWCASE ═══ -->
  <section style="padding: 5rem 1.5rem; background: white;">
    <div style="max-width: 1100px; margin: 0 auto;">

      <div style="text-align: center; margin-bottom: 3rem;" class="reveal">
        <div style="display: inline-block; background: linear-gradient(90deg, #6C22FF, #E879F9); color: white; font-size: .72rem; font-weight: 800; letter-spacing: 2px; padding: .35rem 1.1rem; border-radius: 50px; margin-bottom: 1rem;">
          תמונות + וידאו AI
        </div>
        <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.4rem); color: #12023C; margin: 0 0 .75rem;">
          סלפי עם כוכבי כדורגל
        </h2>
        <p style="color: #555; font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.7;">
          מ-6 תמונות נפרדות — AI יצר סלפי קבוצתי שהפך לסרטון חי
        </p>
      </div>

      <div style="max-width: 80%; margin: 0 auto;">
      <!-- שורה עליונה: 2 תמונות -->
      <div class="reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">

        <div style="text-align: center;">
          <div style="border-radius: 18px; overflow: hidden; box-shadow: 0 6px 30px rgba(108,34,255,.1);">
            <img
              src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/football%20players.png"
              alt="6 תמונות מקוריות של שחקני כדורגל"
              style="width: 100%; height: auto; display: block;"
              loading="lazy"
            />
          </div>
          <p style="margin-top: .75rem; font-weight: 700; color: #12023C; font-size: .88rem;">📸 6 תמונות מקוריות</p>
        </div>

        <div style="text-align: center;">
          <div style="border-radius: 18px; overflow: hidden; box-shadow: 0 6px 30px rgba(108,34,255,.15);">
            <img
              src="https://pub-0fce3727bd4b426f910073f9e5070a72.r2.dev/ai%20elements/football-photo.png"
              alt="סלפי קבוצתי עם כוכבי כדורגל — תמונת AI"
              style="width: 100%; height: auto; display: block;"
              loading="lazy"
            />
          </div>
          <p style="margin-top: .75rem; font-weight: 700; color: #12023C; font-size: .88rem;">🤳 סלפי קבוצתי עם AI</p>
        </div>

      </div>

      <!-- חץ -->
      <div class="reveal" style="text-align: center; margin-bottom: 1.5rem;">
        <span style="color: #E879F9; font-size: 2rem; font-weight: 900;">↓</span>
