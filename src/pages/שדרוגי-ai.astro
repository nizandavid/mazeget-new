<script is:inline>
(function() {
  const canvas = document.getElementById('ai-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const hero = document.getElementById('ai-hero');

  let mouse = { x: -9999, y: -9999 };
  let dots = [];
  const DOT_COUNT = 80;
  const CONNECT_DIST = 130;
  const REPEL_DIST = 90;

  function resize() {
    canvas.width = hero.offsetWidth;
    canvas.height = hero.offsetHeight;
  }

  function initDots() {
    dots = [];
    for (let i = 0; i < DOT_COUNT; i++) {
      dots.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        ox: 0, oy: 0,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: Math.random() * 2 + 1.5,
      });
      dots[i].ox = dots[i].x;
      dots[i].oy = dots[i].y;
    }
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // move dots
    dots.forEach(d => {
      // gentle drift
      d.ox += d.vx;
      d.oy += d.vy;
      if (d.ox < 0 || d.ox > canvas.width) d.vx *= -1;
      if (d.oy < 0 || d.oy > canvas.height) d.vy *= -1;

      // repel from mouse
      const dx = d.ox - mouse.x;
      const dy = d.oy - mouse.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < REPEL_DIST && dist > 0) {
        const force = (REPEL_DIST - dist) / REPEL_DIST;
        d.x = d.ox + (dx / dist) * force * 55;
        d.y = d.oy + (dy / dist) * force * 55;
      } else {
        d.x = d.ox;
        d.y = d.oy;
      }
    });

    // draw connections
    for (let i = 0; i < dots.length; i++) {
      for (let j = i + 1; j < dots.length; j++) {
        const dx = dots[i].x - dots[j].x;
        const dy = dots[i].y - dots[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECT_DIST) {
          const alpha = (1 - dist / CONNECT_DIST) * 0.55;
          // purple near dots, pink near mouse
          const mx = (dots[i].x + dots[j].x) / 2;
          const my = (dots[i].y + dots[j].y) / 2;
          const md = Math.sqrt((mx - mouse.x) ** 2 + (my - mouse.y) ** 2);
          const t = Math.max(0, 1 - md / 200);
          const r = Math.round(108 + t * 124);
          const g = Math.round(34 + t * 87);
          const b = Math.round(255 - t * 6);
          ctx.beginPath();
          ctx.moveTo(dots[i].x, dots[i].y);
          ctx.lineTo(dots[j].x, dots[j].y);
          ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
          ctx.lineWidth = 1;
          ctx.stroke();
        }
      }
    }

    // draw dots
    dots.forEach(d => {
      const dx = d.x - mouse.x;
      const dy = d.y - mouse.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const glow = dist < REPEL_DIST * 1.5;
      ctx.beginPath();
      ctx.arc(d.x, d.y, glow ? d.r * 1.8 : d.r, 0, Math.PI * 2);
      ctx.fillStyle = glow ? 'rgba(232,121,249,0.95)' : 'rgba(168,85,247,0.7)';
      ctx.fill();
    });

    requestAnimationFrame(draw);
  }

  hero.addEventListener('mousemove', e => {
    const rect = hero.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });
  hero.addEventListener('mouseleave', () => {
    mouse.x = -9999; mouse.y = -9999;
  });

  window.addEventListener('resize', () => { resize(); initDots(); });
  resize();
  initDots();
  draw();
})();
</script>

