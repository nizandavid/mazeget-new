---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import { showcases } from '../../data/ai-showcases';

export function getStaticPaths() {
  return showcases.map(s => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const s = showcases.find(x => x.slug === slug)!;
const others = showcases.filter(x => x.slug !== slug).slice(0, 3);
---

<Layout
  title={`${s.title} | שדרוגי AI | Mazeget`}
  description={s.description}
>
  <Header />

  <!-- חזרה לגלריה -->
  <div style="background: #2e0975; padding: 1rem 2rem;">
    <a href="/שדרוגי-ai" style="color: rgba(255,255,255,.6); text-decoration: none; font-size: .88rem; display: inline-flex; align-items: center; gap: .4rem;">
      ← כל שדרוגי ה-AI
    </a>
  </div>

  <!-- ═══ HERO ═══ -->
  <section style="background: linear-gradient(135deg, #2e0975, #4a1595); padding: 4rem 1.5rem; text-align: center;">
    <div style="max-width: 700px; margin: 0 auto;" class="reveal">
      <div style="display: inline-block; background: linear-gradient(90deg, #6C22FF, #E879F9); color: white; font-size: .72rem; font-weight: 800; letter-spacing: 2px; padding: .35rem 1.1rem; border-radius: 50px; margin-bottom: 1.2rem;">
        {s.badge}
      </div>
      <h1 style="font-family: 'Secular One', sans-serif; font-size: clamp(2rem, 5vw, 3.2rem); color: white; margin: 0 0 1rem; line-height: 1.1;">
        {s.title}
      </h1>
      <p style="color: rgba(255,255,255,.75); font-size: 1.05rem; line-height: 1.75; max-width: 560px; margin: 0 auto;" set:html={s.description}></p>
    </div>
  </section>

  <!-- ═══ SHOWCASE CONTENT ═══ -->
  <section style="padding: 5rem 1.5rem; background: #F5F3FF;">
    <div style="max-width: 1100px; margin: 0 auto;">

      {/* image-video layout */}
      {s.type === 'image-video' && (
        <div class="reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center;">
          <div style="text-align: center;">
            <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 8px 40px rgba(108,34,255,.12);">
              <img src={s.original!.src} alt={s.original!.alt} style="width: 100%; height: 380px; object-fit: cover; display: block;" loading="lazy" />
            </div>
            <div style="margin-top: 1rem; display: inline-block; background: white; color: #6C22FF; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 2px 12px rgba(108,34,255,.15);">
              {s.original!.label}
            </div>
          </div>
          <div style="text-align: center;">
            {s.aiResult!.isVideo ? (
              s.videoStyle === 'portrait' ? (
                <video src={s.aiResult!.src} autoplay loop muted playsinline style="height: 380px; width: auto; display: block; margin: 0 auto; border-radius: 20px; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5), 0 8px 40px rgba(108,34,255,.25);"></video>
              ) : (
                <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5), 0 8px 40px rgba(108,34,255,.25);">
                  <video src={s.aiResult!.src} autoplay loop muted playsinline style="width: 100%; height: 380px; object-fit: cover; display: block;"></video>
                </div>
              )
            ) : (
              <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5), 0 8px 40px rgba(108,34,255,.25);">
                <img src={s.aiResult!.src} alt={s.aiResult!.alt || s.title} style="width: 100%; height: 380px; object-fit: cover; display: block;" loading="lazy" />
              </div>
            )}
            <div style="margin-top: 1rem; display: inline-block; background: linear-gradient(90deg, #E879F9, #6C22FF); color: white; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 4px 18px rgba(232,121,249,.4);">
              {s.aiResult!.label}
            </div>
          </div>
        </div>
      )}

      {/* selfie layout */}
      {s.type === 'selfie' && (
        <div class="reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center;">
          <div style="text-align: center;">
            <div style="display: flex; justify-content: center;">
              <img src={s.portrait!.src} alt={s.portrait!.alt} style="height: 320px; width: auto; display: block; border-radius: 20px; box-shadow: 0 8px 40px rgba(108,34,255,.12);" loading="lazy" />
            </div>
            <div style="margin-top: 1rem; display: inline-block; background: white; color: #6C22FF; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 2px 12px rgba(108,34,255,.15);">
              {s.portrait!.label}
            </div>
          </div>
          <div style="text-align: center;">
            <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5);">
              <img src={s.aiResult!.src} alt={s.aiResult!.alt || s.title} style="width: 100%; height: auto; display: block;" loading="lazy" />
            </div>
            <div style="margin-top: 1rem; display: inline-block; background: linear-gradient(90deg, #E879F9, #6C22FF); color: white; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 4px 18px rgba(232,121,249,.4);">
              {s.aiResult!.label}
            </div>
          </div>
        </div>
      )}

      {/* portrait-scenes layout (Alex) */}
      {s.type === 'portrait-scenes' && (
        <>
          <div class="reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; margin-bottom: 2.5rem;">
            <div style="text-align: center;">
              <div style="display: flex; justify-content: center;">
                <img src={s.portrait!.src} alt={s.portrait!.alt} style="height: 300px; width: auto; display: block; border-radius: 20px; box-shadow: 0 8px 40px rgba(108,34,255,.15);" loading="lazy" />
              </div>
              <div style="margin-top: 1rem; display: inline-block; background: #F5F3FF; color: #6C22FF; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px;">
                {s.portrait!.label}
              </div>
            </div>
            <div style="text-align: center;">
              <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.4), 0 8px 40px rgba(108,34,255,.2);">
                <video src={s.openingVideo} autoplay loop muted playsinline style="width: 100%; height: 300px; object-fit: cover; display: block;"></video>
              </div>
              <div style="margin-top: 1rem; display: inline-block; background: linear-gradient(90deg, #E879F9, #6C22FF); color: white; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 4px 18px rgba(232,121,249,.4);">
                פתיח קולנועי שנוצר בעזרת AI
              </div>
            </div>
          </div>
          <div style="text-align: center; margin-bottom: 1.5rem;" class="reveal">
            <p style="color: #6C22FF; font-weight: 700; font-size: 1rem;">ואז — מה יעשה אחרי הפרישה?</p>
          </div>
          <div class="reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: start;">
            <div style="text-align: center;">
              <div style="border-radius: 18px; overflow: hidden; box-shadow: 0 6px 30px rgba(108,34,255,.12);">
                <img src={s.scenarios![0].src} alt={s.scenarios![0].alt} style="width: 100%; height: auto; display: block;" loading="lazy" />
              </div>
              <p style="margin-top: .75rem; font-weight: 700; color: #12023C; font-size: .92rem;">{s.scenarios![0].caption}</p>
            </div>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
              {s.scenarios!.slice(1).map(scene => (
                <div style="text-align: center;">
                  <div style="border-radius: 18px; overflow: hidden; box-shadow: 0 6px 30px rgba(108,34,255,.12);">
                    <img src={scene.src} alt={scene.alt} style="width: 100%; height: auto; display: block;" loading="lazy" />
                  </div>
                  <p style="margin-top: .75rem; font-weight: 700; color: #12023C; font-size: .92rem;">{scene.caption}</p>
                </div>
              ))}
            </div>
          </div>
        </>
      )}

      {/* grid-video layout */}
      {s.type === 'grid-video' && (
        <div style="max-width: 80%; margin: 0 auto;">
          <div class="reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
            {s.gridImages!.map(img => (
              <div style="text-align: center;">
                <div style="border-radius: 18px; overflow: hidden; box-shadow: 0 6px 30px rgba(108,34,255,.1);">
                  <img src={img.src} alt={img.alt} style={`${s.videoStyle === 'portrait' ? 'height: 280px; width: auto; margin: 0 auto;' : 'width: 100%;'} display: block;`} loading="lazy" />
                </div>
                <p style="margin-top: .75rem; font-weight: 700; color: #12023C; font-size: .88rem;">{img.caption}</p>
              </div>
            ))}
          </div>
          <div class="reveal" style="text-align: center; margin-bottom: 1.5rem;">
            <span style="color: #E879F9; font-size: 2rem; font-weight: 900;">↓</span>
          </div>
          <div class="reveal" style="text-align: center;">
            {s.videoStyle === 'portrait' ? (
              <video src={s.mainVideo} autoplay loop muted playsinline style="height: auto; max-height: 65vh; max-width: 52%; border-radius: 20px; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.45); display: inline-block;"></video>
            ) : (
              <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.45);">
                <video src={s.mainVideo} autoplay loop muted playsinline style="width: 100%; height: auto; display: block;"></video>
              </div>
            )}
            <p style="margin-top: 1rem; font-weight: 700; color: #6C22FF; font-size: .95rem;">{s.videoCaption}</p>
          </div>
        </div>
      )}

      {/* single-video layout */}
      {s.type === 'single-video' && (
        <div class="reveal" style="text-align: center;">
          <video
            id="main-video"
            src={s.mainVideo}
            autoplay loop muted playsinline
            style="height: auto; max-height: 65vh; max-width: 52%; border-radius: 20px; box-shadow: 0 0 0 3px #E879F9, 0 0 50px rgba(232,121,249,.5), 0 12px 50px rgba(108,34,255,.3); display: inline-block;"
          ></video>
          {s.hasSound && (
            <div style="margin-top: 1.2rem;">
              <button id="sound-btn" onclick="const v=document.getElementById('main-video');v.muted=!v.muted;this.textContent=v.muted?'🔇 לחץ לשמוע את רונלדו מברך':'🔊 מושתק — לחץ שוב לשמוע';" style="background: linear-gradient(90deg,#E879F9,#6C22FF); color: white; font-weight: 800; font-size: 1rem; padding: .7rem 2rem; border-radius: 50px; border: none; cursor: pointer; box-shadow: 0 6px 24px rgba(232,121,249,.4);">
                🔇 לחץ לשמוע את רונלדו מברך
              </button>
            </div>
          )}
          <p style="text-align: center; margin-top: 1rem; color: #6C22FF; font-weight: 700; font-size: .95rem;">{s.videoCaption}</p>
        </div>
      )}

      {/* קישור למצגת האמיתית */}
      {s.realPresentation && (
        <div class="reveal" style="margin-top: 3rem; text-align: center;">
          <a
            href={`/matzget/${s.realPresentation.slug}`}
            style="display: inline-flex; align-items: center; gap: .7rem; background: #F5F3FF; border: 2px solid #6C22FF; color: #6C22FF; font-weight: 700; font-size: .95rem; padding: .8rem 1.8rem; border-radius: 50px; text-decoration: none;"
          >
            🎬 לצפייה ב{s.realPresentation.label}
            {s.realPresentation.timeCode && (
              <span style="background: #6C22FF; color: white; font-size: .78rem; padding: .2rem .6rem; border-radius: 20px;">⏱ {s.realPresentation.timeCode}</span>
            )}
            ←
          </a>
        </div>
      )}

    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section style="padding: 3.5rem 1.5rem; background: #1e0a50; text-align: center;">
    <div style="max-width: 560px; margin: 0 auto;" class="reveal">
      <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); color: white; margin: 0 0 .75rem;">
        רוצים גם כזה?
      </h2>
      <p style="color: rgba(255,255,255,.65); font-size: .95rem; margin: 0 0 1.75rem;">שלחו תמונות ונציע רעיונות לשדרוג המצגת שלכם</p>
      <a href="https://wa.me/972526780531" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: .6rem; background: #25D366; color: white; font-weight: 800; font-size: 1rem; padding: .8rem 2.2rem; border-radius: 50px; text-decoration: none; box-shadow: 0 6px 24px rgba(37,211,102,.4);">
        <svg width="18" height="18" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        דברו איתנו בוואטסאפ
      </a>
    </div>
  </section>

  <!-- ═══ MORE SHOWCASES ═══ -->
  <section style="padding: 4rem 1.5rem; background: white;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <h2 style="font-family: 'Secular One', sans-serif; font-size: 1.5rem; color: #12023C; margin: 0 0 2rem; text-align: center;" class="reveal">
        עוד דוגמאות
      </h2>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
        {others.map(o => (
          <a href={`/שדרוגי-ai/${o.slug}`} class="reveal" style="display: block; border-radius: 16px; overflow: hidden; background: #F5F3FF; text-decoration: none; transition: transform .2s;">
            <div style="height: 160px; overflow: hidden;">
              {o.thumbnailIsVideo ? (
                <video src={o.thumbnail} autoplay loop muted playsinline style="width: 100%; height: 100%; object-fit: cover; display: block;"></video>
              ) : (
                <img src={o.thumbnail} alt={o.title} style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy" />
              )}
            </div>
            <div style="padding: 1rem 1.2rem;">
              <div style="color: #6C22FF; font-size: .7rem; font-weight: 700; letter-spacing: 1.5px; margin-bottom: .3rem;">{o.badge}</div>
              <p style="color: #12023C; font-weight: 700; font-size: .9rem; margin: 0;">{o.title}</p>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="/שדרוגי-ai" style="color: #6C22FF; font-weight: 700; text-decoration: none; font-size: .9rem;">← לכל הדוגמאות</a>
      </div>
    </div>
  </section>

  <Contact />

</Layout>
