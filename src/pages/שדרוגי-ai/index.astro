<style is:global>
  .page-btn {
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 2px solid rgba(108,34,255,.25);
    background: white;
    color: #6C22FF;
    font-weight: 700; font-size: .9rem;
    cursor: pointer;
    transition: all .18s ease;
    display: flex; align-items: center; justify-content: center;
  }
  .page-btn:hover { background: #F5F3FF; border-color: #6C22FF; }
  .page-btn.active { background: #6C22FF; color: white; border-color: #6C22FF; box-shadow: 0 4px 14px rgba(108,34,255,.3); }
  .page-btn.arrow { font-size: 1.1rem; }
  .page-btn:disabled { opacity: .3; cursor: default; }
  .tag-chip {
    background: white; border: 2px solid #e8e0fc; color: #6C22FF;
    font-weight: 600; font-size: .82rem; padding: .35rem 1rem;
    border-radius: 50px; cursor: pointer; transition: all .18s ease;
    font-family: inherit;
  }
  .tag-chip:hover { border-color: #6C22FF; background: #F5F3FF; }
  .tag-chip.active { background: #6C22FF; color: white; border-color: #6C22FF; box-shadow: 0 4px 14px rgba(108,34,255,.3); }
  .sound-round-btn {
    width: 60px; height: 60px; border-radius: 50%;
    background: linear-gradient(135deg, #7C3AED, #4c1d95);
    border: 4px solid white;
    cursor: pointer; z-index: 10;
    display: flex; align-items: center; justify-content: center;
    padding: 0;
    box-shadow: 0 8px 24px rgba(124,58,237,.4);
    animation: sound-pulse 2.2s ease-out infinite;
    transition: transform .2s;
  }
  .sound-round-btn:hover { transform: scale(1.07); }
  @keyframes sound-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(124,58,237,.55), 0 8px 24px rgba(124,58,237,.35); }
    70%  { box-shadow: 0 0 0 14px rgba(124,58,237,0), 0 8px 24px rgba(124,58,237,.35); }
    100% { box-shadow: 0 0 0 0 rgba(124,58,237,0), 0 8px 24px rgba(124,58,237,.35); }
  }
  .sound-btn {
    position: absolute; bottom: 12px; left: 12px; z-index: 10;
    background: rgba(220,38,38,.82);
    border: none; border-radius: 50%; width: 42px; height: 42px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background .2s, transform .15s;
    box-shadow: 0 2px 8px rgba(0,0,0,.3);
  }
  .sound-btn:hover { transform: scale(1.1); }
  @media (max-width: 640px) {
    .ai-compare-grid {
      grid-template-columns: 1fr !important;
    }
    .ai-compare-grid img,
    .ai-compare-grid video {
      height: 240px !important;
    }
  }
</style>

<script is:inline>
  // AI section video sound toggle
  const aiVideo    = document.getElementById('ai-section-video');
  const aiBtn      = document.getElementById('ai-section-sound-btn');
  const aiMuted    = document.getElementById('ai-section-icon-muted');
  const aiOn       = document.getElementById('ai-section-icon-on');
  const aiLabel    = document.getElementById('ai-section-sound-label');
  aiBtn?.addEventListener('click', () => {
    if (!aiVideo) return;
    aiVideo.muted = !aiVideo.muted;
    aiMuted.style.display = aiVideo.muted ? '' : 'none';
    aiOn.style.display    = aiVideo.muted ? 'none' : '';
    aiLabel.textContent   = aiVideo.muted ? 'מומלץ להפעיל סאונד' : 'השתקה';
  });

  // Hero video sound toggle
  var SVG_MUTED_HERO = '<svg viewBox="0 0 24 24" fill="white" width="20" height="20"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.9 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>';
  var SVG_SOUND_HERO  = '<svg viewBox="0 0 24 24" fill="white" width="20" height="20"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>';
  function toggleHeroSound() {
    var video = document.getElementById('hero-video');
    var btn   = document.getElementById('hero-sound-btn');
    if (!video || !btn) return;
    video.muted = !video.muted;
    btn.innerHTML = video.muted ? SVG_MUTED_HERO : SVG_SOUND_HERO;
    btn.style.background = video.muted ? 'rgba(0,0,0,.45)' : 'rgba(34,197,94,.75)';
  }


  // Sound toggle
  var SVG_MUTED = '<svg viewBox="0 0 24 24" fill="white" width="20" height="20"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.9 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>';
  var SVG_SOUND = '<svg viewBox="0 0 24 24" fill="white" width="20" height="20"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>';
  function toggleSound(btn) {
    var video = btn.previousElementSibling;
    if (!video) return;
    video.muted = !video.muted;
    btn.innerHTML = video.muted ? SVG_MUTED : SVG_SOUND;
    btn.style.background = video.muted ? 'rgba(220,38,38,.82)' : 'rgba(34,197,94,.85)';
    btn.title = video.muted ? 'הפעל צליל' : 'השתק';
  }

  // Filter + Pagination
  (function() {
    const PAGE_SIZE = 3;
    const allItems = Array.from(document.querySelectorAll('.showcase-item'));
    let activeTag = null;

    // Wire up tag chip clicks
    document.querySelectorAll('#ai-tag-filter .tag-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('#ai-tag-filter .tag-chip').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeTag = btn.dataset.tag || null;
        goToPage(1);
      });
    });

    function getFiltered() {
      if (!activeTag) return allItems;
      return allItems.filter(item => (item.dataset.tags || '').split(',').map(t => t.trim()).includes(activeTag));
    }

    function getPagesToShow(current, total) {
      if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
      const pages = [];
      pages.push(total);
      if (current < total - 2) pages.push('...');
      for (let i = Math.min(total - 1, current + 1); i >= Math.max(2, current - 1); i--) pages.push(i);
      if (current > 3) pages.push('...');
      pages.push(1);
      return pages;
    }

    function goToPage(page) {
      const filtered = getFiltered();
      const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
      allItems.forEach(item => item.style.display = 'none');
      filtered.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE).forEach(item => item.style.display = 'block');
      const info = document.getElementById('ai-page-info');
      if (info) info.textContent = page < totalPages ? 'עוד שדרוגי AI בעמודים הבאים ↓' : filtered.length + ' דוגמאות';
      buildPagination(page, totalPages);
      const videoSection = document.getElementById('ai-video-section');
      const videoSpacer = document.getElementById('ai-video-spacer');
      const videoCta = document.getElementById('ai-video-cta');
      if (videoSection) videoSection.style.display = page === 1 ? '' : 'none';
      if (videoSpacer) videoSpacer.style.display = page === 1 ? '' : 'none';
      if (videoCta) videoCta.style.display = page === 1 ? '' : 'none';
      if (page > 1) { const s = document.getElementById('showcases-section'); if (s) window.scrollTo({ top: s.offsetTop - 90, behavior: 'smooth' }); }
    }

    function buildPagination(page, totalPages) {
      const container = document.getElementById('ai-pagination');
      if (!container) return;
      container.innerHTML = '';
      if (totalPages <= 1) return;
      const prev = document.createElement('button');
      prev.className = 'page-btn arrow'; prev.textContent = '›'; prev.disabled = page === 1;
      prev.addEventListener('click', () => goToPage(page - 1));
      container.appendChild(prev);
      getPagesToShow(page, totalPages).forEach(p => {
        if (p === '...') {
          const d = document.createElement('span');
          d.textContent = '…'; d.style.cssText = 'color:#A78BFA;font-weight:700;padding:0 .2rem;display:flex;align-items:center;';
          container.appendChild(d);
        } else {
          const btn = document.createElement('button');
          btn.className = 'page-btn' + (p === page ? ' active' : ''); btn.textContent = String(p);
          btn.addEventListener('click', () => goToPage(p));
          container.appendChild(btn);
        }
      });
      const next = document.createElement('button');
      next.className = 'page-btn arrow'; next.textContent = '‹'; next.disabled = page === totalPages;
      next.addEventListener('click', () => goToPage(page + 1));
      container.appendChild(next);
    }

    goToPage(1);
  })();
</script>
