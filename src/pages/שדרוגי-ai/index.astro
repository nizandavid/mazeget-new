---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import { showcases } from '../../data/ai-showcases';

const featured = showcases.filter(s => s.featured);
const all = showcases;
---

<Layout
  title="שדרוגי AI למצגות — אפקטים, דיבוב ויצירות מיוחדות"
  description="אלמנטים מיוחדים, אפקטים וסצנות שנוצרים בעזרת AI — שדרוגים שהופכים כל מצגת לחוויה בלתי נשכחת."
>
  <Header />

  <!-- ═══ HERO ═══ -->
  <section id="ai-hero" style="background: #2e0975; padding: 5rem 1.5rem 5.5rem; text-align: center; position: relative; overflow: hidden;">
    <canvas id="ai-canvas" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;" aria-hidden="true"></canvas>
    <div style="position: relative; z-index: 1; max-width: 800px; margin: 0 auto;" class="reveal">
      <div style="display: inline-block; background: linear-gradient(90deg, #E879F9, #A855F7); color: white; font-size: .72rem; font-weight: 800; letter-spacing: 2px; padding: .35rem 1.1rem; border-radius: 50px; margin-bottom: 1.5rem; box-shadow: 0 4px 18px rgba(232,121,249,.45);">
        חדש — שדרוגי AI
      </div>
      <h1 style="font-family: 'Secular One', sans-serif; font-size: clamp(2.6rem, 6vw, 4.2rem); color: white; margin: 0 0 1.2rem; line-height: 1.1;">
        מצגות וידאו עם שדרוגי AI — מהתמונות שלכם לחוויה שכולם יזכרו
      </h1>
      <p style="font-size: clamp(1rem, 2.2vw, 1.15rem); color: rgba(255,255,255,0.82); line-height: 1.75; max-width: 640px; margin: 0 auto 2.5rem;">
        מצגת וידאו מקצועית מהתמונות שלכם — ועם רגע אחד של AI שגורם לכל האולם לעצור נשימה.<br><br>
        תמונה שמתחילה לזוז. ילד שמופיע בסט של Harry Potter. ברכה מרונלדו.<br><br>
        אנחנו מכינים מצגות וידאו מקצועיות לבר מצווה, בת מצווה, חתונות וימי הולדת — ומשלבים בהן שדרוג AI אחד או יותר שהופך מצגת טובה לבלתי נשכחת.
      </p>
      <a
        href="https://wa.me/972526780531"
        target="_blank"
        rel="noopener"
        style="display: inline-flex; align-items: center; gap: .6rem; background: #25D366; color: white; font-weight: 800; font-size: 1.05rem; padding: .9rem 2.4rem; border-radius: 50px; text-decoration: none; box-shadow: 0 6px 28px rgba(37,211,102,.45);"
      >
        <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        רוצה גם כזה? שלח הודעה
      </a>
    </div>
  </section>

  <!-- ═══ FEATURED — 2 SHOWCASES ═══ -->
  {featured.map((s, i) => (
    <section style={`padding: 5rem 1.5rem; background: ${i % 2 === 0 ? '#F5F3FF' : 'white'};`}>
      <div style="max-width: 1100px; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 3rem;" class="reveal">
          <div style="display: inline-block; background: linear-gradient(90deg, #6C22FF, #E879F9); color: white; font-size: .72rem; font-weight: 800; letter-spacing: 2px; padding: .35rem 1.1rem; border-radius: 50px; margin-bottom: 1rem;">
            {s.badge}
          </div>
          <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.4rem); color: #12023C; margin: 0 0 .75rem;">
            {s.title}
          </h2>
          <p style="color: #555; font-size: 1rem; max-width: 560px; margin: 0 auto; line-height: 1.7;">{s.description}</p>
        </div>

        <div class="reveal ai-compare-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center;">
          <!-- תמונה מקורית -->
          <div style="text-align: center;">
            <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 8px 40px rgba(108,34,255,.12);">
              <img
                src={s.original!.src}
                alt={s.original!.alt}
                style="width: 100%; height: 340px; object-fit: cover; display: block;"
                loading="lazy"
              />
            </div>
            <div style="margin-top: 1rem; display: inline-block; background: white; color: #6C22FF; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 2px 12px rgba(108,34,255,.15);">
              {s.original!.label}
            </div>
          </div>
          <!-- תוצאת AI -->
          <div style="text-align: center;">
            {s.aiResult!.isVideo ? (
              s.videoStyle === 'portrait' ? (
                <video src={s.aiResult!.src} autoplay loop muted playsinline style="height: 340px; width: auto; display: block; margin: 0 auto; border-radius: 20px; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5), 0 8px 40px rgba(108,34,255,.25);"></video>
              ) : (
                <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5), 0 8px 40px rgba(108,34,255,.25);">
                  <video src={s.aiResult!.src} autoplay loop muted playsinline style="width: 100%; height: 340px; object-fit: cover; display: block;"></video>
                </div>
              )
            ) : (
              <div style="border-radius: 20px; overflow: hidden; box-shadow: 0 0 0 3px #E879F9, 0 0 40px rgba(232,121,249,.5), 0 8px 40px rgba(108,34,255,.25);">
                <img src={s.aiResult!.src} alt={s.aiResult!.alt || s.title} style="width: 100%; height: 340px; object-fit: cover; display: block;" loading="lazy" />
              </div>
            )}
            <div style="margin-top: 1rem; display: inline-block; background: linear-gradient(90deg, #E879F9, #6C22FF); color: white; font-weight: 700; font-size: .85rem; padding: .45rem 1.2rem; border-radius: 50px; box-shadow: 0 4px 18px rgba(232,121,249,.4);">
              {s.aiResult!.label}
            </div>
          </div>
        </div>

        <div style="text-align: center; margin-top: 2rem;" class="reveal">
          <a href={`/שדרוגי-ai/${s.slug}`} style="display: inline-block; border: 2px solid #6C22FF; color: #6C22FF; font-weight: 700; font-size: .9rem; padding: .6rem 1.8rem; border-radius: 50px; text-decoration: none;">
            לסיפור המלא ←
          </a>
        </div>
      </div>
    </section>
  ))}

  <!-- ═══ ALL SHOWCASES GRID ═══ -->
  <section style="padding: 5rem 1.5rem; background: #e8e0fa;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3rem;" class="reveal">
        <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.4rem); color: #12023C; margin: 0 0 .75rem;">
          כל הדוגמאות
        </h2>
        <p style="color: #6C22FF; font-size: 1rem;">לחצו על כל דוגמה לסיפור המלא</p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
        {all.map(s => (
          <a href={`/שדרוגי-ai/${s.slug}`} class="reveal showcase-card" style="display: block; border-radius: 20px; overflow: hidden; background: #1e0a50; border: 1px solid rgba(255,255,255,.15); text-decoration: none; transition: transform .2s, border-color .2s;">
            <div style="position: relative; height: 200px; overflow: hidden;">
              {s.thumbnailIsVideo ? (
                <video src={s.thumbnail} autoplay loop muted playsinline style="width: 100%; height: 100%; object-fit: cover; display: block;"></video>
              ) : (
                <img src={s.thumbnail} alt={s.title} style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy" />
              )}
              {s.featured && (
                <div style="position: absolute; top: .75rem; right: .75rem; background: linear-gradient(90deg, #E879F9, #6C22FF); color: white; font-size: .65rem; font-weight: 800; letter-spacing: 1.5px; padding: .25rem .75rem; border-radius: 50px;">
                  מומלץ
                </div>
              )}
            </div>
            <div style="padding: 1.2rem 1.4rem;">
              <div style="color: #E879F9; font-size: .72rem; font-weight: 700; letter-spacing: 1.5px; margin-bottom: .5rem;">{s.badge}</div>
              <h3 style="color: white; font-weight: 800; font-size: 1rem; margin: 0 0 .5rem; line-height: 1.35;">{s.title}</h3>
              <p style="color: rgba(255,255,255,.55); font-size: .82rem; margin: 0; line-height: 1.55;">{s.description}</p>
              <div style="margin-top: 1rem; color: #E879F9; font-size: .82rem; font-weight: 700;">ראו את הסיפור ←</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CATEGORIES ═══ -->
  <section style="padding: 5rem 1.5rem; background: white;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3rem;" class="reveal">
        <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.4rem); color: #12023C; margin: 0;">מה אפשר לעשות עם AI</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem;">
        <div class="reveal" style="background: #F5F3FF; border-radius: 24px; padding: 2rem 1.75rem; text-align: right;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">🎬</div>
          <h3 style="font-family: 'Secular One', sans-serif; font-size: 1.25rem; color: #12023C; margin: 0 0 1rem;">וידאו AI</h3>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .6rem; color: #555; font-size: .92rem; line-height: 1.55;">
            <li>✓ טרנספורמציות וסצנות בתנועה</li>
            <li>✓ אנימציות על תמונות סטילס</li>
            <li>✓ אפקטים קולנועיים מרהיבים</li>
            <li>✓ פתיחות קולנועיות ייחודיות</li>
          </ul>
        </div>
        <div class="reveal" style="background: #F5F3FF; border-radius: 24px; padding: 2rem 1.75rem; text-align: right;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">🖼️</div>
          <h3 style="font-family: 'Secular One', sans-serif; font-size: 1.25rem; color: #12023C; margin: 0 0 1rem;">תמונות AI</h3>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .6rem; color: #555; font-size: .92rem; line-height: 1.55;">
            <li>✓ סצנות דמיוניות שלא צולמו</li>
            <li>✓ רקעים מיוחדים ומרהיבים</li>
            <li>✓ קומפוזיציות ייחודיות</li>
            <li>✓ עולמות פנטזיה ואגדה</li>
          </ul>
        </div>
        <div class="reveal" style="background: #F5F3FF; border-radius: 24px; padding: 2rem 1.75rem; text-align: right;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">🎵</div>
          <h3 style="font-family: 'Secular One', sans-serif; font-size: 1.25rem; color: #12023C; margin: 0 0 1rem;">אודיו AI</h3>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .6rem; color: #555; font-size: .92rem; line-height: 1.55;">
            <li>✓ שירים מותאמים אישית</li>
            <li>✓ דיבוב בקולות מוכרים</li>
            <li>✓ ברכות קוליות ייחודיות</li>
            <li>✓ מוזיקת רקע מותאמת</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ AI IDEAS ═══ -->
  <section style="padding: 5rem 1.5rem; background: #1e0a50;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3rem;" class="reveal">
        <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.4rem); color: white; margin: 0 0 .75rem;">רעיונות למצגות עם AI</h2>
        <p style="color: rgba(255,255,255,.6); font-size: 1rem; max-width: 500px; margin: 0 auto;">אפשר לשלב בכל אירוע — בר מצווה, בת מצווה, יום הולדת, חתונה</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.2rem;">
        {[
          { icon: '👸', text: 'להפוך את הילדה לנסיכה מהאגדות' },
          { icon: '🌍', text: 'ליצור סצנה של טיול דמיוני בעולם' },
          { icon: '🎬', text: 'לשלב פתיחה קולנועית מיוחדת' },
          { icon: '🎵', text: 'ליצור שיר אישי בעזרת AI' },
          { icon: '🎤', text: 'לשלב ברכה בקול מוכר' },
          { icon: '⚽', text: 'סלפי עם כוכבי ספורט אהובים' },
          { icon: '🗼', text: 'לשים את הילד בכל מקום בעולם' },
          { icon: '✨', text: 'תמונה שמתחילה לזוז ולחיות' },
        ].map(idea => (
          <div class="reveal" style="background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 16px; padding: 1.2rem 1.4rem; display: flex; align-items: center; gap: .9rem;">
            <span style="font-size: 1.8rem; flex-shrink: 0;">{idea.icon}</span>
            <p style="color: rgba(255,255,255,.85); font-size: .9rem; font-weight: 600; margin: 0; line-height: 1.45;">{idea.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section style="padding: 5rem 1.5rem; background: white;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3.5rem;" class="reveal">
        <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.4rem); color: #12023C; margin: 0;">
          איך זה עובד?
        </h2>
      </div>
      <div class="reveal" style="display: flex; align-items: flex-start; justify-content: center; gap: 0;">
        {[
          { n: '1', text: 'שולחים תמונות' },
          { n: '2', text: 'אנחנו מציעים רעיונות' },
          { n: '3', text: 'יוצרים עם AI' },
          { n: '4', text: 'משלבים במצגת' },
          { n: '5', text: 'מצגת מרגשת ובלתי נשכחת' },
        ].map((step, i, arr) => (
          <>
            <div style="display: flex; flex-direction: column; align-items: center; text-align: center; flex: 1; padding: 0 .75rem;">
              <div style="width: 52px; height: 52px; border-radius: 50%; background: linear-gradient(135deg, #E879F9, #6C22FF); color: white; font-weight: 900; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">{step.n}</div>
              <p style="color: #12023C; font-weight: 700; font-size: .95rem; line-height: 1.45; margin: 0;">{step.text}</p>
            </div>
            {i < arr.length - 1 && (
              <div style="color: rgba(108,34,255,.4); font-size: 1.6rem; margin-top: 14px; flex-shrink: 0;">&#8592;</div>
            )}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ WHY AI ═══ -->
  <section style="padding: 5rem 1.5rem; background: white;">
    <div style="max-width: 800px; margin: 0 auto; text-align: right;">
      <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.2rem); color: #12023C; margin: 0 0 1.25rem;" class="reveal">
        כולם עושים מצגת. לא כולם עושים רגע שעוצר את האולם.
      </h2>
      <p style="color: #555; font-size: 1.05rem; line-height: 1.85; margin-bottom: 1rem;">
        מצגת וידאו טובה מרגשת — זה ידוע. אבל יש הבדל בין "יפה, בכינו קצת" לבין "רגע, מה זה עכשיו?!"
      </p>
      <p style="color: #555; font-size: 1.05rem; line-height: 1.85; margin-bottom: 1rem;">
        שדרוג AI הוא אותו רגע. תמונה שפתאום מתחילה לזוז. ילדה שמופיעה בצד הזוהר של Wicked. אבא שמקבל ברכה מכוכב כדורגל אהוב.
      </p>
      <p style="color: #555; font-size: 1.05rem; line-height: 1.85;">
        כי בסוף — מצגות שכולם זוכרים הן לא בהכרח הכי ארוכות או הכי יקרות. הן פשוט מכילות <strong style="color: #6C22FF;">את הרגע הנכון.</strong>
      </p>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section style="padding: 5rem 1.5rem; background: #F5F3FF;">
    <div style="max-width: 800px; margin: 0 auto;">
      <h2 style="font-family: 'Secular One', sans-serif; font-size: clamp(1.7rem, 3.5vw, 2.2rem); color: #12023C; margin: 0 0 2.5rem; text-align: center;" class="reveal">
        שאלות נפוצות
      </h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">

        {[
          { q: 'מה זה בעצם שדרוג AI במצגת?', a: 'מצגת וידאו מקצועית מהתמונות שלכם, עם תוספת של רגע אחד (או כמה) שנוצר בעזרת בינה מלאכותית. למשל: תמונה שמתחילה לזוז, סצנה דמיונית, דיבוב בקול מוכר, או סלפי עם כוכב. הרגע הזה הוא מה שכולם מדברים עליו אחרי האירוע.' },
          { q: 'לאיזה אירועים מתאים שדרוג AI?', a: 'לכל אירוע — מצגת בר מצווה עם AI, מצגת בת מצווה עם בינה מלאכותית, יום הולדת, חתונה או פרישה. בכל אירוע יש רגע שיכול להפוך לבלתי נשכח.' },
          { q: 'כמה זה עולה?', a: 'שדרוג AI הוא תוספת על מצגת הוידאו הרגילה. המחיר תלוי בסוג השדרוג. שלחו לנו תיאור — נחזור עם הצעה מדויקת.' },
          { q: 'צריך לשלוח תמונות מיוחדות?', a: 'לא. תמונה רגילה מהטלפון עובדת מצוין. אנחנו מסבירים בדיוק מה צריך לפי הרגע שתרצו ליצור.' },
          { q: 'האם זה נראה אמיתי?', a: 'תלוי בסוג. סרטוני תנועה מתמונה נראים מרהיבים. תמונות AI צריכות הנחיה נכונה — אנחנו יודעים מה עובד ומה לא, ורק מציעים מה שיראה טוב באמת.' },
          { q: 'אפשר להוסיף AI למצגת שכבר הזמנתי?', a: 'בהחלט. אפשר להוסיף שדרוג AI בכל שלב — גם אם כבר התחלנו לעבוד יחד.' },
