---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import { categories } from '../../data/categories';

const WP_URL = import.meta.env.WP_URL || 'http://mazeget-local.local';

export async function getStaticPaths() {
  const { categories } = await import('../../data/categories');
  return categories.map(cat => ({ params: { category: cat.key } }));
}

const { category } = Astro.params;
const catInfo = categories.find(c => c.key === category);

let presentations = [];
try {
  const res = await fetch(`${WP_URL}/wp-json/wp/v2/presentations`);
  const all = await res.json();
  presentations = all.filter((p: any) => p.acf_fields?.category === category);
} catch (e) {
  presentations = [];
}
---

<Layout title={`${catInfo?.label} — מצגות וידאו | Mazeget`}>
  <Header />

  <!-- Hero -->
  <section class="py-24 px-6 text-center" style="background: linear-gradient(135deg, #6C22FF 0%, #E879F9 100%);">
    <div class="text-6xl mb-4">{catInfo?.emoji}</div>
    <h1 class="text-5xl text-white font-black mb-4" style="font-family: 'Secular One', sans-serif;">
      מצגות {catInfo?.label}
    </h1>
    <p class="text-white/90 text-xl max-w-xl mx-auto">{catInfo?.description}</p>
  </section>

  <!-- Presentations -->
  <section class="py-20 px-6 bg-[#F8F7FF]">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-black text-[#12023C] text-center mb-12" style="font-family: 'Secular One', sans-serif;">
        דוגמאות עבודות
      </h2>

      {presentations.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-400 text-lg">בקרוב יתווספו דוגמאות לקטגוריה זו</p>
          <a href="/#contact" class="inline-block mt-6 bg-[#6C22FF] text-white font-bold px-8 py-3 rounded-full hover:bg-[#5a1dd6] transition-colors">
            צרו קשר לפרטים
          </a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {presentations.map((p: any) => {
            const vimeoId = p.acf_fields?.vimeo_url?.match(/vimeo\.com\/(\d+)/)?.[1];
            return (
              <div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all hover:-translate-y-1">
                {vimeoId ? (
                  <div class="aspect-video">
                    <iframe
                      src={`https://player.vimeo.com/video/${vimeoId}`}
                      class="w-full h-full"
                      frameborder="0"
                      allow="autoplay; fullscreen"
                    ></iframe>
                  </div>
                ) : (
                  <div class="aspect-video bg-gradient-to-br from-[#6C22FF] to-[#E879F9] flex items-center justify-center">
                    <span class="text-white text-4xl">{catInfo?.emoji}</span>
                  </div>
                )}
                <div class="p-4 text-right">
                  <h3 class="font-bold text-[#12023C]">{p.title.rendered}</h3>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- SEO Text -->
  <section class="py-16 px-6 bg-white">
    <div class="max-w-2xl mx-auto text-right">
      <h2 class="text-2xl font-black text-[#12023C] mb-4" style="font-family: 'Secular One', sans-serif;">
        מצגת {catInfo?.label} מקצועית
      </h2>
      <p class="text-gray-600 leading-relaxed">
        {catInfo?.description} אנחנו ב-Mazeget מתמחים ביצירת מצגות וידאו מותאמות אישית לכל אירוע.
        כל מצגת עוברת עריכה מקצועית עם טכנולוגיית AI מתקדמת — מהתמונות שלכם ועד מצגת מרגשת.
      </p>
    </div>
  </section>

  <Contact />

</Layout>
