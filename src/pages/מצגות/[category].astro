---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import { categories } from '../../data/categories';
import { getVideosForCategory, getVideoPages } from '../../lib/sheets';

export async function getStaticPaths() {
  const { categories } = await import('../../data/categories');
  return categories.map(cat => ({ params: { category: cat.key } }));
}

const { category } = Astro.params;
const catInfo = categories.find(c => c.key === category);
const videos = await getVideosForCategory(category!);
const slugMap = new Map<string, string>(); // placeholder — fallback מטופל ב-template

const isOther = category === 'other';
const subcategories = isOther
  ? ['הכל', ...Array.from(new Set(videos.map(v => v.subcategory).filter(Boolean)))]
  : [];

// נתוני עמודי מצגות לסינון לפי נושא / פתיח
const allPages = await getVideoPages();
const pageMap = new Map(allPages.filter(p => p.category_key === category).map(p => [p.vimeo_id, p]));

const topicValues = [...new Set([...pageMap.values()].map(p => p.detail_style).filter(Boolean))];
const introValues = [...new Set(
  [...pageMap.values()].flatMap(p =>
    p.detail_elements ? p.detail_elements.split(',').map(s => s.trim()).filter(Boolean) : []
  )
)];
const showTopicFilter = topicValues.length > 1;
const showIntroFilter = introValues.length > 1;

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `מצגת ${catInfo?.label}`,
  "description": catInfo?.description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mazeget — ניצן שמיר מצגות",
    "url": "https://mazeget.com",
    "telephone": "+972526780531"
  },
  "areaServed": { "@type": "Country", "name": "Israel" },
  "url": `https://mazeget.com/מצגות/${category}`,
  "inLanguage": "he"
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "דף הבית", "item": "https://mazeget.com" },
    { "@type": "ListItem", "position": 2, "name": "מצגות", "item": "https://mazeget.com" },
    { "@type": "ListItem", "position": 3, "name": catInfo?.label, "item": `https://mazeget.com/מצגות/${category}` }
  ]
});
---

<Layout
  title={`${catInfo?.label} — מצגות וידאו | Mazeget`}
  description={`${catInfo?.description}. צפו בדוגמאות אמיתיות של מצגות ${catInfo?.label} שיצרנו — עיצוב מקצועי עם AI, מוכן להקרנה באירוע.`}
  eventLabel={catInfo?.label}
>
  <script type="application/ld+json" is:inline set:html={serviceSchema} slot="head" />
  <script type="application/ld+json" is:inline set:html={breadcrumbSchema} slot="head" />
  <Header />

  <!-- Hero -->
  <section class="py-14 px-6 text-center" style="background: linear-gradient(135deg, #6C22FF 0%, #E879F9 100%);">
    <h1 class="text-5xl text-white font-black mb-3" style="font-family: 'Secular One', sans-serif;">
      {isOther ? 'מצגות שוות לכל אירוע' : `מצגות ${catInfo?.label}`}
    </h1>
    <p class="text-white/90 text-xl max-w-xl mx-auto">{catInfo?.description}</p>
  </section>

  <!-- Gallery -->
  <section class="py-10 px-6 bg-[#F8F7FF]">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-black text-[#12023C] text-center mb-6" style="font-family: 'Secular One', sans-serif;">
        מצגות מקצועיות נוספות
      </h2>

      {(showTopicFilter || showIntroFilter) && (
        <div class="mb-8 space-y-3">
          {showTopicFilter && (
            <div class="flex flex-wrap gap-2 justify-center items-center">
              <span class="text-sm font-bold text-[#12023C] ml-3">נושא:</span>
              <button class="topic-btn px-4 py-1.5 rounded-full border-2 font-bold text-sm transition-all" data-value="" style="background:#6C22FF; color:white; border-color:#6C22FF;">הכל</button>
              {topicValues.map(t => (
                <button class="topic-btn px-4 py-1.5 rounded-full border-2 font-bold text-sm transition-all" data-value={t} style="background:white; color:#6C22FF; border-color:#6C22FF;">{t}</button>
              ))}
            </div>
          )}
          {showIntroFilter && (
            <div class="flex flex-wrap gap-2 justify-center items-center">
              <span class="text-sm font-bold text-[#12023C] ml-3">פתיח:</span>
              <button class="intro-btn px-4 py-1.5 rounded-full border-2 font-bold text-sm transition-all" data-value="" style="background:#6C22FF; color:white; border-color:#6C22FF;">הכל</button>
              {introValues.map(i => (
                <button class="intro-btn px-4 py-1.5 rounded-full border-2 font-bold text-sm transition-all" data-value={i} style="background:white; color:#6C22FF; border-color:#6C22FF;">{i}</button>
              ))}
            </div>
          )}
        </div>
      )}

      {isOther && subcategories.length > 1 && (
        <div class="flex flex-wrap gap-3 justify-center mb-10" id="filter-buttons">
          {subcategories.map(sub => (
            <button
              class="filter-btn px-5 py-2 rounded-full border-2 font-bold text-sm transition-all"
              data-filter={sub}
              style={sub === 'הכל' ? 'background:#6C22FF; color:white; border-color:#6C22FF;' : 'background:white; color:#6C22FF; border-color:#6C22FF;'}
            >
              {sub}
            </button>
          ))}
        </div>
      )}

      {videos.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-400 text-lg">בקרוב יתווספו דוגמאות לקטגוריה זו</p>
          <a href="/#contact" class="inline-block mt-6 bg-[#6C22FF] text-white font-bold px-8 py-3 rounded-full">
            צרו קשר לפרטים
          </a>
        </div>
      ) : (
        <>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="video-grid">
            {videos.map((v, i) => (
              <div
                class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all hover:-translate-y-1 cursor-pointer video-card"
                data-video-id={v.vimeo_id}
                data-subcategory={v.subcategory || ''}
                data-index={i}
                data-page-slug={slugMap.get(v.vimeo_id) || `video-${v.vimeo_id}`}
                data-topic={pageMap.get(v.vimeo_id)?.detail_style || ''}
                data-intro={pageMap.get(v.vimeo_id)?.detail_elements || ''}
                style={i >= 6 ? 'display:none' : ''}
              >
                <div class="aspect-video relative bg-gray-900">
                  {v.thumbnail && (
                    <img src={v.thumbnail} alt={v.title} class="w-full h-full object-cover" loading="lazy" />
                  )}
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-16 h-16 rounded-full bg-white/90 flex items-center justify-center shadow-lg">
                      <svg width="22" height="22" fill="#7C3AED" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                  </div>
                </div>
                <div class="p-4 text-right">
                  <h3 class="font-bold text-[#12023C] mb-1">{v.title}</h3>
                  {v.description && <p class="text-sm text-gray-500 leading-relaxed">{v.description}</p>}
                </div>
              </div>
            ))}
          </div>

          {videos.length > 6 && (
            <div class="text-center mt-12" id="load-more-wrap">
              <button id="load-more-btn" class="bg-[#6C22FF] text-white font-bold px-10 py-3 rounded-full hover:bg-[#5a1dd6] transition-colors text-lg">
                הצג 6 נוספים
              </button>
              <p class="text-gray-400 text-sm mt-3" id="video-counter">
                מציג 6 מתוך {videos.length}
              </p>
            </div>
          )}
        </>
      )}
    </div>
  </section>

  <!-- SEO Text -->
  <section class="py-10 px-6 bg-white">
    <div class="max-w-2xl mx-auto text-right">
      <h2 class="text-2xl font-black text-[#12023C] mb-4" style="font-family: 'Secular One', sans-serif;">
        {isOther ? 'מצגות מקצועיות לכל אירוע' : `מצגת ${catInfo?.label} מקצועית`}
      </h2>
      <p class="text-gray-600 leading-relaxed">
        {catInfo?.description} אנחנו ב-Mazeget מתמחים ביצירת מצגות וידאו מותאמות אישית לכל אירוע.
        כל מצגת עוברת עריכה מקצועית עם טכנולוגיית AI מתקדמת — מהתמונות שלכם ועד מצגת מרגשת.
      </p>
    </div>
  </section>

  <!-- AI BANNER -->
  <section style="padding: 2.5rem 6%; background: linear-gradient(135deg, #0a0118, #2d0a6e); text-align: center;">
    <p style="color: rgba(255,255,255,.7); font-size: .95rem; margin: 0 0 .8rem;">רוצים לשדרג את המצגת עם אלמנטים מיוחדים?</p>
    <a href="/שדרוגי-ai" style="display: inline-block; background: linear-gradient(135deg, #6C22FF, #E879F9); color: white; font-weight: 800; font-size: .95rem; padding: .7rem 2rem; border-radius: 50px; text-decoration: none; box-shadow: 0 6px 20px rgba(108,34,255,.4);">
      ✨ ראו את שדרוגי ה-AI שלנו
    </a>
  </section>

  <Contact />

</Layout>

<!-- Lightbox -->
<div id="video-lightbox" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.9); z-index:600; align-items:center; justify-content:center; padding:1rem;">
  <button id="lightbox-close" style="position:absolute; top:1.2rem; left:1.2rem; background:rgba(255,255,255,.15); border:none; color:white; width:46px; height:46px; border-radius:50%; font-size:1.8rem; cursor:pointer; display:flex; align-items:center; justify-content:center;">×</button>
  <div id="lightbox-content" style="width:min(960px,95vw); aspect-ratio:16/9; border-radius:12px; overflow:hidden; background:#000;"></div>
</div>

<script define:vars={{ total: videos.length }}>
  let shown = 6;
  const STEP = 6;
  let activeTopic = '';
  let activeIntro = '';
  let activeSubcat = 'הכל';

  function applyFilters() {
    const cards = document.querySelectorAll('.video-card');
    const filterActive = activeTopic || activeIntro || activeSubcat !== 'הכל';
    cards.forEach((card, i) => {
      const el = card;
      const topic = el.dataset.topic || '';
      const intro = el.dataset.intro || '';
      const sub   = el.dataset.subcategory || '';
      const topicMatch  = !activeTopic  || topic === activeTopic;
      const introMatch  = !activeIntro  || intro.split(',').map(s => s.trim()).includes(activeIntro);
      const subcatMatch = activeSubcat === 'הכל' || sub === activeSubcat;
      const matches = topicMatch && introMatch && subcatMatch;
      el.style.display = filterActive ? (matches ? '' : 'none') : (i < shown ? '' : 'none');
    });
    const wrap = document.getElementById('load-more-wrap');
    if (wrap) wrap.style.display = filterActive || shown >= total ? 'none' : '';
  }

  window.__applyFilters      = applyFilters;
  window.__setActiveTopic    = v => { activeTopic  = v; applyFilters(); };
  window.__setActiveIntro    = v => { activeIntro  = v; applyFilters(); };
  window.__setActiveSubcat   = v => { activeSubcat = v; applyFilters(); };

  document.getElementById('load-more-btn')?.addEventListener('click', function() {
    shown = Math.min(shown + STEP, total);
    applyFilters();
    const counter = document.getElementById('video-counter');
    if (counter) counter.textContent = 'מציג ' + shown + ' מתוך ' + total;
    if (shown >= total) {
      const wrap = document.getElementById('load-more-wrap');
      if (wrap) wrap.remove();
    }
  });
</script>

<script>
  function setActive(btns: NodeListOf<Element>, value: string, attr: string) {
    btns.forEach(b => {
      const el = b as HTMLElement;
      const isActive = (el.dataset[attr] ?? el.dataset.value) === value;
      el.style.background = isActive ? '#6C22FF' : 'white';
      el.style.color      = isActive ? 'white'   : '#6C22FF';
    });
  }

  // topic filter
  document.querySelectorAll('.topic-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const val = (btn as HTMLElement).dataset.value ?? '';
      setActive(document.querySelectorAll('.topic-btn'), val, 'value');
      (window as any).__setActiveTopic?.(val);
    });
  });

  // intro filter
  document.querySelectorAll('.intro-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const val = (btn as HTMLElement).dataset.value ?? '';
      setActive(document.querySelectorAll('.intro-btn'), val, 'value');
      (window as any).__setActiveIntro?.(val);
    });
  });

  // subcategory filter (קטגוריה "אחר")
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter || 'הכל';
      setActive(document.querySelectorAll('.filter-btn'), filter, 'filter');
      (window as any).__setActiveSubcat?.(filter);
    });
  });

  // Navigation to presentation page
  document.querySelectorAll('.video-card').forEach(card => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      const slug = el.dataset.pageSlug;
      if (slug) { window.location.href = '/matzget/' + slug; return; }
      const id = el.dataset.videoId;
      const content = document.getElementById('lightbox-content');
      const lb = document.getElementById('video-lightbox');
      if (!content || !lb || !id) return;
      content.innerHTML = `<iframe src="https://player.vimeo.com/video/${id}?autoplay=1&color=7C3AED" width="100%" height="100%" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>`;
      lb.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    });
  });

  function closeLightbox() {
    const lb = document.getElementById('video-lightbox');
    const content = document.getElementById('lightbox-content');
    if (lb) lb.style.display = 'none';
    if (content) content.innerHTML = '';
    document.body.style.overflow = '';
  }

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('video-lightbox')?.addEventListener('click', e => {
    if (e.target === document.getElementById('video-lightbox')) closeLightbox();
  });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>
