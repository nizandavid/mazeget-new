---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="מאמרים — Mazeget מצגות" pageUrl="https://mazeget.com/מאמרים">
  <Header />

  <!-- Hero -->
  <section class="py-20 px-6 text-center" style="background: linear-gradient(135deg, #12023C 0%, #6C22FF 100%);">
    <h1 class="text-5xl text-white font-black mb-4" style="font-family: 'Secular One', sans-serif;">מאמרים וטיפים</h1>
    <p class="text-white/90 text-xl max-w-xl mx-auto">כל מה שצריך לדעת על מצגות וידאו לאירועים</p>
  </section>

  <!-- Category Filter -->
  <section id="cat-filter" class="py-8 px-6 bg-white border-b border-gray-100" style="display:none;">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-center gap-3" id="cat-buttons"></div>
  </section>

  <!-- Posts Grid -->
  <section class="py-16 px-6 bg-[#F8F7FF]">
    <div class="max-w-5xl mx-auto">
      <div id="posts-loading" class="text-center py-20 text-gray-400">טוען מאמרים...</div>
      <div id="posts-error" class="text-center py-20 text-red-400" style="display:none;"></div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid" style="display:none;"></div>
    </div>
  </section>

</Layout>

<script>
  const WP_API = '/api/wp/wp/v2';

  function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('he-IL', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function renderPosts(posts: any[], activeCat: string | number = 'all') {
    const grid = document.getElementById('posts-grid')!;
    grid.innerHTML = posts
      .filter(p => activeCat === 'all' || p.categories.includes(Number(activeCat)))
      .map(post => `
        <article class="post-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all hover:-translate-y-1 cursor-pointer" data-categories='${JSON.stringify(post.categories)}'>
          <a href="/מאמרים/${decodeURIComponent(post.slug)}">
            <div class="p-6 text-right">
              <p class="text-xs text-gray-400 mb-2">${formatDate(post.date)}</p>
              <h2 class="font-black text-[#12023C] text-lg mb-3 leading-tight">${post.title.rendered}</h2>
              <p class="text-gray-500 text-sm leading-relaxed line-clamp-3">${post.excerpt.rendered.replace(/<[^>]*>/g, '').substring(0, 120)}...</p>
              <span class="inline-block mt-4 text-[#6C22FF] font-medium text-sm">קרא עוד ←</span>
            </div>
          </a>
        </article>
      `).join('');
    grid.style.display = 'grid';
  }

  async function loadPosts() {
    const loading = document.getElementById('posts-loading')!;
    const errorEl = document.getElementById('posts-error')!;

    try {
      const [postsRes, catsRes] = await Promise.all([
        fetch(`${WP_API}/posts?per_page=100&_fields=id,slug,title,excerpt,date,categories`),
        fetch(`${WP_API}/categories?per_page=50`)
      ]);

      if (!postsRes.ok) throw new Error('שגיאה בטעינת מאמרים');
      const posts = await postsRes.json();
      const categories = catsRes.ok ? await catsRes.json() : [];

      loading.style.display = 'none';

      // Category buttons
      if (categories.filter((c: any) => c.count > 0).length > 0) {
        const filterSection = document.getElementById('cat-filter')!;
        const btnContainer = document.getElementById('cat-buttons')!;
        filterSection.style.display = '';

        const allBtn = document.createElement('button');
        allBtn.dataset.cat = 'all';
        allBtn.className = 'cat-btn px-5 py-2 rounded-full text-sm font-medium border-2 border-[#6C22FF] bg-[#6C22FF] text-white transition-all';
        allBtn.textContent = 'הכל';
        btnContainer.appendChild(allBtn);

        categories.filter((c: any) => c.count > 0).forEach((cat: any) => {
          const btn = document.createElement('button');
          btn.dataset.cat = String(cat.id);
          btn.className = 'cat-btn px-5 py-2 rounded-full text-sm font-medium border-2 border-[#6C22FF] text-[#6C22FF] bg-white transition-all';
          btn.textContent = `${cat.name} (${cat.count})`;
          btnContainer.appendChild(btn);
        });

        btnContainer.querySelectorAll('.cat-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            btnContainer.querySelectorAll('.cat-btn').forEach(b => {
              (b as HTMLElement).style.background = 'white';
              (b as HTMLElement).style.color = '#6C22FF';
            });
            (btn as HTMLElement).style.background = '#6C22FF';
            (btn as HTMLElement).style.color = 'white';
            renderPosts(posts, (btn as HTMLElement).dataset.cat || 'all');
          });
        });
      }

      if (posts.length === 0) {
        errorEl.textContent = 'אין מאמרים להצגה כרגע';
        errorEl.style.display = '';
      } else {
        renderPosts(posts);
      }

    } catch (e: any) {
      loading.style.display = 'none';
      errorEl.textContent = 'לא הצלחנו לטעון את המאמרים, נסה שוב מאוחר יותר';
      errorEl.style.display = '';
    }
  }

  loadPosts();
</script>
