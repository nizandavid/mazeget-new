---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import postsData from '../../data/posts.json';

const posts = (postsData as any[]).map(p => ({
  id: p.id,
  slug: p.slug,
  title: p.title,
  excerpt: p.excerpt,
  date: p.date,
  categories: p.categories,
  _embedded: p._embedded,
  _terms: p._embedded?.['wp:term']?.[0] ?? [],
}));

// Build category map: id → name
const catMap: Record<number, string> = {};
for (const p of postsData as any[]) {
  const terms = p._embedded?.['wp:term']?.[0] ?? [];
  for (const t of terms) {
    if (t.id && t.name) catMap[t.id] = t.name;
  }
}
const catMapJson = JSON.stringify(catMap);
const postsJson = JSON.stringify(posts);
---

<Layout
  title="מדריכים וטיפים על מצגות וידאו לאירועים בישראל"
  description="מאמרים וטיפים על מצגות וידאו לאירועים — כל מה שצריך לדעת על הזמנת מצגת מקצועית לבר מצווה, בת מצווה, ימי הולדת וחתונות."
  noAutoOpen={true}
  pageUrl="https://mazeget.com/מאמרים"
>
  <Header />

  <!-- Hero -->
  <section class="py-10 px-6 text-center" style="background: linear-gradient(135deg, #12023C 0%, #6C22FF 100%);">
    <p class="text-[#E879F9] text-sm font-semibold uppercase tracking-widest mb-2">הבלוג שלנו</p>
    <h1 class="text-4xl md:text-5xl text-white font-black mb-3 leading-tight" style="font-family: 'Secular One', sans-serif;">מאמרים וטיפים</h1>
    <p class="text-white/75 text-base max-w-md mx-auto">כל מה שצריך לדעת על מצגות וידאו לאירועים</p>
  </section>

  <!-- Category Filter -->
  <section id="cat-filter" class="py-5 px-6 bg-white border-b border-gray-100 sticky top-0 z-10" style="display:none;">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-center gap-2" id="cat-buttons"></div>
  </section>

  <!-- Posts Grid -->
  <section class="py-12 px-6 bg-[#F8F7FF] min-h-[40vh]">
    <div class="max-w-5xl mx-auto">
      <div id="posts-loading" class="flex flex-col items-center justify-center py-20 gap-3 text-[#6C22FF]/50">
        <svg class="animate-spin w-7 h-7" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
        </svg>
        <span class="text-sm font-medium">טוען מאמרים...</span>
      </div>
      <script id="posts-data" type="application/json" set:html={postsJson}></script>
      <script id="cat-map-data" type="application/json" set:html={catMapJson}></script>
      <div id="posts-error" class="text-center py-16 text-gray-400 text-sm" style="display:none;"></div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid" style="display:none;"></div>

      <!-- Pagination -->
      <div id="pagination-wrap" class="mt-10" style="display:none;">
        <div class="flex flex-wrap items-center justify-center gap-2" id="pagination-buttons"></div>
        <p class="text-center text-sm text-gray-400 mt-3" id="pagination-info"></p>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  .post-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(108, 34, 255, 0.08);
    box-shadow: 0 2px 12px rgba(18, 2, 60, 0.06);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(108, 34, 255, 0.15);
  }
  .post-card .card-arrow {
    transition: transform 0.2s ease;
  }
  .post-card:hover .card-arrow {
    transform: translateX(-4px);
  }
  .cat-btn-active {
    background: #6C22FF !important;
    color: white !important;
    border-color: #6C22FF !important;
    box-shadow: 0 4px 14px rgba(108, 34, 255, 0.3);
  }
  .cat-btn-inactive {
    background: white;
    color: #6C22FF;
    border-color: rgba(108, 34, 255, 0.3);
  }
  .cat-btn-inactive:hover {
    background: #F5F3FF;
    border-color: #6C22FF;
  }
  .page-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 2px solid rgba(108, 34, 255, 0.25);
    background: white;
    color: #6C22FF;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.18s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .page-btn:hover {
    background: #F5F3FF;
    border-color: #6C22FF;
  }
  .page-btn.active {
    background: #6C22FF;
    color: white;
    border-color: #6C22FF;
    box-shadow: 0 4px 14px rgba(108, 34, 255, 0.3);
  }
  .page-btn.arrow {
    font-size: 1.1rem;
  }
  .page-btn:disabled {
    opacity: 0.3;
    cursor: default;
  }
</style>

<script>
  function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('he-IL', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  const PAGE_SIZE = 12;
  let allPosts: any[] = [];
  let currentPage = 1;
  let activeCatGlobal: string | number = 'all';

  function postCard(post: any) {
    return `
        <article class="post-card" data-categories='${JSON.stringify(post.categories)}'>
          <a href="/מאמרים/${decodeURIComponent(post.slug)}" class="block text-right h-full">
            ${post._embedded?.['wp:featuredmedia']?.[0]?.source_url ? `<img src="${post._embedded['wp:featuredmedia'][0].source_url}" alt="${post.title.rendered}" loading="lazy" style="width:100%;height:180px;object-fit:cover;border-radius:12px 12px 0 0;" />` : ''}
            <div class="p-6">
            <p class="text-xs text-[#6C22FF]/50 font-medium mb-3 tracking-wide">${formatDate(post.date)}</p>
            <h2 class="font-black text-[#12023C] text-lg mb-3 leading-snug" style="font-family: 'Secular One', sans-serif;">${post.title.rendered}</h2>
            <p class="text-gray-400 text-sm leading-relaxed line-clamp-3 mb-5">${post.excerpt.rendered.replace(/<[^>]*>/g, '').substring(0, 120)}...</p>
            <span class="inline-flex items-center gap-1 text-[#6C22FF] font-semibold text-sm card-arrow">
              קרא עוד
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
            </div>
          </a>
        </article>
      `;
  }

  function getFiltered() {
    if (activeCatGlobal === 'new') {
      return [...allPosts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).slice(0, 5);
    }
    return allPosts.filter(p => activeCatGlobal === 'all' || p.categories.includes(Number(activeCatGlobal)));
  }

  function goToPage(page: number) {
    currentPage = page;
    updateGrid();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function updateGrid() {
    const grid = document.getElementById('posts-grid')!;
    const paginationWrap = document.getElementById('pagination-wrap')!;
    const paginationButtons = document.getElementById('pagination-buttons')!;
    const paginationInfo = document.getElementById('pagination-info')!;

    const filtered = getFiltered();
    const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
    const start = (currentPage - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;

    grid.innerHTML = filtered.slice(start, end).map(postCard).join('');
    grid.style.display = 'grid';

    if (totalPages <= 1) {
      paginationWrap.style.display = 'none';
      return;
    }

    paginationWrap.style.display = '';
    paginationInfo.textContent = `עמוד ${currentPage} מתוך ${totalPages}`;

    // Build page buttons
    paginationButtons.innerHTML = '';

    // Arrow right (prev) — RTL so right = prev
    const prevBtn = document.createElement('button');
    prevBtn.className = 'page-btn arrow';
    prevBtn.textContent = '›';
    prevBtn.disabled = currentPage === 1;
    prevBtn.addEventListener('click', () => goToPage(currentPage - 1));
    paginationButtons.appendChild(prevBtn);

    // Page numbers with ellipsis
    const pages = getPagesToShow(currentPage, totalPages);
    pages.forEach(p => {
      if (p === '...') {
        const dots = document.createElement('span');
        dots.textContent = '…';
        dots.className = 'text-gray-400 px-1';
        paginationButtons.appendChild(dots);
      } else {
        const btn = document.createElement('button');
        btn.className = `page-btn${p === currentPage ? ' active' : ''}`;
        btn.textContent = String(p);
        btn.addEventListener('click', () => goToPage(Number(p)));
        paginationButtons.appendChild(btn);
      }
    });

    // Arrow left (next)
    const nextBtn = document.createElement('button');
    nextBtn.className = 'page-btn arrow';
    nextBtn.textContent = '‹';
    nextBtn.disabled = currentPage === totalPages;
    nextBtn.addEventListener('click', () => goToPage(currentPage + 1));
    paginationButtons.appendChild(nextBtn);
  }

  function getPagesToShow(current: number, total: number): (number | string)[] {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
    const pages: (number | string)[] = [];
    pages.push(1);
    if (current > 3) pages.push('...');
    for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
      pages.push(i);
    }
    if (current < total - 2) pages.push('...');
    pages.push(total);
    return pages;
  }

  function renderPosts(activeCat: string | number = 'all') {
    activeCatGlobal = activeCat;
    currentPage = 1;
    updateGrid();
  }

  function buildCategoryFilter(catMap: Record<string, string>) {
    const usedCatIds = new Set<string>();
    allPosts.forEach(p => p.categories.forEach((c: number) => usedCatIds.add(String(c))));

    const cats = Object.entries(catMap).filter(([id]) => usedCatIds.has(id));
    if (cats.length === 0) return;

    const filterSection = document.getElementById('cat-filter')!;
    const buttonsContainer = document.getElementById('cat-buttons')!;
    filterSection.style.display = '';

    // "הכל" button
    const allBtn = document.createElement('button');
    allBtn.textContent = 'הכל';
    allBtn.className = 'px-4 py-1.5 rounded-full border font-semibold text-sm transition-all cat-btn-active';
    allBtn.dataset.cat = 'all';
    allBtn.addEventListener('click', () => setActiveCategory('all', allBtn));
    buttonsContainer.appendChild(allBtn);

    // "חדש" button
    const newBtn = document.createElement('button');
    newBtn.textContent = '✨ חדש';
    newBtn.className = 'px-4 py-1.5 rounded-full border font-semibold text-sm transition-all cat-btn-inactive';
    newBtn.dataset.cat = 'new';
    newBtn.addEventListener('click', () => setActiveCategory('new', newBtn));
    buttonsContainer.appendChild(newBtn);

    cats.forEach(([id, name]) => {
      const btn = document.createElement('button');
      btn.textContent = name;
      btn.className = 'px-4 py-1.5 rounded-full border font-semibold text-sm transition-all cat-btn-inactive';
      btn.dataset.cat = id;
      btn.addEventListener('click', () => setActiveCategory(id, btn));
      buttonsContainer.appendChild(btn);
    });
  }

  function setActiveCategory(catId: string, activeBtn: HTMLElement) {
    document.querySelectorAll('#cat-buttons button').forEach(btn => {
      btn.className = 'px-4 py-1.5 rounded-full border font-semibold text-sm transition-all cat-btn-inactive';
    });
    activeBtn.className = 'px-4 py-1.5 rounded-full border font-semibold text-sm transition-all cat-btn-active';
    renderPosts(catId === 'all' || catId === 'new' ? catId : Number(catId));
  }

  function loadPosts() {
    const loading = document.getElementById('posts-loading')!;
    const posts = JSON.parse(document.getElementById('posts-data')!.textContent || '[]');
    const catMap = JSON.parse(document.getElementById('cat-map-data')!.textContent || '{}');

    loading.style.display = 'none';

    if (posts.length === 0) {
      const errorEl = document.getElementById('posts-error')!;
      errorEl.textContent = 'אין מאמרים להצגה כרגע';
      errorEl.style.display = '';
      return;
    }

    allPosts = posts;
    buildCategoryFilter(catMap);
    renderPosts();
  }

  loadPosts();
</script>
