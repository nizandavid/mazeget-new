---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
  const allPosts = (await import('../../data/posts.json')).default as any[];
  return allPosts.map(post => ({
    params: { slug: decodeURIComponent(post.slug) },
    props: { post },
  }));
}

const { post } = Astro.props;

const featuredImage = post?._embedded?.['wp:featuredmedia']?.[0]?.source_url;
const excerpt = post?.excerpt?.rendered?.replace(/<[^>]*>/g, '').substring(0, 160) ?? '';

const breadcrumbSchema = post ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "דף הבית", "item": "https://mazeget.com" },
    { "@type": "ListItem", "position": 2, "name": "מאמרים", "item": "https://mazeget.com/מאמרים" },
    { "@type": "ListItem", "position": 3, "name": post.title.rendered.replace(/<[^>]*>/g, ''), "item": `https://mazeget.com/מאמרים/${post.slug}` }
  ]
}) : null;

const articleSchema = post ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title.rendered.replace(/<[^>]*>/g, ''),
  "datePublished": post.date,
  "dateModified": post.modified || post.date,
  "author": {
    "@type": "Person",
    "name": "ניצן שמיר",
    "url": "https://mazeget.com/אודותינו"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Mazeget",
    "logo": { "@type": "ImageObject", "url": "https://mazeget.com/og-image.jpg" }
  },
  "image": featuredImage || "https://mazeget.com/og-image.jpg",
  "url": `https://mazeget.com/מאמרים/${post.slug}`,
  "inLanguage": "he",
  "description": excerpt
}) : null;

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('he-IL', { year: 'numeric', month: 'long', day: 'numeric' });
}

function processContent(html: string): string {
  return html
    // URL גולמי של MP4 בתוך <p> → <video>
    .replace(
      /<p>(https?:\/\/[^\s<"]+\.mp4[^<]*)<\/p>/gi,
      '<p><video src="$1" controls style="max-width:100%;border-radius:8px;"></video></p>'
    )
    // URL גולמי של תמונה בתוך <p> → <img>
    .replace(
      /<p>(https?:\/\/[^\s<"]+\.(jpg|jpeg|png|gif|webp)[^<]*)<\/p>/gi,
      '<p><img src="$1" style="max-width:100%;border-radius:8px;"></p>'
    );
}
---

<Layout
  title={post ? post.title.rendered + ' — Mazeget' : 'מאמר — Mazeget'}
  description={excerpt || undefined}
  ogImage={featuredImage || undefined}
  pageUrl={post?.link}
>
  {articleSchema && <script type="application/ld+json" is:inline set:html={articleSchema} slot="head" />}
  {breadcrumbSchema && <script type="application/ld+json" is:inline set:html={breadcrumbSchema} slot="head" />}
  <Header />

  {!post ? (
    <div class="py-40 text-center">
      <p class="text-gray-400 text-xl">המאמר לא נמצא</p>
      <a href="/מאמרים" class="text-[#6C22FF] mt-4 inline-block hover:underline">חזרה למאמרים</a>
    </div>
  ) : (
    <>
      <!-- Hero -->
      <section class="py-20 px-6 text-center" style="background: linear-gradient(135deg, #12023C 0%, #6C22FF 100%);">
        <p class="text-white/60 text-sm mb-4">{formatDate(post.date)}</p>
        <h1 class="text-4xl md:text-5xl text-white font-black max-w-3xl mx-auto leading-tight"
          style="font-family: 'Secular One', sans-serif;"
          set:html={post.title.rendered} />
      </section>

      <!-- Featured Image -->
      {post._embedded?.['wp:featuredmedia']?.[0]?.source_url && (
        <div class="max-w-2xl mx-auto px-6 pt-10">
          <img
            src={post._embedded['wp:featuredmedia'][0].source_url}
            alt={post._embedded['wp:featuredmedia'][0].alt_text || post.title.rendered}
            class="w-full rounded-2xl"
            style="max-height:400px;object-fit:cover;"
          />
        </div>
      )}

      <!-- Content -->
      <article class="py-16 px-6">
        <div class="max-w-2xl mx-auto text-right">
          <div dir="rtl" class="prose prose-lg prose-headings:font-black prose-headings:text-[#12023C] prose-p:text-gray-600 prose-p:leading-relaxed max-w-none"
            set:html={processContent(post.content.rendered)} />

          <!-- Back Link -->
          <div class="mt-16 pt-8 border-t border-gray-100">
            <a href="/מאמרים" class="text-[#6C22FF] font-medium hover:underline">
              ← חזרה לכל המאמרים
            </a>
          </div>
        </div>
      </article>

      <!-- CTA -->
      <section class="py-16 px-6 text-center bg-[#F8F7FF]">
        <h2 class="text-2xl font-black text-[#12023C] mb-4" style="font-family: 'Secular One', sans-serif;">
          מעוניינים במצגת לאירוע שלכם?
        </h2>
        <a href="/#contact"
          class="inline-block bg-[#6C22FF] text-white font-bold text-lg px-10 py-4 rounded-full hover:bg-[#5a1dd6] transition-colors">
          צרו קשר עכשיו
        </a>
      </section>
    </>
  )}
</Layout>
