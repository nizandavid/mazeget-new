---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import { getVideoPages } from '../../lib/sheets';

export async function getStaticPaths() {
  let pages: Awaited<ReturnType<typeof getVideoPages>> = [];
  try {
    pages = await getVideoPages();
  } catch {
    // אם הגיליון לא קיים עדיין, בונים בלי עמודי מצגות
  }
  return pages.map(p => ({
    params: { slug: p.slug },
    props:  { page: p },
  }));
}

const { page } = Astro.props;

const sections = [
  { title: 'על המצגת',                                       text: page.section1 },
  { title: 'מה מיוחד במצגת הזאת',                           text: page.section2 },
  { title: `רעיונות למצגת ${page.category_label}`,          text: page.section3 },
].filter(s => s.text);

const details = [
  { label: 'סוג האירוע',    value: page.detail_event },
  { label: 'נושא',          value: page.detail_style },
  { label: 'ענף',           value: page.branch },
  { label: 'פתיח',          value: page.detail_elements },
  { label: 'סדר המצגת',     value: page.detail_duration },
  { label: 'סגנון ומוסיקה', value: page.detail_music },
].filter(d => d.value);

const FAQ_MAP: Record<string, { q: string; a: string }[]> = {
  bar_mitzva: [
    { q: 'כמה זמן נמשכת מצגת בר מצווה?', a: 'בדרך כלל 3–7 דקות, תלוי בכמות החומרים שתספקו והסגנון שתבחרו.' },
    { q: 'איזה חומרים צריך לספק?', a: 'תמונות מהילדות, קטעי וידאו, ושיר אחד-שניים שאהובים עליכם — ואנחנו מסדרים את השאר.' },
    { q: 'האם אפשר להוסיף אפקטים מיוחדים?', a: 'בוודאי! ניתן להוסיף אנימציות, אפקטי AI, כתוביות ועוד — הכל לפי הסגנון שתרצו.' },
    { q: 'כמה זמן לוקח הייצור?', a: 'בדרך כלל 5–10 ימי עבודה לאחר קבלת כל החומרים.' },
  ],
  bat_mitzva: [
    { q: 'כמה זמן נמשכת מצגת בת מצווה?', a: 'בממוצע 3–7 דקות, תלוי בכמות הצילומים והסגנון.' },
    { q: 'איזה חומרים צריך למצגת בת מצווה?', a: 'תמונות מהילדות, סרטונים אהובים ושיר שמייצג אותה — ואנחנו מסדרים את הכל.' },
    { q: 'האם אפשר להוסיף אפקטים מיוחדים?', a: 'כן! אפקטי AI, אנימציות ומעברים קינמטיים — הכל לפי מה שתרצו.' },
    { q: 'כמה זמן לוקח הייצור?', a: 'בדרך כלל 5–10 ימי עבודה לאחר קבלת כל החומרים.' },
  ],
  birthday: [
    { q: 'לאיזה גיל מתאימה מצגת וידאו?', a: 'לכל גיל! מ-1 ועד 100+ — כל יום הולדת ראוי לסרטון שישמר לנצח.' },
    { q: 'כמה זמן לוקחת ההכנה?', a: 'בדרך כלל 3–5 ימי עבודה לאחר קבלת כל החומרים.' },
    { q: 'איזה מוסיקה ניתן לבחור?', a: 'כל שיר שתרצו — מתוך מבחר גדול אצלנו, או שיר שתבחרו בעצמכם.' },
    { q: 'האם צריך תמונות מקצועיות?', a: 'לא! גם תמונות מהטלפון עובדות מצוין. אנחנו נטפל בכל העריכה.' },
  ],
  wedding: [
    { q: 'מתי כדאי להזמין מצגת חתונה?', a: 'מומלץ 3–6 שבועות לפני האירוע, כדי שיהיה זמן לתיקונים ושידרוגים.' },
    { q: 'האם צריך לספק תמונות מוגמרות?', a: 'לא חייב — ניתן לספק גם תמונות גולמיות ואנו מטפלים בכל העריכה.' },
    { q: 'האם אפשר לקבל עותק לשיתוף?', a: 'כן! הסרטון המוגמר מועלה לאינטרנט ומוכן לשיתוף מיידי עם כל המשפחה.' },
    { q: 'כמה תמונות צריך לספק?', a: 'ככל שיותר — כך יותר טוב, אבל עובדים מצוין גם עם 50–80 תמונות.' },
  ],
  trip: [
    { q: 'איזה חומרים צריך לסרטון טיול?', a: 'תמונות וסרטונים מהמסע, פרטים על היעדים, ושיר שמתאים לאווירה.' },
    { q: 'האם ניתן לשלב קטעי וידאו?', a: 'בוודאי! ניתן לשלב צילומי וידאו יחד עם תמונות לתוצאה מדהימה.' },
    { q: 'כמה זמן נמשך הסרטון?', a: 'בדרך כלל 4–8 דקות, תלוי בכמות החומרים שתספקו.' },
    { q: 'האם ניתן להוסיף כיתובים ושמות יעדים?', a: 'כן! נוסיף כיתובים, תאריכים ושמות מקומות לפי בחירתכם.' },
  ],
  other: [
    { q: 'לאיזה אירועים מתאימה מצגת וידאו?', a: 'לכל אירוע! פרישה לגמלאות, יובל, כנס חברה, השקת מוצר ועוד.' },
    { q: 'האם ניתן להכין מצגת לאירוע עסקי?', a: 'כן, אנו מכינים מצגות לאירועי חברה, השקות מוצר וכנסים מקצועיים.' },
    { q: 'כמה זמן נמשכת ההכנה?', a: 'תלוי בסוג ומורכבות המצגת, בדרך כלל 5–10 ימי עבודה.' },
    { q: 'האם ניתן לקבל גרסאות שונות?', a: 'כן, ניתן להזמין מספר גרסאות — קצרה לרשתות חברתיות וארוכה לאירוע עצמו.' },
  ],
};

const faqs = FAQ_MAP[page.category_key] ?? FAQ_MAP['other'];
---

<Layout
  title={`${page.title} | Mazeget`}
  description={page.description || `${page.section1?.slice(0, 150) || `מצגת וידאו ל${page.category_label} — מקצועית ומרגשת`}.`}
>
  <Header />

  <!-- 1. כותרת + Breadcrumb -->
  <section style="background:linear-gradient(145deg,#1e0a4a 0%,#4c1d95 55%,#7c3aed 100%); padding:3.5rem 6% 3rem; position:relative; overflow:hidden; text-align:center;">
    <div style="position:absolute;width:500px;height:500px;border-radius:50%;background:#6d28d9;top:-200px;right:-100px;opacity:.25;filter:blur(60px);"></div>
    <div style="position:absolute;width:350px;height:350px;border-radius:50%;background:#EC4899;bottom:-100px;left:-80px;opacity:.2;filter:blur(60px);"></div>
    <div style="max-width:900px; margin:0 auto; position:relative; z-index:1;">

      <!-- Breadcrumb -->
      <nav style="display:flex; justify-content:center; align-items:center; gap:.5rem; font-size:.8rem; color:rgba(255,255,255,.55); margin-bottom:1.5rem; flex-wrap:wrap;">
        <a href="/" style="color:rgba(255,255,255,.55); text-decoration:none;">בית</a>
        <span>›</span>
        <a href={`/מצגות/${page.category_key}`} style="color:rgba(255,255,255,.55); text-decoration:none;">{page.category_he}</a>
        <span>›</span>
        <span style="color:white;">{page.title}</span>
      </nav>

      <!-- Badge -->
      <div style="display:inline-flex; align-items:center; gap:.5rem; background:rgba(255,255,255,.15); border-radius:50px; padding:.35rem 1rem; font-size:.78rem; font-weight:700; color:white; margin-bottom:1rem;">
        {page.category_label}
      </div>

      <!-- כותרת -->
      <h1 style="font-size:clamp(2rem,4vw,3rem); font-weight:900; color:white; margin:0; font-family:'Secular One',sans-serif; line-height:1.2;">
        {page.title}
      </h1>

      {page.description && (
        <p style="margin:1.2rem auto 0; max-width:600px; font-size:1.05rem; color:rgba(255,255,255,.8); line-height:1.7;">
          {page.description}
        </p>
      )}

    </div>
  </section>

  <!-- 2. וידאו -->
  <section style="background:#F8F7FF; padding:3rem 6%;">
    <div style="max-width:860px; margin:0 auto;">
      <div style="border-radius:20px; overflow:hidden; box-shadow:0 16px 48px rgba(0,0,0,.18); aspect-ratio:16/9;">
        <iframe
          src={`https://player.vimeo.com/video/${page.vimeo_id}?color=7C3AED&title=0&byline=0&portrait=0`}
          style="width:100%; height:100%; display:block;"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- 3. תוכן + סיידבר -->
  <section style="padding:0 6% 4rem; background:#F8F7FF;">
    <div style="max-width:900px; margin:0 auto; display:grid; grid-template-columns:1fr 280px; gap:2.5rem; align-items:start;">

      <!-- תיאור עם כותרות -->
      <div style="text-align:right;">
        {sections.map(s => (
          <div style="margin-bottom:2rem;">
            <h2 style="font-size:1.2rem; font-weight:900; color:#12023C; margin-bottom:.7rem; font-family:'Secular One',sans-serif; border-bottom:2px solid #EDE9FE; padding-bottom:.5rem;">
              {s.title}
            </h2>
            <p style="color:#4b5563; line-height:1.9; font-size:.95rem; margin:0;">{s.text}</p>
          </div>
        ))}
      </div>

      <!-- סיידבר -->
      <div style="position:sticky; top:90px;">

        <!-- פרטי מצגת -->
        {details.length > 0 && (
          <div style="background:white; border-radius:16px; padding:1.4rem; border:1px solid #ede9fe; margin-bottom:1rem;">
            <h3 style="font-size:.95rem; font-weight:900; color:#12023C; margin-bottom:1rem; text-align:right;">פרטי המצגת</h3>
            <div style="display:flex; flex-direction:column; gap:.55rem;">
              {details.map(d => (
                <p style="font-size:.85rem; color:#374151; margin:0; text-align:right; line-height:1.5;">
                  <span style="color:#6b7280;">{d.label}:</span> <strong style="color:#12023C;">{d.value}</strong>
                </p>
              ))}
            </div>
          </div>
        )}

        <!-- CTA -->
        <div style="background:white; border-radius:16px; padding:1.4rem; border:1px solid #ede9fe; text-align:center;">
          <p style="font-size:.82rem; color:#6b7280; margin-bottom:1rem; line-height:1.6;">גם ה{page.category_label} שלכם מגיע למצגת כזו</p>
          <a href="/#contact" style="display:block; background:linear-gradient(135deg,#7C3AED,#4c1d95); color:white; padding:.85rem 1.5rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none; margin-bottom:.7rem;">
            הזמינו מצגת כזו ←
          </a>
          <a href="/מחירון" style="display:block; border:1.5px solid #7C3AED; color:#7C3AED; padding:.65rem 1.5rem; border-radius:50px; font-weight:600; font-size:.83rem; text-decoration:none;">
            לצפייה במחירון
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. מצגות נוספות -->
  {page.related.length > 0 && (
    <section style="padding:4rem 6%; background:white;">
      <div style="max-width:900px; margin:0 auto;">
        <h2 style="font-size:1.5rem; font-weight:900; color:#12023C; margin-bottom:2rem; font-family:'Secular One',sans-serif; text-align:right;">
          מצגות {page.category_label} נוספות
        </h2>
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;">
          {page.related.map((v, i) => (
            <div style="border-radius:16px; overflow:hidden; background:#F8F7FF; box-shadow:0 4px 16px rgba(0,0,0,.06); cursor:pointer;" class="related-card" data-video-id={v.id}>
              <div style="aspect-ratio:16/9; position:relative; background:#1a0533; overflow:hidden;">
                <img src={`https://vumbnail.com/${v.id}.jpg`} alt={v.title} style="width:100%; height:100%; object-fit:cover; display:block;" loading="lazy" />
                <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
                  <div style="width:52px; height:52px; border-radius:50%; background:rgba(255,255,255,.9); display:flex; align-items:center; justify-content:center; box-shadow:0 4px 16px rgba(0,0,0,.25);">
                    <svg width="18" height="18" fill="#7C3AED" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>
              <div style="padding:.9rem 1rem; text-align:right;">
                <div style="display:inline-block; background:#EDE9FE; color:#7C3AED; font-size:.65rem; font-weight:700; padding:.15rem .6rem; border-radius:50px; margin-bottom:.4rem;">{page.category_label}</div>
                <h3 style="font-size:.88rem; font-weight:800; color:#12023C; margin:0;">{v.title}</h3>
              </div>
            </div>
          ))}
        </div>
        <div style="text-align:center; margin-top:2rem;">
          <a href={`/מצגות/${page.category_key}`} style="display:inline-flex; align-items:center; gap:.5rem; border:2px solid #7C3AED; color:#7C3AED; padding:.7rem 2rem; border-radius:50px; font-weight:700; font-size:.88rem; text-decoration:none;">
            לכל מצגות {page.category_label} ←
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- 5. כפתורי CTA + FAQ -->
  <section style="padding:3rem 6% 4rem; background:#F8F7FF;">
    <div style="max-width:900px; margin:0 auto;">

      <!-- כפתורי ניווט -->
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-bottom:3.5rem;">
        <a href={`/מצגות/${page.category_key}`} style="display:inline-flex; align-items:center; gap:.5rem; background:white; border:2px solid #7C3AED; color:#7C3AED; padding:.75rem 1.8rem; border-radius:50px; font-weight:700; font-size:.9rem; text-decoration:none;">
          עוד מצגות {page.category_label} ←
        </a>
        <a href="/#contact" style="display:inline-flex; align-items:center; gap:.5rem; background:linear-gradient(135deg,#7C3AED,#4c1d95); color:white; padding:.75rem 1.8rem; border-radius:50px; font-weight:700; font-size:.9rem; text-decoration:none;">
          רוצים מצגת כזו? דברו איתי ←
        </a>
      </div>

      <!-- שאלות נפוצות -->
      <h2 style="font-size:1.5rem; font-weight:900; color:#12023C; margin-bottom:1.5rem; font-family:'Secular One',sans-serif; text-align:right;">
        שאלות נפוצות על מצגות {page.category_label}
      </h2>
      <div class="faq-list">
        {faqs.map((item, i) => (
          <div class="faq-item" data-index={i}>
            <button class="faq-q" aria-expanded="false">
              <span>{item.q}</span>
              <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="faq-a">
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <Contact />

</Layout>

<div id="video-lightbox" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.9); z-index:600; align-items:center; justify-content:center; padding:1rem;">
  <button id="lightbox-close" style="position:absolute; top:1.2rem; left:1.2rem; background:rgba(255,255,255,.15); border:none; color:white; width:46px; height:46px; border-radius:50%; font-size:1.8rem; cursor:pointer; display:flex; align-items:center; justify-content:center;">×</button>
  <div id="lightbox-content" style="width:min(900px,95vw); aspect-ratio:16/9; border-radius:12px; overflow:hidden; background:#000;"></div>
</div>

<script>
  document.querySelectorAll('.related-card').forEach(card => {
    card.addEventListener('mouseenter', () => { (card as HTMLElement).style.transform = 'translateY(-4px)'; (card as HTMLElement).style.boxShadow = '0 12px 32px rgba(0,0,0,.12)'; });
    card.addEventListener('mouseleave', () => { (card as HTMLElement).style.transform = ''; (card as HTMLElement).style.boxShadow = ''; });
    card.addEventListener('click', () => {
      const id = (card as HTMLElement).dataset.videoId;
      const content = document.getElementById('lightbox-content');
      const lb = document.getElementById('video-lightbox');
      if (!content || !lb || !id) return;
      content.innerHTML = `<iframe src="https://player.vimeo.com/video/${id}?autoplay=1&color=7C3AED" width="100%" height="100%" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>`;
      lb.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    });
  });
  function closeLightbox() {
    const lb = document.getElementById('video-lightbox');
    const content = document.getElementById('lightbox-content');
    if (lb) lb.style.display = 'none';
    if (content) content.innerHTML = '';
    document.body.style.overflow = '';
  }
  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('video-lightbox')?.addEventListener('click', e => { if (e.target === document.getElementById('video-lightbox')) closeLightbox(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

  // FAQ accordion
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });
</script>

<style>
  .related-card { transition: transform .2s, box-shadow .2s; }

  /* FAQ */
  .faq-list { display: flex; flex-direction: column; gap: .6rem; }
  .faq-item { background: white; border-radius: 14px; border: 1px solid #ede9fe; overflow: hidden; }
  .faq-q {
    width: 100%; display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; padding: 1.1rem 1.3rem; background: none; border: none; cursor: pointer;
    font-size: .97rem; font-weight: 700; color: #12023C; text-align: right; direction: rtl;
  }
  .faq-q:hover { background: #faf8ff; }
  .faq-icon { flex-shrink: 0; transition: transform .25s; }
  .faq-item.open .faq-icon { transform: rotate(180deg); }
  .faq-a { max-height: 0; overflow: hidden; transition: max-height .3s ease, padding .3s; }
  .faq-item.open .faq-a { max-height: 200px; }
  .faq-a p { margin: 0; padding: .2rem 1.3rem 1.1rem; font-size: .9rem; color: #4b5563; line-height: 1.75; text-align: right; direction: rtl; }

  @media (max-width: 768px) {
    div[style*="grid-template-columns:1fr 280px"] { grid-template-columns: 1fr !important; }
    div[style*="position:sticky"] { position: static !important; }
    div[style*="grid-template-columns:repeat(3,1fr)"] { grid-template-columns: 1fr !important; }
  }
</style>
