---
const response = await fetch('http://mazeget-local.local/wp-json/wp/v2/presentations');
const presentations = await response.json();
---

<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <title>בדיקת מצגות</title>
    <style>
      body { font-family: sans-serif; padding: 2rem; background: #F8F7FF; }
      .card { background: white; padding: 1rem; margin: 1rem 0; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    </style>
  </head>
  <body>
    <h1>מצגות מוורדפרס</h1>
    {presentations.map((p: any) => (
      <div class="card">
        <h2>{p.title.rendered}</h2>
        <p><strong>קטגוריה:</strong> {p.acf_fields?.category}</p>
        <p><strong>קישור וימאו:</strong> {p.acf_fields?.vimeo_url || 'לא הוזן'}</p>
      </div>
    ))}
  </body>
</html>
