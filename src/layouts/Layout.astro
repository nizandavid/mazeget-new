---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  pageUrl?: string;
  ogImage?: string;
}

const {
  title = 'Mazeget — מצגות לאירועים משפחתיים',
  description = 'Mazeget מתמחה במצגות וידאו מרגשות לאירועים משפחתיים — בר מצווה, בת מצווה, ימי הולדת וחתונות.',
  pageUrl,
  ogImage = 'https://mazeget.com/og-image.jpg'
} = Astro.props;

const canonicalUrl = `https://mazeget.com${Astro.url.pathname}`;

let rankMathHead = '';
if (pageUrl) {
  try {
    const res = await fetch(`https://wp.mazeget.com/wp-json/rankmath/v1/getHead?url=${encodeURIComponent(pageUrl)}`);
    const data = await res.json();
    if (data.success) rankMathHead = data.head;
  } catch (e) {
    // אם ה-API לא זמין — ממשיכים בלי SEO
  }
}
---

<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    {!rankMathHead && <meta name="description" content={description} />}
    {!rankMathHead && <meta property="og:title" content={title} />}
    {!rankMathHead && <meta property="og:description" content={description} />}
    {!rankMathHead && <meta property="og:type" content="website" />}
    {!rankMathHead && <meta property="og:url" content={canonicalUrl} />}
    {!rankMathHead && <meta property="og:image" content={ogImage} />}
    {!rankMathHead && <meta property="og:locale" content="he_IL" />}
    {!rankMathHead && <meta property="og:site_name" content="Mazeget" />}
    {rankMathHead && <Fragment set:html={rankMathHead} />}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Mazeget — מצגות וידאו לאירועים",
      "alternateName": "ניצן שמיר מצגות",
      "url": "https://mazeget.com",
      "logo": "https://mazeget.com/og-image.jpg",
      "image": "https://mazeget.com/og-image.jpg",
      "description": "מצגות וידאו מרגשות לאירועים משפחתיים — בר מצווה, בת מצווה, ימי הולדת וחתונות. עריכה מקצועית, מוזיקה, AI ואפקטים.",
      "telephone": "+972526780531",
      "email": "nizan.shamir@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "רחוב הנדיב 3",
        "addressLocality": "הרצליה",
        "addressRegion": "מרכז",
        "addressCountry": "IL"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 32.1676,
        "longitude": 34.8378
      },
      "areaServed": {"@type": "Country", "name": "Israel"},
      "priceRange": "₪₪",
      "currenciesAccepted": "ILS",
      "inLanguage": "he",
      "openingHours": "Mo-Su 09:00-22:00",
      "sameAs": ["https://wa.me/972526780531"],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "מצגות וידאו לאירועים",
        "itemListElement": [
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "מצגת לבר מצווה"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "מצגת לבת מצווה"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "מצגת ליום הולדת"}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "מצגת לחתונה"}}
        ]
      }
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800;900&family=Secular+One&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Animated mesh background -->
    <div class="mesh-bg">
      <div class="mesh-orb mesh-orb-1"></div>
      <div class="mesh-orb mesh-orb-2"></div>
      <div class="mesh-orb mesh-orb-3"></div>
      <div class="mesh-orb mesh-orb-4"></div>
    </div>

    <div style="position:relative; z-index:1;">
      <slot />
    </div>

    <Footer />

    <!-- WhatsApp floating button -->
    <a href="https://wa.me/972526780531" target="_blank"
      style="position:fixed; bottom:1.8rem; left:1.8rem; z-index:300; width:56px; height:56px; border-radius:50%; background:#25D366; display:flex; align-items:center; justify-content:center; box-shadow:0 6px 24px rgba(37,211,102,.4); text-decoration:none; transition:transform .2s;">
      <svg width="28" height="28" fill="white" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <script>
      // Scroll reveal
      const io = new IntersectionObserver(entries => {
        entries.forEach((e, i) => {
          if (e.isIntersecting) {
            setTimeout(() => e.target.classList.add('in'), i * 70);
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));

      // Nav shadow on scroll
      const nav = document.getElementById('main-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          nav.classList.toggle('scrolled', window.scrollY > 40);
        });
      }
    </script>
  </body>
</html>
