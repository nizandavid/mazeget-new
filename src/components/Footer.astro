---
import { categories } from '../data/categories';
---

<footer style="position:relative; z-index:1; background:#1e0a4a;">

  <!-- Main footer content -->
  <div style="max-width:1280px; margin:0 auto; padding:3.5rem 6% 2rem; display:grid; grid-template-columns:2fr 1fr 1fr; gap:3rem; text-align:right;" class="footer-grid">

    <!-- Brand -->
    <div>
      <div style="margin-bottom:1rem;">
        <a href="/"><img src="/logo-matzget.png" alt="מצגת – זה כל הסיפור" style="height:60px; width:auto; display:block; filter:brightness(0) invert(1);" /></a>
      </div>
      <p style="font-size:.85rem; color:rgba(255,255,255,.6); line-height:1.7; max-width:300px;">
        מצגות וידאו מקצועיות לאירועים משפחתיים — בר מצווה, בת מצווה, ימי הולדת וחתונות. עריכה מושקעת עם טכנולוגיית AI.
      </p>
    </div>

    <!-- Categories -->
    <div>
      <h4 style="font-size:.78rem; font-weight:700; color:rgba(255,255,255,.45); letter-spacing:1.5px; text-transform:uppercase; margin-bottom:1rem;">מצגות</h4>
      <ul style="list-style:none; display:flex; flex-direction:column; gap:.6rem;">
        {categories.filter(cat => !cat.hideFromNav).map(cat => (
          <li>
            <a href={`/מצגות/${cat.key}`} style="color:rgba(255,255,255,.7); text-decoration:none; font-size:.85rem; transition:color .2s;" onmouseover="this.style.color='#C4B5FD'" onmouseout="this.style.color='rgba(255,255,255,.7)'">
              {cat.emoji} {cat.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Links -->
    <div>
      <h4 style="font-size:.78rem; font-weight:700; color:rgba(255,255,255,.45); letter-spacing:1.5px; text-transform:uppercase; margin-bottom:1rem;">ניווט</h4>
      <ul style="list-style:none; display:flex; flex-direction:column; gap:.6rem;">
        {[
          { label:'מחירון', href:'/מחירון' },
          { label:'מאמרים', href:'/מאמרים' },
          { label:'העלאת קבצים', href:'/העלאת-קבצים' },
          { label:'אודותינו', href:'/אודותינו' },
        ].map(link => (
          <li>
            <a href={link.href} style="color:rgba(255,255,255,.7); text-decoration:none; font-size:.85rem;" onmouseover="this.style.color='#C4B5FD'" onmouseout="this.style.color='rgba(255,255,255,.7)'">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div style="max-width:1280px; margin:0 auto; padding:1.2rem 6%; border-top:1px solid rgba(255,255,255,.1); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
    <span style="font-size:.78rem; color:rgba(255,255,255,.45);">© {new Date().getFullYear()} Mazeget · כל הזכויות שמורות</span>
    <a href="https://wa.me/972526780531" target="_blank"
      style="display:inline-flex; align-items:center; gap:.5rem; background:#25D366; color:white; padding:.45rem 1.1rem; border-radius:50px; font-size:.82rem; font-weight:600; text-decoration:none;">
      <svg width="16" height="16" fill="white" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      וואטסאפ
    </a>
  </div>

</footer>

<style>
  @media(max-width:768px){
    .footer-grid { grid-template-columns:1fr !important; }
  }
</style>
