---
import { categories } from '../data/categories';
---

<footer class="bg-[#12023C] text-white pt-16 pb-8 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12 text-right">

      <!-- Logo & Tagline -->
      <div class="md:col-span-2">
        <img src="/logo.png" alt="Mazeget" class="h-14 object-contain mb-4" />
        <p class="text-white/60 text-lg mb-2">מצגת – זה כל הסיפור</p>
        <p class="text-white/40 text-sm leading-relaxed">
          מצגות וידאו מקצועיות לאירועים משפחתיים — בר מצווה, בת מצווה, ימי הולדת וחתונות.
          עריכה מושקעת עם טכנולוגיית AI מתקדמת.
        </p>
      </div>

      <!-- קטגוריות -->
      <div>
        <h3 class="font-black text-white mb-4">מצגות</h3>
        <ul class="flex flex-col gap-2">
          {categories.map(cat => (
            <li>
              <a href={`/מצגות/${cat.key}`}
                class="text-white/60 hover:text-[#E879F9] transition-colors text-sm">
                {cat.emoji} {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- קישורים וקשר -->
      <div>
        <h3 class="font-black text-white mb-4">פרטים</h3>
        <ul class="flex flex-col gap-2 mb-6">
          <li><a href="/מחירון" class="text-white/60 hover:text-[#E879F9] transition-colors text-sm">מחירון</a></li>
          <li><a href="/מאמרים" class="text-white/60 hover:text-[#E879F9] transition-colors text-sm">מאמרים</a></li>
          <li><a href="/העלאת-קבצים" class="text-white/60 hover:text-[#E879F9] transition-colors text-sm">העלאת קבצים</a></li>
          <li><a href="/אודותינו" class="text-white/60 hover:text-[#E879F9] transition-colors text-sm">אודותינו</a></li>
        </ul>
        <div class="flex flex-col gap-2 text-sm">
          <a href="tel:074-764-86-37" class="text-white/60 hover:text-white transition-colors">
            📞 074-764-86-37
          </a>
          <a href="mailto:nizan.shamir@gmail.com" class="text-white/60 hover:text-white transition-colors">
            ✉️ nizan.shamir@gmail.com
          </a>
          <p class="text-white/40">📍 רחוב הנדיב 3, הרצליה</p>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 pt-8 flex flex-wrap justify-between items-center gap-4 text-sm text-white/40">
      <p>© {new Date().getFullYear()} ניצן-שמיר מצגות | Mazeget. כל הזכויות שמורות.</p>
      <a href="https://wa.me/972500000000" target="_blank"
        class="flex items-center gap-2 bg-[#25D366] text-white px-4 py-2 rounded-full hover:bg-[#1ebe5d] transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        וואטסאפ
      </a>
    </div>

  </div>
</footer>
