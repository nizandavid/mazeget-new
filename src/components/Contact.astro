---
import { categories } from '../data/categories';
---

<section id="contact" style="padding:3.5rem 6%; position:relative; background:linear-gradient(135deg,#6d28d9 0%,#4c1d95 100%); overflow:hidden;">
  <div class="section-orb" style="width:420px;height:420px;background:#e879f9;top:-80px;left:-80px;animation-delay:-5s;"></div>
  <div class="section-orb" style="width:280px;height:280px;background:#818cf8;bottom:-60px;right:5%;animation-delay:-15s;"></div>
  <div style="max-width:1100px; margin:0 auto; position:relative; z-index:1;">

    <div style="text-align:center; margin-bottom:2.5rem;" class="reveal">
      <div style="display:inline-block; background:rgba(255,255,255,0.15); color:#1e1b4b; font-size:.68rem; font-weight:700; letter-spacing:2.5px; text-transform:uppercase; padding:.3rem .9rem; border-radius:50px; margin-bottom:.75rem;">צרו קשר</div>
      <h2 style="font-size:clamp(1.7rem,3vw,2.6rem); font-weight:900; color:#1e1b4b; margin:0;">בואו <em class="shimmer-text" style="font-style:normal;">נדבר</em></h2>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1.3fr; gap:3rem; align-items:start;" class="contact-grid">

      <!-- Left: info -->
      <div class="reveal">
        <h3 style="font-size:1.55rem; font-weight:900; line-height:1.25; margin-bottom:.85rem; color:#1e1b4b;">מוכנים להפוך את האירוע שלכם לבלתי נשכח?</h3>
        <p style="color:rgba(255,255,255,0.72); line-height:1.75; margin-bottom:1.75rem; font-size:.92rem;">שלחו פרטים ונחזור אליכם תוך שעות ספורות עם הצעה מותאמת אישית.</p>

        <div style="display:flex; flex-direction:column; gap:.75rem; margin-bottom:1.75rem;">
          <div style="display:flex; align-items:center; gap:.9rem;">
            <div style="width:40px; height:40px; border-radius:12px; background:rgba(255,255,255,0.13); display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0;">📍</div>
            <span style="font-size:.88rem; color:rgba(255,255,255,0.82);">רחוב הנדיב 3, הרצליה</span>
          </div>
          <div style="display:flex; align-items:center; gap:.9rem;">
            <div style="width:40px; height:40px; border-radius:12px; background:rgba(255,255,255,0.13); display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0;">📞</div>
            <a href="tel:052-6780531" style="font-size:.88rem; color:rgba(255,255,255,0.82); text-decoration:none;">052-6780531</a>
          </div>
          <div style="display:flex; align-items:center; gap:.9rem;">
            <div style="width:40px; height:40px; border-radius:12px; background:rgba(255,255,255,0.13); display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0;">✉️</div>
            <a href="mailto:nizan.shamir@gmail.com" style="font-size:.88rem; color:rgba(255,255,255,0.82); text-decoration:none;">nizan.shamir@gmail.com</a>
          </div>
        </div>

        <a href="https://wa.me/972526780531" target="_blank" rel="noopener"
          style="display:inline-flex; align-items:center; gap:.6rem; color:rgba(255,255,255,0.75); text-decoration:none; font-size:.82rem; transition:color .2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.75)'">
          <span style="width:30px; height:30px; border-radius:50%; background:#25D366; display:flex; align-items:center; justify-content:center; flex-shrink:0; box-shadow:0 2px 8px rgba(37,211,102,.35);">
            <svg width="16" height="16" fill="white" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </span>
          דברו עם דליה בוואטסאפ
        </a>
      </div>

      <!-- Right: form -->
      <div style="background:rgba(255,255,255,0.55); border:1px solid rgba(255,255,255,0.4); border-radius:20px; padding:2rem; backdrop-filter:blur(14px);" class="reveal">
        <form style="display:flex; flex-direction:column; gap:.85rem; text-align:right;">
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:.85rem;">
            <div>
              <label style="display:block; font-size:.68rem; font-weight:700; color:#7c3aed; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:.4rem;">שם</label>
              <input type="text" placeholder="השם שלכם" style="width:100%; background:rgba(196,181,253,0.35); border:1.5px solid rgba(167,139,250,0.5); border-radius:11px; padding:.72rem .95rem; color:#1e1b4b; font-family:'Heebo',sans-serif; font-size:.88rem; outline:none; transition:border-color .2s; box-sizing:border-box;" onfocus="this.style.borderColor='#a78bfa'" onblur="this.style.borderColor='rgba(196,181,253,0.4)'" />
            </div>
            <div>
              <label style="display:block; font-size:.68rem; font-weight:700; color:#7c3aed; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:.4rem;">טלפון</label>
              <input type="tel" placeholder="050-000-0000" style="width:100%; background:rgba(196,181,253,0.35); border:1.5px solid rgba(167,139,250,0.5); border-radius:11px; padding:.72rem .95rem; color:#1e1b4b; font-family:'Heebo',sans-serif; font-size:.88rem; outline:none; transition:border-color .2s; box-sizing:border-box;" onfocus="this.style.borderColor='#a78bfa'" onblur="this.style.borderColor='rgba(196,181,253,0.4)'" />
            </div>
          </div>
          <div>
            <label style="display:block; font-size:.68rem; font-weight:700; color:#7c3aed; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:.4rem;">אימייל</label>
            <input type="email" placeholder="your@email.com" style="width:100%; background:rgba(196,181,253,0.35); border:1.5px solid rgba(167,139,250,0.5); border-radius:11px; padding:.72rem .95rem; color:#1e1b4b; font-family:'Heebo',sans-serif; font-size:.88rem; outline:none; transition:border-color .2s; box-sizing:border-box;" onfocus="this.style.borderColor='#a78bfa'" onblur="this.style.borderColor='rgba(196,181,253,0.4)'" />
          </div>
          <div>
            <label style="display:block; font-size:.68rem; font-weight:700; color:#7c3aed; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:.4rem;">סוג האירוע</label>
            <select style="width:100%; background:rgba(196,181,253,0.35); border:1.5px solid rgba(167,139,250,0.5); border-radius:11px; padding:.72rem .95rem; color:#1e1b4b; font-family:'Heebo',sans-serif; font-size:.88rem; outline:none; appearance:none; cursor:pointer; box-sizing:border-box;">
              <option value="">בחרו...</option>
              {categories.map(c => <option value={c.key}>{c.label}</option>)}
            </select>
          </div>
          <div>
            <label style="display:block; font-size:.68rem; font-weight:700; color:#7c3aed; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:.4rem;">הערות</label>
            <textarea placeholder="ספרו לנו על האירוע..." rows="3" style="width:100%; background:rgba(196,181,253,0.35); border:1.5px solid rgba(167,139,250,0.5); border-radius:11px; padding:.72rem .95rem; color:#1e1b4b; font-family:'Heebo',sans-serif; font-size:.88rem; outline:none; resize:vertical; box-sizing:border-box;" onfocus="this.style.borderColor='#a78bfa'" onblur="this.style.borderColor='rgba(196,181,253,0.4)'"></textarea>
          </div>
          <button type="submit" style="width:100%; background:linear-gradient(135deg,#7C3AED,#9D5CF6); color:#1e1b4b; border:none; padding:.9rem; border-radius:50px; font-weight:700; font-size:.95rem; font-family:'Heebo',sans-serif; cursor:pointer; box-shadow:0 6px 22px rgba(124,58,237,.45); transition:transform .15s, box-shadow .15s;" onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 8px 28px rgba(124,58,237,.55)'" onmouseout="this.style.transform='';this.style.boxShadow='0 6px 22px rgba(124,58,237,.45)'">
            שליחה &rarr;
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  @media(max-width:768px){
    .contact-grid { grid-template-columns:1fr !important; gap:2rem !important; }
  }
  ::placeholder { color: rgba(139,92,246,0.45) !important; }
</style>
