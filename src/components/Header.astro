---
import { categories } from '../data/categories';
---

<style>
  nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 200;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 6%;
    background: rgba(250,250,250,0.92);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--border);
    transition: box-shadow .3s;
  }
  nav.scrolled { box-shadow: 0 4px 24px rgba(124,58,237,.08); }

  .nav-logo { display:flex; align-items:center; gap:.5rem; text-decoration:none; }
  .nav-logo-mark {
    width:36px; height:36px; border-radius:10px;
    background: linear-gradient(135deg, var(--purple), var(--purple-mid));
    display:flex; align-items:center; justify-content:center;
    color:white; font-weight:900; font-size:.9rem;
  }
  .nav-logo-text { font-size:1.05rem; font-weight:800; color:var(--text); line-height:1; }
  .nav-logo-sub  { font-size:.68rem; color:var(--text-muted); font-weight:400; }

  /* ── Desktop links ── */
  .nav-links { display:flex; align-items:center; gap:1.8rem; list-style:none; margin:0; padding:0; }
  .nav-links a {
    color:var(--text-mid); text-decoration:none;
    font-size:.88rem; font-weight:500;
    position:relative; transition:color .2s;
  }
  .nav-links a::after {
    content:''; position:absolute; bottom:-4px; right:0;
    width:0; height:2px;
    background: linear-gradient(90deg, var(--purple), var(--pink));
    transition: width .3s;
  }
  .nav-links a:hover { color:var(--purple); }
  .nav-links a:hover::after { width:100%; }

  /* Dropdown */
  .dropdown { position:relative; }
  .dropdown-btn {
    background:none; border:none; cursor:pointer;
    color:var(--text-mid); font-size:.88rem; font-weight:500;
    font-family:'Heebo',sans-serif;
    display:flex; align-items:center; gap:.3rem;
    transition:color .2s; padding:0;
  }
  .dropdown-btn:hover { color:var(--purple); }
  .dropdown-menu {
    position:absolute; top:calc(100% + 12px); right:0;
    background:white; border:1px solid var(--border);
    border-radius:16px; padding:.5rem;
    min-width:180px;
    box-shadow:0 16px 40px rgba(124,58,237,.12);
    opacity:0; visibility:hidden;
    transform:translateY(-6px);
    transition:opacity .2s, transform .2s, visibility .2s;
  }
  .dropdown:hover .dropdown-menu {
    opacity:1; visibility:visible; transform:translateY(0);
  }
  .dropdown-menu a {
    display:flex; align-items:center; gap:.6rem;
    padding:.55rem 1rem; border-radius:10px;
    color:var(--text-mid); text-decoration:none;
    font-size:.85rem; font-weight:500;
    transition:background .15s, color .15s;
  }
  .dropdown-menu a:hover { background:var(--purple-light); color:var(--purple); }

  .nav-cta {
    background: #fff;
    color: var(--purple);
    border: 2px solid var(--purple);
    padding:.5rem 1.3rem;
    border-radius:50px; font-weight:700;
    font-size:.85rem; text-decoration:none;
    transition:background .2s, color .2s;
  }
  .nav-cta:hover { background: var(--purple); color: #fff; }
  .nav-cta::after { display:none !important; }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    border-radius: 8px;
    transition: background .2s;
  }
  .hamburger:hover { background: var(--purple-light); }
  .hamburger span {
    display: block;
    height: 2.5px;
    background: var(--text);
    border-radius: 2px;
    transition: transform .3s, opacity .3s;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }

  /* ── Mobile overlay menu ── */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 68px 0 0;
    background: rgba(250,250,250,0.97);
    backdrop-filter: blur(18px);
    z-index: 199;
    overflow-y: auto;
    padding: 1.5rem 6% 3rem;
    flex-direction: column;
    gap: .25rem;
  }
  .mobile-menu.open { display: flex; }

  .mobile-link {
    display: block;
    padding: 1rem 1.2rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    border-radius: 12px;
    transition: background .15s, color .15s, transform .1s;
    -webkit-tap-highlight-color: transparent;
    min-height: 52px;
    display: flex;
    align-items: center;
  }
  .mobile-link:hover { background: var(--purple-light); color: var(--purple); }
  .mobile-link:active { background: #DDD6FE; color: var(--purple); transform: scale(.98); }

  .mobile-ai-link {
    background: linear-gradient(90deg, #6C22FF, #E879F9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 800;
  }
  .mobile-ai-link:hover, .mobile-ai-link:active {
    background: var(--purple-light);
    -webkit-background-clip: unset;
    -webkit-text-fill-color: var(--purple);
  }

  /* Mobile dropdown */
  .mobile-dropdown-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.2rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    background: none;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    font-family: 'Heebo', sans-serif;
    transition: background .15s, transform .1s;
    text-align: right;
    min-height: 52px;
    -webkit-tap-highlight-color: transparent;
  }
  .mobile-dropdown-btn:hover { background: var(--purple-light); color: var(--purple); }
  .mobile-dropdown-btn:active { background: #DDD6FE; color: var(--purple); transform: scale(.98); }
  .mobile-dropdown-btn svg { transition: transform .3s; }
  .mobile-dropdown-btn.open svg { transform: rotate(180deg); }
  .mobile-dropdown-btn.open { background: var(--purple-light); color: var(--purple); }

  .mobile-sub {
    display: none;
    flex-direction: column;
    padding: .25rem 0 .25rem 1rem;
    gap: .1rem;
  }
  .mobile-sub.open { display: flex; }
  .mobile-sub a {
    display: block;
    padding: .85rem 1rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-mid);
    text-decoration: none;
    border-radius: 10px;
    transition: background .15s, color .15s, transform .1s;
    border-right: 2px solid var(--border);
    min-height: 48px;
    display: flex;
    align-items: center;
    -webkit-tap-highlight-color: transparent;
  }
  .mobile-sub a:hover { background: var(--purple-light); color: var(--purple); border-color: var(--purple); }
  .mobile-sub a:active { background: #DDD6FE; color: var(--purple); border-color: var(--purple); transform: scale(.98); }

  .mobile-divider { height: 1px; background: var(--border); margin: .5rem 0; }

  .mobile-cta {
    display: block;
    margin-top: 1rem;
    padding: 1rem;
    background: var(--purple);
    color: white;
    font-size: 1.05rem;
    font-weight: 800;
    text-align: center;
    border-radius: 14px;
    text-decoration: none;
  }

  .spacer { height: 68px; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
  }
</style>

<nav id="main-nav">
  <!-- Logo -->
  <a href="/" class="nav-logo">
    <img src="/logo-matzget.png" alt="מצגת – זה כל הסיפור" style="height:44px; width:auto; display:block;" />
  </a>

  <!-- Desktop links -->
  <ul class="nav-links">
    <li><a href="/שדרוגי-ai" style="background: linear-gradient(90deg, #6C22FF, #E879F9); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 700;">✨ שדרוגי AI</a></li>
    <li class="dropdown">
      <button class="dropdown-btn">
        המצגות שלנו
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div class="dropdown-menu">
        {categories.filter(cat => !cat.hideFromNav).map(cat => (
          <a href={`/מצגות/${cat.key}`}>{cat.label}</a>
        ))}
      </div>
    </li>
    <li><a href="/מחירון">מחירון</a></li>
    <li><a href="/העלאת-קבצים">העלאת קבצים</a></li>
    <li><a href="/שאלות-ותשובות">שאלות ותשובות</a></li>
    <li><a href="/מאמרים">מאמרים</a></li>
    <li><a href="/אודותינו">אודותינו</a></li>
    <li><a href="/#contact" class="nav-cta">צרו קשר</a></li>
  </ul>

  <!-- Hamburger -->
  <button class="hamburger" id="hamburger" aria-label="פתח תפריט" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobile-menu">
  <a href="/שדרוגי-ai" class="mobile-link mobile-ai-link">✨ שדרוגי AI</a>

  <div class="mobile-divider"></div>

  <!-- Dropdown: המצגות שלנו -->
  <button class="mobile-dropdown-btn" id="mobile-dropdown-btn">
    המצגות שלנו
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path d="M19 9l-7 7-7-7"/>
    </svg>
  </button>
  <div class="mobile-sub" id="mobile-sub">
    {categories.filter(cat => !cat.hideFromNav).map(cat => (
      <a href={`/מצגות/${cat.key}`}>{cat.label}</a>
    ))}
  </div>

  <a href="/מחירון" class="mobile-link">מחירון</a>
  <a href="/העלאת-קבצים" class="mobile-link">העלאת קבצים</a>
  <a href="/שאלות-ותשובות" class="mobile-link">שאלות ותשובות</a>
  <a href="/מאמרים" class="mobile-link">מאמרים</a>
  <a href="/אודותינו" class="mobile-link">אודותינו</a>

  <a href="/#contact" class="mobile-cta">צרו קשר</a>
</div>

<div class="spacer"></div>

<script is:inline>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileDropBtn = document.getElementById('mobile-dropdown-btn');
  const mobileSub = document.getElementById('mobile-sub');

  hamburger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('open');
    hamburger.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  mobileDropBtn.addEventListener('click', () => {
    mobileSub.classList.toggle('open');
    mobileDropBtn.classList.toggle('open');
  });

  // Close menu on link click
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburger.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // Scrolled state
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });
</script>
